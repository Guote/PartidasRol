<form class='{{cssClass}}' autocomplete='off'>
  {{#> "systems/animabf-guote/templates/common/ui/group.hbs"
    class="chat-combat-defense-values"
  }}
    {{>
    "systems/animabf-guote/templates/common/ui/group-header.hbs"
      title=(localize 'anima.chat.combat.defense.dialogTitle')
    }}
    {{#> "systems/animabf-guote/templates/common/ui/group-body.hbs"
      class="chat-combat-defense-values"
    }}
      {{!-- Defender info --}}
      <div class="chat-combat-defender-summary">
        <img src="{{this.defender.token.texture.src}}" class="chat-combat-portrait-dialog" alt="{{this.defender.token.name}}" />
        <span class="chat-combat-defender-name-dialog">{{this.defender.token.name}}</span>
      </div>

      {{!-- Attacker info (hidden in standalone mode) --}}
      {{#unless this.standalone}}
      <div class="chat-combat-attacker-summary">
        <img src="{{this.attacker.img}}" class="chat-combat-portrait-mini" alt="{{this.attacker.name}}" />
        <span class="chat-combat-vs-label">{{localize 'anima.chat.combat.defense.vsLabel'}}</span>
        <span class="chat-combat-attacker-name">{{this.attacker.name}}</span>
        <span class="chat-combat-attack-value">({{this.attacker.attackTotal}})</span>
      </div>
      {{/unless}}

      <nav class="abf-tabs sheet-tabs tabs" data-group="primary">
        {{#if (is 'eq' this.defender.actor.system.general.settings.defenseType.value 'resistance')}}
          <a class="item" data-tab="accumulation">Acumulación</a>
        {{/if}}
        <a class="item" data-tab="combat">Armas</a>
        {{#if this.ui.hasMysticSpells}}
          <a class="item" data-tab="mystic">Hechizos</a>
        {{/if}}
        {{#if this.ui.hasPsychicPowers}}
          <a class="item" data-tab="psychic">Poderes Psí.</a>
        {{/if}}
        {{#if this.ui.hasSummons}}
          <a class="item" data-tab="summon">Invocaciones</a>
        {{/if}}
      </nav>

      <section class="sheet-body">
        <div class="tab accumulation" data-group="primary" data-tab="accumulation">
          {{> 'systems/animabf-guote/templates/dialog/combat/chat-combat-defense/parts/accumulation.hbs' this=this}}
        </div>

        <div class="tab combat" data-group="primary" data-tab="combat">
          {{> 'systems/animabf-guote/templates/dialog/combat/chat-combat-defense/parts/combat.hbs' this=this}}
        </div>

        <div class="tab mystic" data-group="primary" data-tab="mystic">
          {{> 'systems/animabf-guote/templates/dialog/combat/chat-combat-defense/parts/mystic.hbs' this=this}}
        </div>

        <div class="tab psychic" data-group="primary" data-tab="psychic">
          {{> 'systems/animabf-guote/templates/dialog/combat/chat-combat-defense/parts/psychic.hbs' this=this}}
        </div>

        <div class="tab summon" data-group="primary" data-tab="summon">
          {{> 'systems/animabf-guote/templates/dialog/combat/chat-combat-defense/parts/summon.hbs' this=this}}
        </div>
      </section>

      {{!-- ═══ DEFENSE DETAILS (shared, rendered once to avoid duplicate inputs) ═══ --}}
      {{#unless this.defenseSent}}
      <div class="dialog-section attack-details-section">
        <div class="dialog-section-label">
          <span class="section-label-text">Modificadores de defensa</span>
          <span class="section-label-line"></span>
          {{#if this.ui.isGM}}
          <label class="show-roll-toggle {{#if this.defender.showRoll}}active{{/if}}"
            title="{{localize 'anima.macros.combat.dialog.showRoll.title'}}">
            <input type="checkbox" name="defender.showRoll"
              {{#if this.defender.showRoll}}checked{{/if}} />
            <i class="fas {{#if this.defender.showRoll}}fa-eye{{else}}fa-eye-slash{{/if}}"></i>
          </label>
          {{/if}}
        </div>

        <div class="attack-details-grid">

          {{!-- Row 1 col 1: HD modifier (driven by active tab via getData) --}}
          <div>
            {{>
            "systems/animabf-guote/templates/common/ui/horizontal-titled-input.hbs"
            title="HD mod."
            inputName=this.ui.activeModifierInputName
            inputValue=this.ui.activeModifierValue
            }}
          </div>

          {{!-- Row 1 col 2: Sin tirar dado --}}
          <div>
            {{>
            "systems/animabf-guote/templates/common/ui/horizontal-titled-input.hbs"
            title="Sin tirar dado"
            inputType="checkbox"
            inputName="defender.withoutRoll"
            inputValue=(is 'eq' this.defender.withoutRoll true)
            }}
          </div>

          {{!-- Row 2 col 1: TA bonus input + type selector inline --}}
          <div class="ta-combined-field">
            {{>
            "systems/animabf-guote/templates/common/ui/horizontal-titled-input.hbs"
            title="TA mod."
            inputName="defender.combat.at.special"
            inputValue=this.defender.combat.at.special
            }}
            {{#> 'systems/animabf-guote/templates/common/ui/custom-select.hbs'
            hideTitle=true
            class="ta-type-select-container"
            inputName="defender.combat.at.type"
            }}
              {{#if config.iterables.combat.weapon.criticTypes}}
                {{selectOptions config.iterables.combat.weapon.criticTypes selected=this.defender.combat.at.type localize=true}}
              {{/if}}
            {{/'systems/animabf-guote/templates/common/ui/custom-select.hbs'}}
          </div>

          {{!-- Row 2 col 2: Mod. Daño enemigo --}}
          <div>
            {{>
            "systems/animabf-guote/templates/common/ui/horizontal-titled-input.hbs"
            title="Mod. Daño enemigo"
            inputName="defender.damageModifier"
            inputValue=this.defender.damageModifier
            }}
          </div>

        </div>
      </div>
      {{/unless}}

      {{!-- ═══ RESUMEN ═══ --}}
      {{#unless this.defenseSent}}
      {{#if this.ui.activeSummary}}
      <div class="combat-summary-bar">
        <span class="summary-item">
          <span class="summary-label">HD</span>
          <span class="summary-value">{{this.ui.activeSummary.hdFinal}}</span>
        </span>
        <span class="summary-item">
          <span class="summary-label">TA</span>
          <span class="summary-value">{{this.ui.activeSummary.taFinal}}</span>
        </span>
        {{#if this.ui.activeSummary.damageModifier}}
        <span class="summary-item">
          <span class="summary-label">Mod. Daño enemigo</span>
          <span class="summary-value">{{this.ui.activeSummary.damageModifier}}</span>
        </span>
        {{/if}}
      </div>
      {{/if}}
      {{/unless}}

      {{!-- ═══ FOOTER ═══ --}}
      {{#if this.defenseSent}}
      <div class='defense-sent'>
        {{>'systems/animabf-guote/templates/common/ui/loading-indicator.hbs' class="big"}}
        <p class='label'>
          {{localize 'anima.macros.combat.dialog.defenseSent.title'}}
        </p>
      </div>
      {{else}}
      <div class="dialog-footer-row">
        <select class="input preset-selector load-defense-preset">
          <option value="">-- {{localize 'anima.ui.combat.newDefense'}} --</option>
          {{#each this.defender.actor.system.combat.defensePresets}}
          <option value="{{this._id}}" {{#if (is 'eq' this._id ../this.selectedPresetId)}}selected{{/if}}>{{this.name}}</option>
          {{/each}}
        </select>
        <button type="button" class="abf-button icon-button save-defense-preset"
          title="{{localize 'anima.ui.combat.saveCurrentTooltip'}}">
          <i class="fas fa-save"></i>
        </button>
        <span></span>
        <button type="button" class="abf-button send-defense dialog-footer-send">
          {{localize 'anima.macros.combat.dialog.defenseButton.title'}}
        </button>
      </div>
      {{/if}}

    {{/"systems/animabf-guote/templates/common/ui/group-body.hbs"}}
  {{/"systems/animabf-guote/templates/common/ui/group.hbs"}}
</form>
