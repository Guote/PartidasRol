<form class="zeon-calculator">

  {{!-- ═══ CONJUROS ═══ --}}
  <div class="zc-section">
    <div class="zc-section-title">Conjuros</div>

    {{#if heldSpellRows.length}}
    <div class="zc-held-rows">
      {{#each heldSpellRows}}
      <div class="zc-held-row">
        <i class="fas fa-lock"></i>
        <span class="zc-held-row__name">{{this.name}}</span>
        <span class="zc-held-row__grade">{{this.grade}}</span>
        <span class="zc-held-row__cost">{{this.zeonCost}} z</span>
      </div>
      {{/each}}
    </div>
    {{/if}}

    {{!-- Spell action buttons --}}
    <div class="zc-add-buttons">
      <button type="button" data-action="add-spell" class="abf-button zc-btn">
        <i class="fas fa-plus"></i> {{localize "anima.ui.zeonCalc.spell.add"}}
      </button>
      <button type="button" data-action="duplicate-spell" class="abf-button zc-btn"
        {{#unless canDuplicate}}disabled{{/unless}}>
        <i class="fas fa-copy"></i> {{localize "anima.ui.zeonCalc.spell.duplicate"}}
      </button>
      <span class="zc-add-buttons__spacer"></span>
      <button type="button" data-action="clear" class="abf-button zc-btn zc-btn--clear">
        <i class="fas fa-trash"></i> Limpiar
      </button>
    </div>

    <div class="zc-spells">
      {{#each spells}}
      <div class="zc-spell-row" data-row-id="{{this.id}}">

        {{!-- Top: spell selector + grade + actions --}}
        <div class="zc-spell-row__top">
          <input type="number" name="spell.{{this.id}}.quantity" value="{{this.quantity}}"
            class="zc-input zc-input--quantity" min="1" max="99">
          <span class="zc-spell-row__qty-sep">×</span>
          <select name="spell.{{this.id}}.spellId" class="zc-select zc-select--spell">
            <option value="">{{localize "anima.ui.zeonCalc.spell.placeholder"}}</option>
            {{#each (groupSpellsByVia @root.actorSpells)}}
            <optgroup label="{{this.label}}">
              {{#each this.spells}}
              <option value="{{this.id}}" {{#if (is "eq" this.id ../../spellId)}}selected{{/if}}>{{this.name}}</option>
              {{/each}}
            </optgroup>
            {{/each}}
          </select>

          <select name="spell.{{this.id}}.grade" class="zc-select zc-select--grade">
            <option value="base" {{#if (is "eq" this.grade "base" )}}selected{{/if}}>{{localize
              "anima.ui.mystic.spell.grade.base.title"}}</option>
            <option value="intermediate" {{#if (is "eq" this.grade "intermediate" )}}selected{{/if}}>{{localize
              "anima.ui.mystic.spell.grade.intermediate.title"}}</option>
            <option value="advanced" {{#if (is "eq" this.grade "advanced" )}}selected{{/if}}>{{localize
              "anima.ui.mystic.spell.grade.advanced.title"}}</option>
            <option value="arcane" {{#if (is "eq" this.grade "arcane" )}}selected{{/if}}>{{localize
              "anima.ui.mystic.spell.grade.arcane.title"}}</option>
          </select>

          <button type="button" data-action="open-spell-sheet" data-spell-id="{{this.spellId}}"
            class="abf-button icon-button zc-icon-btn" style="width:auto!important" {{#unless
            this.spellId}}disabled{{/unless}} title="Abrir ficha del conjuro">
            <i class="fas fa-external-link-alt"></i>
          </button>

          <button type="button" data-action="remove-spell" class="abf-button icon-button zc-icon-btn zc-btn-remove"
            style="width:auto!important" {{#if (is "eq" @root.spells.length 1)}}disabled{{/if}}
            title="Eliminar conjuro">
            <i class="fas fa-times"></i>
          </button>
        </div>

        {{!-- Metamagic perk collapsible --}}
        {{#if @root.perks.length}}
        <details class="zc-perks-details">
          <summary class="zc-perks-summary">Añadir metamagia</summary>
          <div class="zc-perks-grid">
            {{!-- Column 1: Zeon a acumular --}}
            <div class="zc-perks-col zc-perks-col--acum">
              <div class="zc-perks-col__header">Zeon a acumular</div>
              {{#each @root.perks as |perk perkIdx|}}
              {{#each perk.levels as |level levelIdx|}}
              {{#if level.zeon_to_accumulate}}
              <label class="zc-perk-option">
                <input type="checkbox" name="spell.{{../../id}}.perk.{{perkIdx}}.{{levelIdx}}" {{#if (includesPerk
                  ../../selectedPerkLevels perkIdx levelIdx)}}checked{{/if}}>
                <div class="zc-perk-body">
                  <span class="zc-perk-name zc-perk-name--acum">{{perk.name}}{{#if level.name}} ({{level.name}}){{/if}}</span>
                </div>
                <span class="zc-perk-cost zc-perk-cost--acum">+{{level.zeon_to_accumulate}}</span>
              </label>
              {{/if}}
              {{/each}}
              {{/each}}
            </div>
            {{!-- Column 2: Zeon de la reserva (only levels without accumulate to avoid duplication) --}}
            <div class="zc-perks-col zc-perks-col--reserve">
              <div class="zc-perks-col__header">Zeon de la reserva</div>
              {{#each @root.perks as |perk perkIdx|}}
              {{#each perk.levels as |level levelIdx|}}
              {{#if level.zeon_reserve}}
              {{#unless level.zeon_to_accumulate}}
              <label class="zc-perk-option">
                <input type="checkbox" name="spell.{{../../id}}.perk.{{perkIdx}}.{{levelIdx}}" {{#if (includesPerk
                  ../../selectedPerkLevels perkIdx levelIdx)}}checked{{/if}}>
                <div class="zc-perk-body">
                  <span class="zc-perk-name zc-perk-name--reserve">{{perk.name}}{{#if level.name}} ({{level.name}}){{/if}}</span>
                </div>
                <span class="zc-perk-cost zc-perk-cost--reserve">+{{level.zeon_reserve}}</span>
              </label>
              {{/unless}}
              {{/if}}
              {{/each}}
              {{/each}}
            </div>
          </div>
        </details>
        {{/if}}

        {{!-- Spell summary --}}
        <div class="zc-spell-summary">
          <div class="zc-spell-summary__grid">
            <div class="zc-spell-summary__group">
              <span class="zc-spell-summary__group-title">Zeon a acumular</span>
              <div class="zc-spell-summary__row">
                <span class="zc-field__label">Base</span>
                <span class="zc-field__value">{{this.baseZeon}}</span>
                <label class="zc-field__label">Mod.</label>
                <input type="number" name="spell.{{this.id}}.extraAccumulate" value="{{this.extraAccumulate}}"
                  class="zc-input zc-input--xs{{#if this.extraAccumulate}} zc-input--modified{{/if}}" min="0">
                <span class="zc-field__label">Final</span>
                <span class="zc-field__value zc-value--accent">{{this.rowAccumulate}}</span>
              </div>
            </div>
            <div class="zc-spell-summary__group">
              <span class="zc-spell-summary__group-title">Zeon de la reserva</span>
              <div class="zc-spell-summary__row">
                <label class="zc-field__label">Mod. Zeon</label>
                <input type="number" name="spell.{{this.id}}.extraReserve" value="{{this.extraReserve}}"
                  class="zc-input zc-input--xs{{#if this.extraReserve}} zc-input--modified{{/if}}" min="0">
                <span class="zc-field__label">Final</span>
                <span class="zc-field__value zc-value--reserve">{{this.rowReserve}}</span>
              </div>
            </div>
          </div>
          <div class="zc-spell-checkboxes">
            <label class="zc-checkbox-label">
              <input type="checkbox" name="spell.{{this.id}}.castear" {{#if this.castear}}checked{{/if}}>
              Contabilizar para castear
            </label>
            <label class="zc-add-active-label{{#unless this.rowIsUpkeepable}} zc-add-active-label--disabled{{/unless}}">
              <input type="checkbox" name="spell.{{this.id}}.addToActiveSpells"
                {{#if this.addToActiveSpells}}checked{{/if}}
                {{#unless this.rowIsUpkeepable}}disabled{{/unless}}>
              <i class="fas fa-clock"></i> {{localize "anima.ui.combat.addToActiveSpells"}}
              {{#if this.rowMaintenanceCost}}
              <span class="zc-maint-info">({{this.rowMaintenanceCost}}/{{#if this.rowHasDailyMaintenance}}día{{else}}asalto{{/if}})</span>
              {{/if}}
            </label>
          </div>
        </div>

      </div>
      {{/each}}
    </div>

  </div>

  {{!-- ACT --}}
  <div class="zc-section">
    <div class="zc-section-title">ACT</div>
    <table class="zc-act-table">
      <thead>
        <tr>
          <th>ACT</th>
          <th title="Si realizas o realizarás otras acciones activas distintas de magia este asalto, tu ACT base se divide a la mitad">½</th>
          <th>Cansancio</th>
          <th>Extra</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="zc-cell--center">
            <div class="zc-radio-toolbar">
              <input type="radio" id="act-main" name="actChoice" value="main"
                {{#if (is "eq" actChoice "main")}}checked{{/if}}>
              <label for="act-main">Base {{actMainValue}}</label>
              <input type="radio" id="act-alt" name="actChoice" value="alternative"
                {{#if (is "eq" actChoice "alternative")}}checked{{/if}}>
              <label for="act-alt">Alt. {{actAltValue}}</label>
              <input type="radio" id="act-none" name="actChoice" value="none"
                {{#if (is "eq" actChoice "none")}}checked{{/if}}>
              <label for="act-none">No acumular</label>
            </div>
          </td>
          <td class="zc-cell--center">
            <input type="checkbox" name="halfAct" {{#if halfAct}}checked{{/if}}
              title="Si realizas o realizarás otras acciones activas distintas de magia este asalto, tu ACT base se divide a la mitad">
          </td>
          <td class="zc-cell--center">
            <span class="zc-fatigue-row">
              <input type="number" name="fatigue.pointsToUse" value="{{fatigue.pointsToUse}}" min="0"
                class="zc-input zc-input--xs{{#if fatigue.pointsToUse}} zc-input--modified{{/if}}">
              <span class="zc-fatigue-sep">×</span>
              <select name="fatigue.bonusPerPoint" class="zc-select zc-select--sm{{#if (is "neq" fatigue.bonusPerPoint fatigueBonusPerPointDefault)}} zc-select--modified{{/if}}">
                <option value="15" {{#if (is "eq" fatigue.bonusPerPoint 15)}}selected{{/if}}>+15</option>
                <option value="25" {{#if (is "eq" fatigue.bonusPerPoint 25)}}selected{{/if}}>+25</option>
                <option value="40" {{#if (is "eq" fatigue.bonusPerPoint 40)}}selected{{/if}}>+40</option>
              </select>
            </span>
          </td>
          <td class="zc-cell--center">
            <input type="number" name="actModifier" value="{{actModifier}}"
              class="zc-input zc-input--xs{{#if actModifier}} zc-input--modified{{/if}}">
          </td>
        </tr>
      </tbody>
    </table>

    {{!-- Magic type + cast checkbox --}}
    <div class="zc-act-options">
      <div class="zc-radio-toolbar">
        <input type="radio" id="acc-pure" name="accumulationType" value="pure"
          {{#if (is "eq" accumulationType "pure")}}checked{{/if}}>
        <label for="acc-pure">Magia pura</label>
        <input type="radio" id="acc-specific" name="accumulationType" value="specific"
          {{#if (is "eq" accumulationType "specific")}}checked{{/if}}>
        <label for="acc-specific">Conjuro específico</label>
      </div>
      {{#if canHold}}
      <label class="zc-cast-label">
        <input type="checkbox" name="holdThisRound" {{#if holdThisRound}}checked{{/if}}>
        Aguantar conjuro (hasta {{holdRounds}} asaltos)
      </label>
      {{/if}}
    </div>
  </div>

  {{!-- Resumen --}}
  <div class="zc-section">
    <div class="zc-section-title">Resumen</div>
    <table class="zc-summary-table">
      <thead>
        <tr>
          <th>ACT final</th>
          <th>Zeon deseado</th>
          <th title="Se calcula suponiendo que todos los turnos acumularás lo mismo que éste">Turnos</th>
          <th>Castear</th>
          <th>Zeon reserva</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="zc-summary-val">{{thisRound}}</td>
          <td class="zc-summary-val">{{totalToAccumulate}}</td>
          <td class="zc-summary-val zc-summary-val--turns">
            {{#if turnsNeeded}}
              {{turnsNeeded}}
            {{else}}
              {{#if (is "eq" turnsNeeded 0)}}✓{{else}}—{{/if}}
            {{/if}}
          </td>
          <td class="zc-summary-val">
            <label class="zc-cast-label">
              <input type="checkbox" name="castThisRound" {{#if castThisRoundChecked}}checked{{/if}}
              {{#if castThisRoundReadonly}}disabled{{/if}}>
            </label>
          </td>
          <td class="zc-summary-val">{{totalFromReserve}}</td>
        </tr>
      </tbody>
    </table>
  </div>

  {{!-- ═══ FOOTER: initial state → final state | Confirmar ═══ --}}
  <div class="zc-footer">
    <div class="zc-res-group zc-res-group--compact">
      <div class="zc-res">
        <span class="zc-res__label"><i class="fas fa-hat-wizard"></i> Reserva</span>
        <div class="zc-res__values">
          <input type="number" class="zc-res__input zc-res__input--compact" data-actor-update="system.mystic.zeon.value"
            value="{{currentZeon}}">
        </div>
      </div>
      <div class="zc-res-group__sep"></div>
      <div class="zc-res">
        <span class="zc-res__label">Acumulado</span>
        <div class="zc-res__values">
          <input type="number" class="zc-res__input zc-res__input--compact"
            data-actor-update="system.mystic.zeonAccumulated.value" value="{{currentAccumulated}}">
        </div>
      </div>
      {{#if fatigue.pointsToUse}}
      <div class="zc-res-group__sep"></div>
      <div class="zc-res">
        <span class="zc-res__label"><i class="fas fa-bolt" style="color:#d10000;"></i></span>
        <div class="zc-res__values">
          <input type="number" class="zc-res__input zc-res__input--compact"
            data-actor-update="system.characteristics.secondaries.fatigue.value" value="{{currentFatigue}}">
        </div>
      </div>
      {{/if}}
    </div>

    <span class="zc-footer__arrow">→</span>

    <div class="zc-res-group zc-res-group--compact">
      <div class="zc-res">
        <span class="zc-res__label"><i class="fas fa-hat-wizard"></i> Reserva</span>
        <div class="zc-res__values">
          <span class="zc-res__final-val">{{finalZeon}}</span>
        </div>
      </div>
      <div class="zc-res-group__sep"></div>
      <div class="zc-res">
        <span class="zc-res__label">Acumulado</span>
        <div class="zc-res__values">
          <span class="zc-res__final-val">{{finalAccumulated}}</span>
        </div>
      </div>
      {{#if fatigue.pointsToUse}}
      <div class="zc-res-group__sep"></div>
      <div class="zc-res">
        <span class="zc-res__label"><i class="fas fa-bolt" style="color:#d10000;"></i></span>
        <div class="zc-res__values">
          <span class="zc-res__final-val">{{finalFatigue}}</span>
        </div>
      </div>
      {{/if}}
    </div>

    <button type="button" data-action="confirm" class="abf-button zc-btn zc-btn--confirm">
      Confirmar
    </button>
  </div>

  {{#if activeSpellsToAdd.length}}
  <div class="zc-active-list">
    <span class="zc-active-list__label">Nuevos activos:</span>
    <span class="zc-active-list__spells">{{#each activeSpellsToAdd}}{{#if @index}}, {{/if}}{{this.spellName}} ({{this.gradeLabel}}){{/each}}</span>
  </div>
  {{/if}}

</form>

<style>
  .zeon-calculator {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.85rem;
  }

  /* ─── Section wrapper ─── */
  .zc-section {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .zc-section-title {
    font-size: 0.68rem;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #888;
    border-bottom: 1px solid #d8d4c4;
    padding-bottom: 0.15rem;
  }

  /* ─── Initial state: Zeon resources ─── */
  .zc-resources {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .zc-res-group {
    display: flex;
    align-items: stretch;
    background: #fff;
    border: 1px solid #c8c4b4;
    border-radius: 5px;
    overflow: hidden;
  }

  .zc-res-group .zc-res {
    background: none;
    border: none;
    border-radius: 0;
  }

  .zc-res-group__sep {
    width: 1px;
    background: #c8c4b4;
    margin: 0.25rem 0;
  }

  .zc-res {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    padding: 0.3rem 0.6rem;
    background: #fff;
    border: 1px solid #c8c4b4;
    border-radius: 5px;
  }

  .zc-res__label {
    font-weight: bold;
    font-size: 0.7rem;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 0.2rem;
    color: #4a20a0;
  }

  .zc-res__values {
    display: flex;
    align-items: center;
    gap: 1px;
  }

  .zeon-calculator .zc-res__input {
    width: 38px;
    text-align: center;
    font-size: 0.9rem;
    font-weight: 600;
    border: none;
    border-bottom: 1px solid #bbb;
    border-radius: 0;
    padding: 0 2px;
    background: transparent;
  }

  .zeon-calculator .zc-res__input--wide {
    width: 48px;
  }

  .zc-res__sep {
    color: #aaa;
    font-size: 0.82rem;
    padding: 0 1px;
  }

  /* ─── Spell list ─── */
  .zc-spells {
    max-height: 380px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding-right: 0.2rem;
  }

  .zc-spell-row {
    border: 1px solid #d8d4c4;
    border-radius: 4px;
    padding: 0.4rem 0.5rem;
    background: #faf9f5;
  }

  /* Spell row — top line */
  .zc-spell-row__top {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .zc-spell-row__top .zc-select--spell {
    flex: 1 1 0;
    min-width: 0;
  }

  /* Spell summary */
  .zc-spell-summary {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    margin-top: 0.35rem;
  }

  .zc-spell-summary__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }

  .zc-spell-summary__group {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .zc-spell-summary__group-title {
    font-size: 0.65rem;
    font-weight: bold;
    color: #555;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    border-bottom: 1px solid #d8d4c4;
    padding-bottom: 0.1rem;
    white-space: normal;
    line-height: 1.2;
  }

  .zc-spell-summary__row {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    flex-wrap: nowrap;
  }

  .zc-value--accent {
    color: #2a6a20;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .zc-value--reserve {
    color: #20467a;
    font-size: 0.9rem;
    font-weight: 700;
  }

  /* Selects */
  .zc-select {
    background: #e7e5da;
    border: 1px solid #bbb;
    border-radius: 4px;
    padding: 0.1rem 0.2rem;
    font-size: 0.82rem;
  }

  .zc-select--grade {
    width: 90px;
    flex-shrink: 0;
  }

  .zc-select--sm {
    width: 60px;
  }

  /* Icon buttons */
  .zc-icon-btn {
    padding: 0.15rem 0.35rem;
    flex-shrink: 0;
    font-size: 0.78rem;
    color: #555;
  }

  .zc-btn-remove {
    color: #8b2020;
  }

  /* Field label/value */
  .zc-field {
    display: flex;
    flex-direction: column;
  }

  .zc-field__label {
    font-size: 0.68rem;
    color: #777;
    line-height: 1.1;
    white-space: nowrap;
  }

  .zc-field__value {
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.1rem 0;
  }

  /* Inputs — scoped under .zeon-calculator to beat Foundry's
     input[type="number"] { width: 100% } which has specificity (0,1,1),
     higher than a bare class selector (0,1,0). Scoping gives us (0,2,0). */
  .zeon-calculator .zc-input {
    width: 46px;
    text-align: center;
    border: 1px solid #bbb;
    border-radius: 3px;
    padding: 0.1rem 0.2rem;
    font-size: 0.82rem;
  }

  .zeon-calculator .zc-input--sm {
    width: 44px;
    flex: none;
  }

  .zeon-calculator .zc-input--xs {
    width: 32px;
    flex-shrink: 0;
  }

  .zeon-calculator .zc-input--comment-full {
    width: 100%;
    text-align: left;
    font-size: 0.82rem;
    box-sizing: border-box;
  }

  /* Non-default input highlight — rgba(120, 46, 34, 0.25) per styles.md */
  .zc-input--modified,
  .zc-select--modified {
    background: rgba(120, 46, 34, 0.25) !important;
  }

  /* Metamagic collapsible */
  .zc-perks-details {
    margin-top: 0.3rem;
  }

  .zc-perks-summary {
    font-size: 0.78rem;
    color: #7a6030;
    cursor: pointer;
    user-select: none;
  }

  .zc-perks-grid {
    margin-top: 0.3rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }

  .zc-perks-col {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .zc-perks-col__header {
    font-size: 0.65rem;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    padding-bottom: 0.15rem;
    margin-bottom: 0.1rem;
    border-bottom: 1px solid currentColor;
  }

  .zc-perks-col--acum .zc-perks-col__header {
    color: #2a6a20;
  }

  .zc-perks-col--reserve .zc-perks-col__header {
    color: #20467a;
  }

  .zc-perk-option {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.2rem 0.3rem;
    padding: 0.15rem 0.25rem;
    border-radius: 3px;
    cursor: pointer;
