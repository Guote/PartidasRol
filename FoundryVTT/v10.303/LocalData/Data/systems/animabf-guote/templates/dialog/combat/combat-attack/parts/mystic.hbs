{{>
"systems/animabf-guote/templates/common/ui/horizontal-titled-input.hbs"
  title=(localize 'anima.macros.combat.dialog.modifier.title')
  disabled=this.attackSent
  inputName="attacker.mystic.modifier"
  inputValue=this.attacker.mystic.modifier
}}

{{#> 'systems/animabf-guote/templates/common/ui/custom-select.hbs'
  title=(localize 'anima.macros.combat.dialog.magicProjection.title')
  disabled=this.attackSent
  inputName='attacker.mystic.magicProjectionType'
}}
  <option {{#if (is "eq" this.attacker.mystic.magicProjectionType 'normal')}}selected{{/if}} value='normal'>{{concat (localize 'anima.macros.combat.dialog.magicProjection.normal.title') " (" this.attacker.actor.system.mystic.magicProjection.final.value ")" }}</option>
  <option {{#if (is "eq" this.attacker.mystic.magicProjectionType 'offensive')}}selected{{/if}} value='offensive'>{{concat (localize 'anima.macros.combat.dialog.magicProjection.offensive.title') " (" this.attacker.actor.system.mystic.magicProjection.imbalance.offensive.final.value ")" }}</option>
{{/'systems/animabf-guote/templates/common/ui/custom-select.hbs'}}

<div class='common-titled-input'>
  <p class='label'>{{localize 'anima.macros.combat.dialog.spell.title'}}</p>
  <div class='spell-select-row'>
    <select class='input' name='attacker.mystic.spellUsed' {{#if this.attackSent}}disabled{{/if}}>
      {{#each (groupSpellsByVia this.attacker.actor.system.mystic.spells)}}
      <optgroup label="{{this.label}}">
        {{#each this.spells}}
        <option {{#if (is "eq" this._id @root.attacker.mystic.spellUsed)}}selected{{/if}} value='{{this._id}}'>{{this.name}}</option>
        {{/each}}
      </optgroup>
      {{/each}}
    </select>
    <button type="button" class="abf-button open-spell-sheet" title="{{localize 'anima.macros.combat.dialog.spell.open'}}" {{#if this.attackSent}}disabled{{/if}}>
      <i class="fas fa-book-open"></i>
    </button>
  </div>
</div>

{{#> 'systems/animabf-guote/templates/common/ui/custom-select.hbs'
  title=(localize 'anima.macros.combat.dialog.spellGrade.title')
  disabled=this.attackSent
  inputName='attacker.mystic.spellGrade'
}}
  <option {{#if (is "eq" this.attacker.mystic.spellGrade 'base')}}selected{{/if}} value='base'>{{localize 'anima.macros.combat.dialog.spellGrade.base.title'}}</option>
  <option {{#if (is "eq" this.attacker.mystic.spellGrade 'intermediate')}}selected{{/if}} value='intermediate'>{{localize 'anima.macros.combat.dialog.spellGrade.intermediate.title'}}</option>
  <option {{#if (is "eq" this.attacker.mystic.spellGrade 'advanced')}}selected{{/if}} value='advanced'>{{localize 'anima.macros.combat.dialog.spellGrade.advanced.title'}}</option>
  <option {{#if (is "eq" this.attacker.mystic.spellGrade 'arcane')}}selected{{/if}} value='arcane'>{{localize 'anima.macros.combat.dialog.spellGrade.arcane.title'}}</option>
{{/'systems/animabf-guote/templates/common/ui/custom-select.hbs'}}

{{> 'systems/animabf-guote/templates/common/ui/custom-select-choices.hbs'
  disabled=this.attackSent
  choices=config.iterables.combat.weapon.criticTypesWithNone
  title=(localize "anima.macros.combat.dialog.weapon.critic.title")
  inputName='attacker.mystic.critic'
  inputValue=this.attacker.mystic.critic
}}

{{>
"systems/animabf-guote/templates/common/ui/horizontal-titled-input.hbs"
  title=(localize "anima.macros.combat.dialog.damage.title")
  disabled=this.attackSent
  inputName="attacker.mystic.damage"
  inputValue=this.attacker.mystic.damage
}}
{{>
"systems/animabf-guote/templates/common/ui/horizontal-titled-input.hbs"
title='Reducción de TA'
inputName="attacker.mystic.ignoredTA"
inputValue=this.attacker.mystic.ignoredTA
disabled=this.attackSent
}}

{{#if this.attackSent}}
  <div class='mystic-attack-sent'>
    {{>'systems/animabf-guote/templates/common/ui/loading-indicator.hbs' class="big"}}
    <p class='label'>
      {{localize 'anima.macros.combat.dialog.attackSent.title'}}
    </p>
  </div>
{{else}}
  <div class='attack-buttons'>
    <button type="button" class='abf-button send-mystic-attack'>
      {{localize 'anima.macros.combat.dialog.attackButton.title'}}
    </button>
  </div>
{{/if}}
