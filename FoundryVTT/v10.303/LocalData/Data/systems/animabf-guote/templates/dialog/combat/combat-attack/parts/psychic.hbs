{{!-- ═══ TAB CONTENTS: Power & Potential ═══ --}}
<div class="dialog-section">
  <div class="combat-dialog-grid">

    {{!-- Power selector (full width) + open-sheet button --}}
    <div class="combat-grid-full">
      <div class="selector-row">
        {{#> 'systems/animabf-guote/templates/common/ui/custom-select.hbs'
        title=(localize 'anima.macros.combat.dialog.psychicPower.title')
        disabled=this.attackSent
        inputName='attacker.psychic.powerUsed'
        }}
        {{#each this.attacker.actor.system.psychic.psychicPowers}}
        <option {{#if (is "eq" this._id ../this.attacker.psychic.powerUsed)}}selected{{/if}} value='{{this._id}}'>{{this.name}}
          (+{{this.system.bonus.value}})</option>
        {{/each}}
        {{/'systems/animabf-guote/templates/common/ui/custom-select.hbs'}}
        <button type="button" class="abf-button icon-button open-power-sheet"
          title="Abrir ficha del poder"
          {{#if this.attackSent}}disabled{{/if}}>
          <i class="fas fa-external-link-alt"></i>
        </button>
      </div>
    </div>

    {{!-- Roll box: Potential | CV Potencial | Mod | Roll button + result --}}
    <div class="combat-grid-full">
      <div class="roll-input-box">
        <div class="selector-row">
          {{>
          "systems/animabf-guote/templates/common/ui/horizontal-titled-input.hbs"
          title=(localize 'anima.macros.combat.dialog.psychicPotential.title')
          disabled=true
          inputValue=this.attacker.psychic.psychicPotential.final
          }}
          {{#> 'systems/animabf-guote/templates/common/ui/custom-select.hbs'
          title="CV Potencial"
          disabled=this.attackSent
          inputName="attacker.psychic.cvPotencial"
          inputValue=this.attacker.psychic.cvPotencial
          }}
          <option {{#if (is "eq" 0 this.attacker.psychic.cvPotencial)}}selected{{/if}} value='0'>0</option>
          {{#iterateNumber 5}}
          <option {{#if (is "eq" (math this "+" 1) ../this.attacker.psychic.cvPotencial)}}selected{{/if}} value='{{math this "+" 1}}'>{{math this "+" 1}}</option>
          {{/iterateNumber}}
          {{/'systems/animabf-guote/templates/common/ui/custom-select.hbs'}}
          {{>
          "systems/animabf-guote/templates/common/ui/horizontal-titled-input.hbs"
          title="Mod"
          disabled=this.attackSent
          inputName="attacker.psychic.psychicPotential.special"
          inputValue=this.attacker.psychic.psychicPotential.special
          }}
          <button type="button" class="abf-button icon-button roll-psychic-potential"
            title="{{localize 'anima.macros.combat.dialog.rollOnlyPotential.title'}}"
            {{#if this.attackSent}}disabled{{/if}}>
            <i class="fas fa-dice-d20"></i>
          </button>
        </div>
        {{#if this.attacker.psychic.potentialResult}}
        <div class="combat-summary-bar potential-result-bar roll-box-result">
          <span class="summary-item">
            <span class="summary-label">{{localize 'anima.macros.combat.dialog.psychicPotentialResult.title'}}</span>
            <span class="summary-value">{{this.attacker.psychic.potentialResult.total}}</span>
          </span>
        </div>
        {{/if}}
      </div>
    </div>

    {{!-- CV Proyección (half width) --}}
    <div class="combat-grid-half">
      {{#> 'systems/animabf-guote/templates/common/ui/custom-select.hbs'
      title="CV Proyección"
      disabled=this.attackSent
      inputName="attacker.psychic.cvProyeccion"
      inputValue=this.attacker.psychic.cvProyeccion
      }}
      <option {{#if (is "eq" 0 this.attacker.psychic.cvProyeccion)}}selected{{/if}} value='0'>0</option>
      {{#iterateNumber 5}}
      <option {{#if (is "eq" (math this "+" 1) ../this.attacker.psychic.cvProyeccion)}}selected{{/if}} value='{{math this "+" 1}}'>{{math this "+" 1}}</option>
      {{/iterateNumber}}
      {{/'systems/animabf-guote/templates/common/ui/custom-select.hbs'}}
    </div>

  </div>
</div>

{{!-- ═══ ATTACK DETAILS ═══ --}}
<div class="dialog-section attack-details-section">
  {{> 'systems/animabf-guote/templates/dialog/combat/combat-attack/parts/attack-details-header.hbs' this=this}}

  <div class="attack-details-grid">

    {{!-- Row 1: Ataques | Mod. proyección | Sin tirada --}}
    <div>
      {{>
      "systems/animabf-guote/templates/common/ui/horizontal-titled-input.hbs"
      title="Ataques"
      disabled=this.attackSent
      inputName="attacker.attackAccumulation"
      inputValue=this.attacker.attackAccumulation
      }}
    </div>
    <div>
      {{>
      "systems/animabf-guote/templates/common/ui/horizontal-titled-input.hbs"
      title=(localize 'anima.macros.combat.dialog.modifier.title')
      disabled=this.attackSent
      inputName="attacker.psychic.modifier"
      inputValue=this.attacker.psychic.modifier
      }}
    </div>
    <div>
      {{>
      "systems/animabf-guote/templates/common/ui/horizontal-titled-input.hbs"
      title=(localize 'anima.macros.combat.dialog.noRoll.title')
      disabled=this.attackSent
      inputType="checkbox"
      inputName="attacker.withoutRoll"
      inputValue=(is 'eq' this.attacker.withoutRoll true)
      }}
    </div>

    {{!-- Row 2: Daño | Tipo | Red. TA --}}
    <div>
      {{>
      "systems/animabf-guote/templates/common/ui/horizontal-titled-input.hbs"
      title=(localize 'anima.macros.combat.dialog.damage.title')
      disabled=this.attackSent
      inputName="attacker.psychic.damage"
      inputValue=this.attacker.psychic.damage
      }}
    </div>
    <div>
      {{> 'systems/animabf-guote/templates/common/ui/custom-select-choices.hbs'
      disabled=this.attackSent
      choices=config.iterables.combat.weapon.criticTypes
      title=(localize "anima.macros.combat.dialog.weapon.critic.title")
      inputName='attacker.psychic.critic'
      inputValue=this.attacker.psychic.critic
      }}
    </div>
    <div>
      {{>
      "systems/animabf-guote/templates/common/ui/horizontal-titled-input.hbs"
      title='Reduce TA'
      inputName="attacker.psychic.ignoredTA"
      inputValue=this.attacker.psychic.ignoredTA
      disabled=this.attackSent
      }}
    </div>

  </div>
</div>

{{!-- ═══ RESUMEN ═══ --}}
{{#if this.attacker.psychic.summary}}
{{#unless this.attackSent}}
<div class="combat-summary-bar">
  <span class="summary-item">
    <span class="summary-label">HA final</span>
    <span class="summary-value">{{this.attacker.psychic.summary.haFinal}}</span>
  </span>
  <span class="summary-item">
    <span class="summary-label">Daño</span>
    <span class="summary-value">{{this.attacker.psychic.summary.damage}}</span>
  </span>
  <span class="summary-item">
    <span class="summary-label">Red. TA</span>
    <span class="summary-value">{{this.attacker.psychic.summary.ignoredTA}}</span>
  </span>
  {{#if this.attacker.psychic.summary.criticSelected}}
  <span class="summary-item">
    <span class="summary-label">Tipo</span>
    <span class="summary-value">{{localize (concat 'anima.ui.combat.armors.at.' this.attacker.psychic.summary.criticSelected '.title')}}</span>
  </span>
  {{/if}}
</div>
{{/unless}}
{{/if}}

{{!-- ═══ ENVIAR ═══ --}}
{{#if this.attackSent}}
<div class='psychic-attack-sent'>
  {{>'systems/animabf-guote/templates/common/ui/loading-indicator.hbs' class="big"}}
  <p class='label'>
    {{localize 'anima.macros.combat.dialog.attackSent.title'}}
  </p>
</div>
{{else}}
<div class='attack-buttons'>
  <button type="button" class='abf-button send-psychic-attack'>
    {{localize 'anima.macros.combat.dialog.attackButton.title'}}
  </button>
</div>
{{/if}}
