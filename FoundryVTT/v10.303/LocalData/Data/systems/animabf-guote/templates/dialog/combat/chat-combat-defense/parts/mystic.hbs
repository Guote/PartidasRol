{{>
"systems/animabf-guote/templates/common/ui/horizontal-titled-input.hbs"
  title=(localize 'anima.macros.combat.dialog.modifier.title')
  disabled=this.defenseSent
  inputName="defender.mystic.modifier"
  inputValue=this.defender.mystic.modifier
}}

{{#> 'systems/animabf-guote/templates/common/ui/custom-select.hbs'
  title=(localize 'anima.macros.combat.dialog.magicProjection.title')
  disabled=this.defenseSent
  inputName='defender.mystic.magicProjectionType'
}}
  <option {{#if (is "eq" this.defender.mystic.magicProjectionType 'normal')}}selected{{/if}} value='normal'>{{concat (localize 'anima.macros.combat.dialog.magicProjection.normal.title') " (" this.defender.actor.system.mystic.magicProjection.final.value ")" }}</option>
  <option {{#if (is "eq" this.defender.mystic.magicProjectionType 'defensive')}}selected{{/if}} value='defensive'>{{concat (localize 'anima.macros.combat.dialog.magicProjection.defensive.title') " (" this.defender.actor.system.mystic.magicProjection.imbalance.defensive.final.value ")" }}</option>
{{/'systems/animabf-guote/templates/common/ui/custom-select.hbs'}}

<div class='common-titled-input'>
  <p class='label'>{{localize 'anima.macros.combat.dialog.spell.title'}}</p>
  <div class='spell-select-row'>
    <select class='input' name='defender.mystic.spellUsed' {{#if this.defenseSent}}disabled{{/if}}>
      {{#each (groupSpellsByVia this.defender.actor.system.mystic.spells)}}
      <optgroup label="{{this.label}}">
        {{#each this.spells}}
        <option {{#if (is "eq" this._id @root.defender.mystic.spellUsed)}}selected{{/if}} value='{{this._id}}'>{{this.name}}</option>
        {{/each}}
      </optgroup>
      {{/each}}
    </select>
    <button type="button" class="abf-button open-spell-sheet" title="{{localize 'anima.macros.combat.dialog.spell.open'}}" {{#if this.defenseSent}}disabled{{/if}}>
      <i class="fas fa-book-open"></i>
    </button>
  </div>
</div>

{{#> 'systems/animabf-guote/templates/common/ui/custom-select.hbs'
  title=(localize 'anima.macros.combat.dialog.spellGrade.title')
  disabled=this.defenseSent
  inputName='defender.mystic.spellGrade'
}}
  <option {{#if (is "eq" this.defender.mystic.spellGrade 'base')}}selected{{/if}} value='base'>{{localize 'anima.macros.combat.dialog.spellGrade.base.title'}}</option>
  <option {{#if (is "eq" this.defender.mystic.spellGrade 'intermediate')}}selected{{/if}} value='intermediate'>{{localize 'anima.macros.combat.dialog.spellGrade.intermediate.title'}}</option>
  <option {{#if (is "eq" this.defender.mystic.spellGrade 'advanced')}}selected{{/if}} value='advanced'>{{localize 'anima.macros.combat.dialog.spellGrade.advanced.title'}}</option>
  <option {{#if (is "eq" this.defender.mystic.spellGrade 'arcane')}}selected{{/if}} value='arcane'>{{localize 'anima.macros.combat.dialog.spellGrade.arcane.title'}}</option>
{{/'systems/animabf-guote/templates/common/ui/custom-select.hbs'}}

{{#if this.defenseSent}}
  <div class='defense-sent'>
    {{>'systems/animabf-guote/templates/common/ui/loading-indicator.hbs' class="big"}}
    <p class='label'>
      {{localize 'anima.macros.combat.dialog.defenseSent.title'}}
    </p>
  </div>
{{else}}
  <div class='defense-buttons'>
    <button type="button" class='abf-button send-mystic-defense'>
      {{localize 'anima.macros.combat.dialog.defenseButton.title'}} ({{#if (is "eq" this.defender.mystic.magicProjectionType 'defensive')}}{{this.defender.actor.system.mystic.magicProjection.imbalance.defensive.final.value}}{{else}}{{this.defender.actor.system.mystic.magicProjection.final.value}}{{/if}})
    </button>
  </div>
{{/if}}
