{{!-- ═══ TAB CONTENTS: Mystic Defense ═══ --}}
<div class="dialog-section">
  <div class="combat-dialog-grid">

    {{!-- Spell selector | Grade selector | Open sheet button (all inline) --}}
    <div class="combat-grid-full">
      <div class="selector-row">
        <div class='common-titled-input' style="flex: 2 1 0; min-width: 0;">
          <p class='label'>{{localize 'anima.macros.combat.dialog.spell.title'}}</p>
          <select class='input' name='defender.mystic.spellUsed' {{#if this.defenseSent}}disabled{{/if}}>
            {{#each (groupSpellsByVia this.defender.actor.system.mystic.spells)}}
            <optgroup label="{{this.label}}">
              {{#each this.spells}}
              <option {{#if (is "eq" this._id @root.defender.mystic.spellUsed)}}selected{{/if}} value='{{this._id}}'>{{this.name}}</option>
              {{/each}}
            </optgroup>
            {{/each}}
          </select>
        </div>
        <select name='defender.mystic.spellGrade' class="input"
          style="flex: 0 0 auto; min-width: 80px; border-radius: 10px; background: #e7e5da; font-weight: bold; padding: 0.25rem 0.5rem; color: #000;"
          {{#if this.defenseSent}}disabled{{/if}}>
          <option {{#if (is "eq" this.defender.mystic.spellGrade 'base')}}selected{{/if}} value='base'>{{localize 'anima.macros.combat.dialog.spellGrade.base.title'}}</option>
          <option {{#if (is "eq" this.defender.mystic.spellGrade 'intermediate')}}selected{{/if}} value='intermediate'>{{localize 'anima.macros.combat.dialog.spellGrade.intermediate.title'}}</option>
          <option {{#if (is "eq" this.defender.mystic.spellGrade 'advanced')}}selected{{/if}} value='advanced'>{{localize 'anima.macros.combat.dialog.spellGrade.advanced.title'}}</option>
          <option {{#if (is "eq" this.defender.mystic.spellGrade 'arcane')}}selected{{/if}} value='arcane'>{{localize 'anima.macros.combat.dialog.spellGrade.arcane.title'}}</option>
        </select>
        <button type="button" class="abf-button icon-button open-spell-sheet"
          title="{{localize 'anima.macros.combat.dialog.spell.open'}}"
          {{#if this.defenseSent}}disabled{{/if}}>
          <i class="fas fa-book-open"></i>
        </button>
      </div>
    </div>

  </div>
</div>
