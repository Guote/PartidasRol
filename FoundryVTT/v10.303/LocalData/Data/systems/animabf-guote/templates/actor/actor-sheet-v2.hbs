<form class="{{cssClass}} actor-sheet-v2" autocomplete="off">
  {{!-- Compact Header Section --}}
  {{> "systems/animabf-guote/templates/actor-v2/parts/header/header-v2.hbs"}}

  {{!-- Main Content: Side Tabs + Tab Content --}}
  <div class="v2-main">
    {{!-- Side Tab Navigation --}}
    <nav class="v2-sidetabs sheet-tabs tabs" data-group="primary">
      <a class="v2-sidetabs__tab item" data-tab="combat" title="{{localize 'anima.ui.tabs.combat'}}">
        <i class="fas fa-swords"></i>
        <span>{{localize "anima.ui.tabs.combat"}}</span>
      </a>
      <a class="v2-sidetabs__tab item" data-tab="skills" title="{{localize 'anima.ui.tabs.skills'}}">
        <i class="fas fa-book"></i>
        <span>{{localize "anima.ui.tabs.skills"}}</span>
      </a>
      <a class="v2-sidetabs__tab item" data-tab="bio" title="{{localize 'anima.ui.tabs.bio'}}">
        <i class="fas fa-user"></i>
        <span>{{localize "anima.ui.tabs.bio"}}</span>
      </a>
      <a class="v2-sidetabs__tab item" data-tab="inventory" title="{{localize 'anima.ui.tabs.inventory'}}">
        <i class="fas fa-backpack"></i>
        <span>{{localize "anima.ui.tabs.inventory"}}</span>
      </a>
      {{#if system.ui.tabVisibility.mystic.value}}
      <a class="v2-sidetabs__tab item" data-tab="mystic" title="{{localize 'anima.ui.tabs.mystic'}}">
        <i class="fas fa-hat-wizard"></i>
        <span>{{localize "anima.ui.tabs.mystic"}}</span>
      </a>
      {{/if}}
      {{#if system.ui.tabVisibility.domine.value}}
      <a class="v2-sidetabs__tab item" data-tab="domine" title="{{localize 'anima.ui.tabs.domine'}}">
        <i class="fas fa-yin-yang"></i>
        <span>{{localize "anima.ui.tabs.domine"}}</span>
      </a>
      {{/if}}
      {{#if system.ui.tabVisibility.psychic.value}}
      <a class="v2-sidetabs__tab item" data-tab="psychic" title="{{localize 'anima.ui.tabs.psychic'}}">
        <i class="fas fa-brain"></i>
        <span>{{localize "anima.ui.tabs.psychic"}}</span>
      </a>
      {{/if}}
      <a class="v2-sidetabs__tab v2-sidetabs__tab--settings item" data-tab="settings" title="Settings">
        <i class="fas fa-cog"></i>
      </a>
    </nav>

    {{!-- Tab Content --}}
    <section class="v2-body sheet-body">
      {{!-- Combat Tab --}}
      <div class="v2-body__tab tab combat" data-group="primary" data-tab="combat">
        {{> "systems/animabf-guote/templates/actor-v2/parts/tabs/combat.hbs"}}
      </div>

      {{!-- Skills Tab --}}
      <div class="v2-body__tab tab skills" data-group="primary" data-tab="skills">
        {{> "systems/animabf-guote/templates/actor-v2/parts/tabs/skills.hbs"}}
      </div>

      {{!-- Bio Tab --}}
      <div class="v2-body__tab tab bio" data-group="primary" data-tab="bio">
        {{> "systems/animabf-guote/templates/actor-v2/parts/tabs/bio.hbs"}}
      </div>

      {{!-- Inventory Tab --}}
      <div class="v2-body__tab tab inventory" data-group="primary" data-tab="inventory">
        {{> "systems/animabf-guote/templates/actor-v2/parts/tabs/inventory.hbs"}}
      </div>

      {{!-- Mystic Tab (Conditional) --}}
      <div class="v2-body__tab tab mystic" data-group="primary" data-tab="mystic">
        {{> "systems/animabf-guote/templates/actor-v2/parts/tabs/mystic.hbs"}}
      </div>

      {{!-- Domine Tab (Conditional) --}}
      <div class="v2-body__tab tab domine" data-group="primary" data-tab="domine">
        {{> "systems/animabf-guote/templates/actor-v2/parts/tabs/domine.hbs"}}
      </div>

      {{!-- Psychic Tab (Conditional) --}}
      <div class="v2-body__tab tab psychic" data-group="primary" data-tab="psychic">
        {{> "systems/animabf-guote/templates/actor-v2/parts/tabs/psychic.hbs"}}
      </div>

      {{!-- Settings Tab --}}
      <div class="v2-body__tab tab settings" data-group="primary" data-tab="settings">
        {{> "systems/animabf-guote/templates/actor-v2/parts/tabs/settings.hbs"}}
      </div>
    </section>
  </div>
</form>
