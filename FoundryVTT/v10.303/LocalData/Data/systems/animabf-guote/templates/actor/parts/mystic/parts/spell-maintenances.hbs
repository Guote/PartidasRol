{{#> "systems/animabf-guote/templates/common/ui/group.hbs"
  class="spell-maintenances"
}}
  {{>
  "systems/animabf-guote/templates/common/ui/group-header.hbs"
    title=(localize "anima.ui.mystic.spellMaintenances.title")
    addRowButtonData="add-spell-maintenance"
  }}
  {{#> "systems/animabf-guote/templates/common/ui/group-body.hbs"
    class="spell-maintenances"
  }}
    {{#if system.mystic.spellMaintenances.length}}
    <table class="spell-maintenances-table" id="spell-maintenances-context-menu-container">
      <thead>
        <tr>
          <th title="{{localize 'anima.ui.mystic.spellMaintenance.active.title'}}">✓</th>
          <th>{{localize 'anima.ui.mystic.spellMaintenance.name.title'}}</th>
          <th>{{localize 'anima.ui.mystic.spellMaintenance.grade.title'}}</th>
          <th title="{{localize 'anima.ui.mystic.spellMaintenance.roundCost.title'}}">{{localize 'anima.ui.mystic.spellMaintenance.roundCost.title'}}</th>
          <th title="+Mod">+</th>
          <th title="{{localize 'anima.ui.mystic.spellMaintenance.cost.title'}}">{{localize 'anima.ui.mystic.spellMaintenance.cost.title'}}</th>
          <th title="+Mod">+</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {{#each system.mystic.spellMaintenances as |spellMaintenance|}}
        <tr data-item-id='{{spellMaintenance._id}}' class='spell-maintenance-row{{#unless spellMaintenance.system.active.value}} sm-row--inactive{{/unless}}'>
          <td class="sm-col--active">
            <input type="hidden"
              name="{{concat 'system.dynamic.spellMaintenances.' spellMaintenance._id '.system.spellId.value'}}"
              value="{{spellMaintenance.system.spellId.value}}">
            <input type="checkbox"
              name="{{concat 'system.dynamic.spellMaintenances.' spellMaintenance._id '.system.active.value'}}"
              {{#if spellMaintenance.system.active.value}}checked{{/if}}>
          </td>
          <td class="sm-col--name">
            <input type="text" class="v2-input"
              name="{{concat 'system.dynamic.spellMaintenances.' spellMaintenance._id '.name'}}"
              value="{{spellMaintenance.name}}">
          </td>
          <td class="sm-col--grade">
            <select class="v2-select sm-grade-select"
              name="{{concat 'system.dynamic.spellMaintenances.' spellMaintenance._id '.system.grade.value'}}"
              data-spell-id="{{spellMaintenance.system.spellId.value}}"
              data-item-id="{{spellMaintenance._id}}">
              <option value="" {{#unless spellMaintenance.system.grade.value}}selected{{/unless}}>—</option>
              <option value="base" {{#if (is "eq" spellMaintenance.system.grade.value "base")}}selected{{/if}}>{{localize 'anima.macros.combat.dialog.spellGrade.base.title'}}</option>
              <option value="intermediate" {{#if (is "eq" spellMaintenance.system.grade.value "intermediate")}}selected{{/if}}>{{localize 'anima.macros.combat.dialog.spellGrade.intermediate.title'}}</option>
              <option value="advanced" {{#if (is "eq" spellMaintenance.system.grade.value "advanced")}}selected{{/if}}>{{localize 'anima.macros.combat.dialog.spellGrade.advanced.title'}}</option>
              <option value="arcane" {{#if (is "eq" spellMaintenance.system.grade.value "arcane")}}selected{{/if}}>{{localize 'anima.macros.combat.dialog.spellGrade.arcane.title'}}</option>
            </select>
          </td>
          <td class="sm-col--cost">
            <input type="number" class="v2-input v2-input--number"
              name="{{concat 'system.dynamic.spellMaintenances.' spellMaintenance._id '.system.roundCost.value'}}"
              value="{{spellMaintenance.system.roundCost.value}}">
          </td>
          <td class="sm-col--mod">
            <input type="number" class="v2-input v2-input--number"
              name="{{concat 'system.dynamic.spellMaintenances.' spellMaintenance._id '.system.roundCostMod.value'}}"
              value="{{spellMaintenance.system.roundCostMod.value}}">
          </td>
          <td class="sm-col--cost">
            <input type="number" class="v2-input v2-input--number"
              name="{{concat 'system.dynamic.spellMaintenances.' spellMaintenance._id '.system.cost.value'}}"
              value="{{spellMaintenance.system.cost.value}}">
          </td>
          <td class="sm-col--mod">
            <input type="number" class="v2-input v2-input--number"
              name="{{concat 'system.dynamic.spellMaintenances.' spellMaintenance._id '.system.dayCostMod.value'}}"
              value="{{spellMaintenance.system.dayCostMod.value}}">
          </td>
          <td class="sm-col--delete"></td>
        </tr>
        {{/each}}
      </tbody>
    </table>
    {{/if}}
  {{/"systems/animabf-guote/templates/common/ui/group-body.hbs"}}
{{/"systems/animabf-guote/templates/common/ui/group.hbs"}}
