{{#> "systems/animabf-guote/templates/common/ui/group.hbs"
  class="abf-chat-message chat-combat-result-card"
}}
  {{> "systems/animabf-guote/templates/common/ui/group-header.hbs"
    title=(localize "anima.chat.combat.result.title")
  }}
  {{#> "systems/animabf-guote/templates/common/ui/group-body.hbs"}}
    <div class="chat-combat-result-body">
      <div class="chat-combat-attacker-summary">
        <img src="{{attacker.img}}" class="chat-combat-portrait-small" alt="{{attacker.name}}" />
        <span class="chat-combat-attacker-name">{{attacker.name}}</span>
        <span class="chat-combat-attack-summary">
          (HA: {{attackTotal}}, {{localize "anima.chat.combat.baseDamage"}}: {{baseDamage}})
        </span>
      </div>

      <table class="chat-combat-results-table">
        <thead>
          <tr>
            <th>{{localize "anima.chat.combat.result.defender"}}</th>
            <th>{{localize "anima.chat.combat.result.outcome"}}</th>
            <th>{{localize "anima.chat.combat.result.action"}}</th>
          </tr>
        </thead>
        <tbody>
          {{#each results}}
            <tr data-defender-id="{{defenderTokenId}}">
              <td>
                <div class="chat-combat-defender-cell">
                  <img src="{{defenderImg}}" class="chat-combat-portrait-tiny" alt="{{defenderName}}" />
                  <span class="chat-combat-defender-name">{{defenderName}}</span>
                </div>
              </td>
              <td class="chat-combat-outcome-cell">
                {{#if canCounter}}
                  <span class="chat-combat-counter-result">
                    <i class="fas fa-shield-alt"></i>
                    {{localize "anima.chat.combat.result.counter"}}
                    <span class="chat-combat-counter-bonus">+{{counterBonus}}</span>
                  </span>
                {{else if (is "gt" damage 0)}}
                  <span class="chat-combat-damage-result">
                    <i class="fas fa-heart-broken"></i>
                    {{damage}} {{localize "anima.chat.combat.result.damage"}}
                  </span>
                {{else}}
                  <span class="chat-combat-miss-result">
                    <i class="fas fa-times"></i>
                    {{localize "anima.chat.combat.result.miss"}}
                  </span>
                {{/if}}
              </td>
              <td class="chat-combat-action-cell">
                {{#if canCounter}}
                  <span class="chat-combat-counter-info">
                    {{localize "anima.chat.combat.result.counterBonus"}}: +{{counterBonus}}
                  </span>
                {{else if (and (is "gt" damage 0) (not damageApplied))}}
                  <button class="chat-combat-apply-damage abf-button small" data-defender-id="{{defenderTokenId}}">
                    <i class="fas fa-check"></i>
                    {{localize "anima.chat.combat.result.applyDamage"}}
                  </button>
                {{else if damageApplied}}
                  <span class="chat-combat-damage-applied">
                    <i class="fas fa-check-circle"></i>
                    {{localize "anima.chat.combat.result.applied"}}
                  </span>
                {{/if}}
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  {{/"systems/animabf-guote/templates/common/ui/group-body.hbs"}}
{{/"systems/animabf-guote/templates/common/ui/group.hbs"}}
