{{#> "systems/animabf-guote/templates/common/ui/group.hbs"
  class="abf-chat-message abf-defense-result-card"
}}
  {{> "systems/animabf-guote/templates/common/ui/group-header.hbs"
    title=(localize "anima.chat.defenseResult.title")
  }}
  {{#> "systems/animabf-guote/templates/common/ui/group-body.hbs"}}
    <div class="chat-combat-defense-body">
      {{!-- Defender info --}}
      <div class="chat-combat-defender-info">
        <img src="{{defenderImg}}" class="chat-combat-portrait" alt="{{defenderName}}" />
        <div class="chat-combat-defender-details">
          <span class="chat-combat-name">{{defenderName}}</span>
          <span class="chat-combat-defense-type">{{defenseTypeLabel}}</span>
          <span class="chat-combat-standalone-flavor">{{localize "anima.chat.defenseResult.standalone"}}</span>
        </div>
      </div>

      {{!-- Defense total --}}
      <div class="chat-combat-values">
        <div class="chat-combat-value-row">
          <span class="chat-combat-label">{{localize "anima.chat.combat.defenseTotal"}}</span>
          <span class="chat-combat-value">{{defenseTotal}}</span>
        </div>
      </div>

      {{!-- Roll breakdown (collapsible) --}}
      {{#if roll}}
      <details class="chat-combat-details">
        <summary>{{localize "anima.chat.combat.details"}}</summary>
        <div class="chat-combat-values">
          {{#if roll.base}}
          <div class="chat-combat-value-row">
            <span class="chat-combat-label">{{localize "anima.chat.combat.defense.title"}}</span>
            <span class="chat-combat-value">{{roll.base}}</span>
          </div>
          {{/if}}
          {{#if roll.modifier}}
          <div class="chat-combat-value-row">
            <span class="chat-combat-label">{{localize "anima.chat.combat.defense.vsLabel"}}</span>
            <span class="chat-combat-value">{{roll.modifier}}</span>
          </div>
          {{/if}}
          {{#if roll.dice}}
          <div class="chat-combat-value-row">
            <span class="chat-combat-label">1d100</span>
            <span class="chat-combat-value">{{roll.dice}}</span>
          </div>
          {{/if}}
        </div>
      </details>
      {{/if}}
    </div>
  {{/"systems/animabf-guote/templates/common/ui/group-body.hbs"}}
{{/"systems/animabf-guote/templates/common/ui/group.hbs"}}
