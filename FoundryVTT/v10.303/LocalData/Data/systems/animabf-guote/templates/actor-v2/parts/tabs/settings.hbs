{{!-- Settings Tab --}}
<div class="v2-tab-settings">
  {{!-- Tab Visibility --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <span>{{localize "anima.ui.settings.tabVisibility.title"}}</span>
    </div>
    <div class="v2-card__body">
      <div class="v2-grid v2-grid--3">
        <label class="v2-checkbox-label">
          <input type="checkbox"
                 name="system.ui.tabVisibility.mystic.value"
                 {{checked system.ui.tabVisibility.mystic.value}}>
          {{localize "anima.ui.tabs.mystic"}}
        </label>
        <label class="v2-checkbox-label">
          <input type="checkbox"
                 name="system.ui.tabVisibility.domine.value"
                 {{checked system.ui.tabVisibility.domine.value}}>
          {{localize "anima.ui.tabs.domine"}}
        </label>
        <label class="v2-checkbox-label">
          <input type="checkbox"
                 name="system.ui.tabVisibility.psychic.value"
                 {{checked system.ui.tabVisibility.psychic.value}}>
          {{localize "anima.ui.tabs.psychic"}}
        </label>
      </div>
    </div>
  </div>

  {{!-- Resource Visibility --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <span>{{localize "anima.ui.settings.resourceVisibility.title"}}</span>
    </div>
    <div class="v2-card__body">
      <p class="v2-text-muted" style="font-size: var(--font-size-xs); margin-bottom: var(--space-3);">
        {{localize "anima.ui.settings.resourceVisibility.description"}}
      </p>
      <div class="v2-grid v2-grid--3" style="gap: var(--space-2);">
        {{!-- Core Resources --}}
        <label class="v2-checkbox-label">
          <input type="checkbox"
                 name="system.ui.resourceVisibility.hp.value"
                 {{checked system.ui.resourceVisibility.hp.value}}>
          <i class="fas fa-heart" style="color: var(--abf-hp);"></i> PV
        </label>
        <label class="v2-checkbox-label">
          <input type="checkbox"
                 name="system.ui.resourceVisibility.fatigue.value"
                 {{checked system.ui.resourceVisibility.fatigue.value}}>
          <i class="fas fa-bolt" style="color: var(--abf-fatigue);"></i> Cansancio
        </label>
        <label class="v2-checkbox-label">
          <input type="checkbox"
                 name="system.ui.resourceVisibility.destiny.value"
                 {{checked system.ui.resourceVisibility.destiny.value}}>
          <i class="fas fa-star" style="color: var(--abf-destiny);"></i> Destino
        </label>

        {{!-- Mystic Resources --}}
        <label class="v2-checkbox-label">
          <input type="checkbox"
                 name="system.ui.resourceVisibility.zeon.value"
                 {{checked system.ui.resourceVisibility.zeon.value}}>
          <i class="fas fa-hat-wizard" style="color: var(--abf-zeon);"></i> Zeon
        </label>
        <label class="v2-checkbox-label">
          <input type="checkbox"
                 name="system.ui.resourceVisibility.zeonAccumulated.value"
                 {{checked system.ui.resourceVisibility.zeonAccumulated.value}}>
          <i class="fas fa-hat-wizard" style="color: var(--abf-zeon);"></i> Zeon Acum.
        </label>
        <label class="v2-checkbox-label">
          <input type="checkbox"
                 name="system.ui.resourceVisibility.shield.value"
                 {{checked system.ui.resourceVisibility.shield.value}}>
          <i class="fas fa-shield-alt" style="color: #4fc3f7;"></i> Escudo
        </label>

        {{!-- Domine Resources --}}
        <label class="v2-checkbox-label">
          <input type="checkbox"
                 name="system.ui.resourceVisibility.ki.value"
                 {{checked system.ui.resourceVisibility.ki.value}}>
          <i class="fas fa-yin-yang" style="color: var(--abf-ki);"></i> Ki
        </label>
        <label class="v2-checkbox-label">
          <input type="checkbox"
                 name="system.ui.resourceVisibility.kiAccumulated.value"
                 {{checked system.ui.resourceVisibility.kiAccumulated.value}}>
          <i class="fas fa-yin-yang" style="color: var(--abf-ki);"></i> Ki Acum.
        </label>

        {{!-- Psychic Resources --}}
        <label class="v2-checkbox-label">
          <input type="checkbox"
                 name="system.ui.resourceVisibility.psychicPoints.value"
                 {{checked system.ui.resourceVisibility.psychicPoints.value}}>
          <i class="fas fa-brain" style="color: var(--abf-psychic);"></i> CV Psiquicos
        </label>
      </div>
    </div>
  </div>

  {{!-- Advanced Settings --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <span>{{localize "anima.ui.settings.advancedSettings.title"}}</span>
    </div>
    <div class="v2-card__body">
      <div class="v2-grid v2-grid--2" style="gap: var(--space-3);">
        <div>
          <label class="v2-text-muted" style="font-size: var(--font-size-xs);">{{localize "anima.ui.settings.advancedSettings.openRolls.title"}}</label>
          <select class="v2-select" name="system.general.settings.openRolls.value">
            <option value="0" {{#if (is 'eq' system.general.settings.openRolls.value 0)}}selected{{/if}}>-</option>
            <option value="90" {{#if (is 'eq' system.general.settings.openRolls.value 90)}}selected{{/if}}>90+</option>
            <option value="91" {{#if (is 'eq' system.general.settings.openRolls.value 91)}}selected{{/if}}>91+</option>
          </select>
        </div>
        <div>
          <label class="v2-text-muted" style="font-size: var(--font-size-xs);">{{localize "anima.ui.settings.advancedSettings.fumbles.title"}}</label>
          <select class="v2-select" name="system.general.settings.fumbles.value">
            <option value="0" {{#if (is 'eq' system.general.settings.fumbles.value 0)}}selected{{/if}}>-</option>
            <option value="1" {{#if (is 'eq' system.general.settings.fumbles.value 1)}}selected{{/if}}>1-3</option>
            <option value="2" {{#if (is 'eq' system.general.settings.fumbles.value 2)}}selected{{/if}}>1-5</option>
          </select>
        </div>
        <div>
          <label class="v2-checkbox-label">
            <input type="checkbox"
                   name="system.general.settings.openOnDoubles.value"
                   {{checked system.general.settings.openOnDoubles.value}}>
            {{localize "anima.ui.settings.advancedSettings.doubles"}}
          </label>
        </div>
        <div>
          <label class="v2-text-muted" style="font-size: var(--font-size-xs);">{{localize "anima.ui.settings.advancedSettings.defenseType.title"}}</label>
          <select class="v2-select" name="system.general.settings.defenseType.value">
            <option value="" {{#unless system.general.settings.defenseType.value}}selected{{/unless}}>{{localize "anima.ui.settings.advancedSettings.defenseType.normal.title"}}</option>
            <option value="dodge" {{#if (is 'eq' system.general.settings.defenseType.value 'dodge')}}selected{{/if}}>{{localize "anima.ui.combat.baseValues.dodge.title"}}</option>
            <option value="block" {{#if (is 'eq' system.general.settings.defenseType.value 'block')}}selected{{/if}}>{{localize "anima.ui.combat.baseValues.block.title"}}</option>
          </select>
        </div>
      </div>
    </div>
  </div>
</div>
