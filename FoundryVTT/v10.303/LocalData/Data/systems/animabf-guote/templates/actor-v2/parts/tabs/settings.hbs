{{!-- Settings Tab --}}
<div class="v2-tab-settings">
  {{!-- Tab Visibility --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <span>{{localize "anima.ui.settings.tabVisibility.title"}}</span>
    </div>
    <div class="v2-card__body">
      <div class="v2-grid v2-grid--3">
        <div class="v2-res-toggle-group">
          <label class="v2-checkbox-label">
            <input type="checkbox"
                   name="system.ui.tabVisibility.mystic.value"
                   {{checked system.ui.tabVisibility.mystic.value}}>
            {{localize "anima.ui.tabs.mystic"}}
          </label>
          <label class="v2-checkbox-label v2-checkbox-label--sub">
            <input type="checkbox"
                   name="system.ui.tabVisibility.grimoire.value"
                   {{checked system.ui.tabVisibility.grimoire.value}}>
            <i class="fas fa-book-spells"></i> Grimorio
          </label>
          <label class="v2-checkbox-label v2-checkbox-label--sub">
            <input type="checkbox"
                   name="system.ui.tabVisibility.summoning.value"
                   {{checked system.ui.tabVisibility.summoning.value}}>
            <i class="fas fa-ghost"></i> {{localize "anima.ui.tabs.summoning"}}
          </label>
        </div>
        <label class="v2-checkbox-label">
          <input type="checkbox"
                 name="system.ui.tabVisibility.domine.value"
                 {{checked system.ui.tabVisibility.domine.value}}>
          {{localize "anima.ui.tabs.domine"}}
        </label>
        <label class="v2-checkbox-label">
          <input type="checkbox"
                 name="system.ui.tabVisibility.psychic.value"
                 {{checked system.ui.tabVisibility.psychic.value}}>
          {{localize "anima.ui.tabs.psychic"}}
        </label>
      </div>
    </div>
  </div>

  {{!-- Resource Visibility --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <span>{{localize "anima.ui.settings.resourceVisibility.title"}}</span>
      <button type="button" class="v2-barbrawl-btn" data-action="configurar-barras-brawl"
        title="Aplicar barras BarBrawl al actor y todos sus tokens">
        <i class="fas fa-sync-alt"></i> Barras al token
      </button>
    </div>
    <div class="v2-card__body">
      <div class="v2-res-vis-grid">
        {{!-- Row 1 --}}
        <div class="v2-res-vis-entry">
          <span class="v2-res-vis-entry__name"><i class="fas fa-heart" style="color: var(--abf-hp);"></i> PV</span>
          <div class="v2-res-vis-entry__btns">
            {{> "systems/animabf-guote/templates/actor-v2/components/vis-btn.hbs" name="system.ui.tokenBarVisibility.hp.value" value=system.ui.tokenBarVisibility.hp.value icon="fa-user-circle" title="Barra en token"}}
            {{> "systems/animabf-guote/templates/actor-v2/components/vis-btn.hbs" name="system.ui.resourceVisibility.hp.value" value=system.ui.resourceVisibility.hp.value icon="fa-scroll" title="Visible en ficha"}}
          </div>
        </div>
        <div class="v2-res-vis-entry v2-res-vis-entry--sub">
          <span class="v2-res-vis-entry__name"><i class="fas fa-heart-broken" style="color: var(--abf-hp);"></i> Vida Sacrif.</span>
          <div class="v2-res-vis-entry__btns">
            <span class="v2-vis-btn v2-vis-btn--empty"></span>
            {{> "systems/animabf-guote/templates/actor-v2/components/vis-btn.hbs" name="system.ui.resourceVisibility.sacrificedLife.value" value=system.ui.resourceVisibility.sacrificedLife.value icon="fa-scroll" title="Visible en ficha"}}
          </div>
        </div>
        <div class="v2-res-vis-entry">
          <span class="v2-res-vis-entry__name"><i class="fas fa-bolt" style="color: var(--abf-fatigue);"></i> Cansancio</span>
          <div class="v2-res-vis-entry__btns">
            {{> "systems/animabf-guote/templates/actor-v2/components/vis-btn.hbs" name="system.ui.tokenBarVisibility.fatigue.value" value=system.ui.tokenBarVisibility.fatigue.value icon="fa-user-circle" title="Barra en token"}}
            {{> "systems/animabf-guote/templates/actor-v2/components/vis-btn.hbs" name="system.ui.resourceVisibility.fatigue.value" value=system.ui.resourceVisibility.fatigue.value icon="fa-scroll" title="Visible en ficha"}}
          </div>
        </div>
        <div class="v2-res-vis-entry">
          <span class="v2-res-vis-entry__name"><i class="fas fa-star" style="color: var(--abf-destiny);"></i> Destino</span>
          <div class="v2-res-vis-entry__btns">
            <span class="v2-vis-btn v2-vis-btn--empty"></span>
            {{> "systems/animabf-guote/templates/actor-v2/components/vis-btn.hbs" name="system.ui.resourceVisibility.destiny.value" value=system.ui.resourceVisibility.destiny.value icon="fa-scroll" title="Visible en ficha"}}
          </div>
        </div>

        {{!-- Row 2 --}}
        <div class="v2-res-vis-entry">
          <span class="v2-res-vis-entry__name"><i class="fas fa-hat-wizard" style="color: var(--abf-zeon);"></i> Zeon</span>
          <div class="v2-res-vis-entry__btns">
            {{> "systems/animabf-guote/templates/actor-v2/components/vis-btn.hbs" name="system.ui.tokenBarVisibility.zeon.value" value=system.ui.tokenBarVisibility.zeon.value icon="fa-user-circle" title="Barra en token"}}
            {{> "systems/animabf-guote/templates/actor-v2/components/vis-btn.hbs" name="system.ui.resourceVisibility.zeon.value" value=system.ui.resourceVisibility.zeon.value icon="fa-scroll" title="Visible en ficha"}}
          </div>
        </div>
        <div class="v2-res-vis-entry v2-res-vis-entry--sub">
          <span class="v2-res-vis-entry__name"><i class="fas fa-hat-wizard" style="color: var(--abf-zeon);"></i> Zeon Acum.</span>
          <div class="v2-res-vis-entry__btns">
            <span class="v2-vis-btn v2-vis-btn--empty"></span>
            {{> "systems/animabf-guote/templates/actor-v2/components/vis-btn.hbs" name="system.ui.resourceVisibility.zeonAccumulated.value" value=system.ui.resourceVisibility.zeonAccumulated.value icon="fa-scroll" title="Visible en ficha"}}
          </div>
        </div>
        <div class="v2-res-vis-entry">
          <span class="v2-res-vis-entry__name"><i class="fas fa-yin-yang" style="color: var(--abf-ki);"></i> Ki</span>
          <div class="v2-res-vis-entry__btns">
            {{> "systems/animabf-guote/templates/actor-v2/components/vis-btn.hbs" name="system.ui.tokenBarVisibility.ki.value" value=system.ui.tokenBarVisibility.ki.value icon="fa-user-circle" title="Barra en token"}}
            {{> "systems/animabf-guote/templates/actor-v2/components/vis-btn.hbs" name="system.ui.resourceVisibility.ki.value" value=system.ui.resourceVisibility.ki.value icon="fa-scroll" title="Visible en ficha"}}
          </div>
        </div>
        <div class="v2-res-vis-entry v2-res-vis-entry--sub">
          <span class="v2-res-vis-entry__name"><i class="fas fa-yin-yang" style="color: var(--abf-ki);"></i> Ki Acum.</span>
          <div class="v2-res-vis-entry__btns">
            <span class="v2-vis-btn v2-vis-btn--empty"></span>
            {{> "systems/animabf-guote/templates/actor-v2/components/vis-btn.hbs" name="system.ui.resourceVisibility.kiAccumulated.value" value=system.ui.resourceVisibility.kiAccumulated.value icon="fa-scroll" title="Visible en ficha"}}
          </div>
        </div>

        {{!-- Row 3 --}}
        <div class="v2-res-vis-entry">
          <span class="v2-res-vis-entry__name"><i class="fas fa-brain" style="color: var(--abf-psychic);"></i> CV Psíquico</span>
          <div class="v2-res-vis-entry__btns">
            {{> "systems/animabf-guote/templates/actor-v2/components/vis-btn.hbs" name="system.ui.tokenBarVisibility.psychicPoints.value" value=system.ui.tokenBarVisibility.psychicPoints.value icon="fa-user-circle" title="Barra en token"}}
            {{> "systems/animabf-guote/templates/actor-v2/components/vis-btn.hbs" name="system.ui.resourceVisibility.psychicPoints.value" value=system.ui.resourceVisibility.psychicPoints.value icon="fa-scroll" title="Visible en ficha"}}
          </div>
        </div>
        <div class="v2-res-vis-entry">
          <span class="v2-res-vis-entry__name"><i class="fas fa-shield-alt" style="color: var(--abf-shield);"></i> Escudo</span>
          <div class="v2-res-vis-entry__btns">
            {{> "systems/animabf-guote/templates/actor-v2/components/vis-btn.hbs" name="system.ui.tokenBarVisibility.shield.value" value=system.ui.tokenBarVisibility.shield.value icon="fa-user-circle" title="Barra en token"}}
            {{> "systems/animabf-guote/templates/actor-v2/components/vis-btn.hbs" name="system.ui.resourceVisibility.shield.value" value=system.ui.resourceVisibility.shield.value icon="fa-scroll" title="Visible en ficha"}}
          </div>
        </div>
        <div class="v2-res-vis-entry v2-res-vis-entry--sub">
          <span class="v2-res-vis-entry__name"><i class="fas fa-yin-yang" style="color: var(--abf-ki);"></i> Ki FUE</span>
          <div class="v2-res-vis-entry__btns">
            <span class="v2-vis-btn v2-vis-btn--empty"></span>
            {{> "systems/animabf-guote/templates/actor-v2/components/vis-btn.hbs" name="system.ui.resourceVisibility.kiStr.value" value=system.ui.resourceVisibility.kiStr.value icon="fa-scroll" title="Visible en ficha"}}
          </div>
        </div>
        <div class="v2-res-vis-entry v2-res-vis-entry--sub">
          <span class="v2-res-vis-entry__name"><i class="fas fa-yin-yang" style="color: var(--abf-ki);"></i> Ki AGI</span>
          <div class="v2-res-vis-entry__btns">
            <span class="v2-vis-btn v2-vis-btn--empty"></span>
            {{> "systems/animabf-guote/templates/actor-v2/components/vis-btn.hbs" name="system.ui.resourceVisibility.kiAgi.value" value=system.ui.resourceVisibility.kiAgi.value icon="fa-scroll" title="Visible en ficha"}}
          </div>
        </div>

        {{!-- Row 4 --}}
        <div class="v2-res-vis-entry v2-res-vis-entry--sub">
          <span class="v2-res-vis-entry__name"><i class="fas fa-yin-yang" style="color: var(--abf-ki);"></i> Ki DES</span>
          <div class="v2-res-vis-entry__btns">
            <span class="v2-vis-btn v2-vis-btn--empty"></span>
            {{> "systems/animabf-guote/templates/actor-v2/components/vis-btn.hbs" name="system.ui.resourceVisibility.kiDex.value" value=system.ui.resourceVisibility.kiDex.value icon="fa-scroll" title="Visible en ficha"}}
          </div>
        </div>
        <div class="v2-res-vis-entry v2-res-vis-entry--sub">
          <span class="v2-res-vis-entry__name"><i class="fas fa-yin-yang" style="color: var(--abf-ki);"></i> Ki CON</span>
          <div class="v2-res-vis-entry__btns">
            <span class="v2-vis-btn v2-vis-btn--empty"></span>
            {{> "systems/animabf-guote/templates/actor-v2/components/vis-btn.hbs" name="system.ui.resourceVisibility.kiCon.value" value=system.ui.resourceVisibility.kiCon.value icon="fa-scroll" title="Visible en ficha"}}
          </div>
        </div>
        <div class="v2-res-vis-entry v2-res-vis-entry--sub">
          <span class="v2-res-vis-entry__name"><i class="fas fa-yin-yang" style="color: var(--abf-ki);"></i> Ki VOL</span>
          <div class="v2-res-vis-entry__btns">
            <span class="v2-vis-btn v2-vis-btn--empty"></span>
            {{> "systems/animabf-guote/templates/actor-v2/components/vis-btn.hbs" name="system.ui.resourceVisibility.kiWp.value" value=system.ui.resourceVisibility.kiWp.value icon="fa-scroll" title="Visible en ficha"}}
          </div>
        </div>
        <div class="v2-res-vis-entry v2-res-vis-entry--sub">
          <span class="v2-res-vis-entry__name"><i class="fas fa-yin-yang" style="color: var(--abf-ki);"></i> Ki POD</span>
          <div class="v2-res-vis-entry__btns">
            <span class="v2-vis-btn v2-vis-btn--empty"></span>
            {{> "systems/animabf-guote/templates/actor-v2/components/vis-btn.hbs" name="system.ui.resourceVisibility.kiPow.value" value=system.ui.resourceVisibility.kiPow.value icon="fa-scroll" title="Visible en ficha"}}
          </div>
        </div>
      </div>
    </div>
  </div>

  {{!-- Advanced Settings --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <span>{{localize "anima.ui.settings.advancedSettings.title"}}</span>
    </div>
    <div class="v2-card__body">
      <div class="v2-grid v2-grid--2" style="gap: var(--space-3);">
        <div>
          <label class="v2-text-muted" style="font-size: var(--font-size-xs);">{{localize "anima.ui.settings.advancedSettings.openRolls.title"}}</label>
          <input type="number" class="v2-input" name="system.general.settings.openRolls.value" value="{{system.general.settings.openRolls.value}}" placeholder="0">
        </div>
        <div>
          <label class="v2-text-muted" style="font-size: var(--font-size-xs);">{{localize "anima.ui.settings.advancedSettings.fumbles.title"}}</label>
          <input type="number" class="v2-input" name="system.general.settings.fumbles.value" value="{{system.general.settings.fumbles.value}}" placeholder="0">
        </div>
        <div>
          <label class="v2-checkbox-label">
            <input type="checkbox"
                   name="system.general.settings.openOnDoubles.value"
                   {{checked system.general.settings.openOnDoubles.value}}>
            {{localize "anima.ui.settings.advancedSettings.doubles"}}
          </label>
        </div>
        <div>
          <label class="v2-text-muted" style="font-size: var(--font-size-xs);">{{localize "anima.ui.settings.advancedSettings.defenseType.title"}}</label>
          <select class="v2-select" name="system.general.settings.defenseType.value">
            <option value="" {{#unless system.general.settings.defenseType.value}}selected{{/unless}}>{{localize "anima.ui.settings.advancedSettings.defenseType.normal.title"}}</option>
            <option value="resistance" {{#if (is 'eq' system.general.settings.defenseType.value 'resistance')}}selected{{/if}}>{{localize "anima.ui.settings.advancedSettings.defenseType.damageResistance.title"}}</option>
            <option value="mass" {{#if (is 'eq' system.general.settings.defenseType.value 'mass')}}selected{{/if}}>{{localize "anima.ui.settings.advancedSettings.defenseType.mass.title"}}</option>
          </select>
        </div>
        <div>
          <label class="v2-text-muted" style="font-size: var(--font-size-xs);">Multiplicador de PV</label>
          <input type="number" class="v2-input" name="system.characteristics.secondaries.lifePoints.lpMultiplier" value="{{system.characteristics.secondaries.lifePoints.lpMultiplier}}" placeholder="1" step="0.1" min="0">
          <span class="v2-text-muted" style="font-size: var(--font-size-xs); font-style: italic;">Sin efecto actualmente</span>
        </div>
      </div>
    </div>
  </div>
</div>
