{{!-- Bio Tab --}}
<div class="v2-tab-bio">
  <div class="v2-grid v2-grid--2">
    {{!-- Description --}}
    <div class="v2-card">
      <div class="v2-card__header">
        <span>{{localize "anima.ui.descriptionSection.title"}}</span>
      </div>
      <div class="v2-card__body v2-notes-editor">
        {{editor system.general.description.enriched target="system.general.description.value" button=true owner=true editable=true}}
      </div>
    </div>

    {{!-- Aspect --}}
    <div class="v2-card">
      <div class="v2-card__header">
        <span>{{localize "anima.ui.aspectSection.title"}}</span>
      </div>
      <div class="v2-card__body">
        <div class="v2-grid v2-grid--2" style="gap: var(--space-2);">
          {{> "systems/animabf-guote/templates/actor-v2/components/labeled-input.hbs" label=(localize "anima.ui.aspectSection.hair.title") name="system.general.aspect.hair.value" value=system.general.aspect.hair.value}}
          {{> "systems/animabf-guote/templates/actor-v2/components/labeled-input.hbs" label=(localize "anima.ui.aspectSection.eyes.title") name="system.general.aspect.eyes.value" value=system.general.aspect.eyes.value}}
          {{> "systems/animabf-guote/templates/actor-v2/components/labeled-input.hbs" label=(localize "anima.ui.aspectSection.height.title") name="system.general.aspect.height.value" value=system.general.aspect.height.value}}
          {{> "systems/animabf-guote/templates/actor-v2/components/labeled-input.hbs" label=(localize "anima.ui.aspectSection.weight.title") name="system.general.aspect.weight.value" value=system.general.aspect.weight.value}}
          {{> "systems/animabf-guote/templates/actor-v2/components/labeled-input.hbs" label=(localize "anima.ui.aspectSection.age.title") name="system.general.aspect.age.value" value=system.general.aspect.age.value}}
          {{> "systems/animabf-guote/templates/actor-v2/components/labeled-input.hbs" label=(localize "anima.ui.aspectSection.gender.title") name="system.general.aspect.gender.value" value=system.general.aspect.gender.value}}
          {{> "systems/animabf-guote/templates/actor-v2/components/labeled-input.hbs" label=(localize "anima.ui.aspectSection.race.title") name="system.general.aspect.race.value" value=system.general.aspect.race.value}}
          {{> "systems/animabf-guote/templates/actor-v2/components/labeled-input.hbs" label=(localize "anima.ui.aspectSection.size.title") name="system.general.aspect.size.value" value=system.general.aspect.size.value type="number"}}
        </div>
        <div style="margin-top: var(--space-2);">
          <label class="v2-text-muted" style="font-size: var(--font-size-xs);">{{localize "anima.ui.aspectSection.appearance.title"}}</label>
          <textarea class="v2-textarea" style="min-height: 60px;"
                    name="system.general.aspect.appearance.value">{{system.general.aspect.appearance.value}}</textarea>
        </div>
      </div>
    </div>
  </div>

  <div class="v2-grid v2-grid--2">
    {{!-- Advantages --}}
    {{> "systems/animabf-guote/templates/actor-v2/components/simple-item-list.hbs"
        title=(localize "anima.ui.advantageSection.title")
        addAction="add-advantage"
        addLabel=(localize "anima.dialogs.items.advantage.content")
        items=system.general.advantages}}

    {{!-- Disadvantages --}}
    {{> "systems/animabf-guote/templates/actor-v2/components/simple-item-list.hbs"
        title=(localize "anima.ui.disadvantageSection.title")
        addAction="add-disadvantage"
        addLabel=(localize "anima.dialogs.items.disadvantage.content")
        items=system.general.disadvantages}}
  </div>

  <div class="v2-grid v2-grid--2">
    {{!-- Elan --}}
    <div class="v2-card">
      <div class="v2-card__header">
        <div class="v2-card__header-title">
          <span>{{localize "anima.ui.elanSection.title"}}</span>
        </div>
        <div class="v2-card__header-actions">
          <button type="button" class="v2-card__header-btn" data-on-click="add-elan" title="{{localize 'anima.dialogs.items.elan.content'}}">
            <i class="fas fa-plus"></i>
          </button>
        </div>
      </div>
      <div class="v2-card__body" style="padding: 0;">
        <table class="v2-table">
          <thead>
            <tr>
              <th>{{localize "anima.ui.elanSection.elanRow.name"}}</th>
              <th style="width: 60px;">{{localize "anima.ui.elanSection.elanRow.level"}}</th>
            </tr>
          </thead>
          <tbody>
            {{#each system.general.elan as |elan|}}
            <tr data-item-id="{{elan._id}}">
              <td>
                <input type="text" class="v2-table__input"
                       name="system.dynamic.elan.{{elan._id}}.name"
                       value="{{elan.name}}">
              </td>
              <td>
                <input type="number" class="v2-table__input v2-text-center"
                       name="system.dynamic.elan.{{elan._id}}.system.level.value"
                       value="{{elan.system.level.value}}">
              </td>
            </tr>
            {{else}}
            <tr>
              <td colspan="2" class="v2-text-center v2-text-muted">-</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>

    {{!-- Levels --}}
    <div class="v2-card">
      <div class="v2-card__header">
        <div class="v2-card__header-title">
          <span>{{localize "anima.ui.levelSection.title"}}</span>
        </div>
        <div class="v2-card__header-actions">
          <button type="button" class="v2-card__header-btn" data-on-click="add-level" title="{{localize 'anima.dialogs.items.level.content'}}">
            <i class="fas fa-plus"></i>
          </button>
        </div>
      </div>
      <div class="v2-card__body" style="padding: 0;">
        <table class="v2-table">
          <thead>
            <tr>
              <th>{{localize "anima.ui.levelSection.class.title"}}</th>
              <th style="width: 60px;">{{localize "anima.ui.levelSection.level.title"}}</th>
            </tr>
          </thead>
          <tbody>
            {{#each system.general.levels as |level|}}
            <tr data-item-id="{{level._id}}">
              <td>
                <input type="text" class="v2-table__input"
                       name="system.dynamic.levels.{{level._id}}.name"
                       value="{{level.name}}">
              </td>
              <td>
                <input type="number" class="v2-table__input v2-text-center"
                       name="system.dynamic.levels.{{level._id}}.system.level"
                       value="{{level.system.level}}">
              </td>
            </tr>
            {{else}}
            <tr>
              <td colspan="2" class="v2-text-center v2-text-muted">-</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="v2-grid v2-grid--2">
    {{!-- Experience --}}
    <div class="v2-card">
      <div class="v2-card__header">
        <span>{{localize "anima.ui.experienceSection.title"}}</span>
      </div>
      <div class="v2-card__body">
        <div class="v2-grid v2-grid--2">
          {{> "systems/animabf-guote/templates/actor-v2/components/labeled-input.hbs" label=(localize "anima.ui.experienceSection.current.title") name="system.general.experience.current.value" value=system.general.experience.current.value type="number"}}
          {{> "systems/animabf-guote/templates/actor-v2/components/labeled-input.hbs" label=(localize "anima.ui.experienceSection.next.title") name="system.general.experience.next.value" value=system.general.experience.next.value type="number"}}
        </div>
      </div>
    </div>

    {{!-- Presence --}}
    <div class="v2-card">
      <div class="v2-card__header">
        <span>{{localize "anima.ui.general.presence.title"}}</span>
      </div>
      <div class="v2-card__body">
        <input type="number" class="v2-input v2-input--number" style="width: 80px;"
               name="system.general.presence.value"
               value="{{system.general.presence.value}}">
      </div>
    </div>
  </div>

  {{!-- Contacts --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <div class="v2-card__header-title">
        <span>{{localize "anima.ui.contactSection.title"}}</span>
      </div>
      <div class="v2-card__header-actions">
        <button type="button" class="v2-card__header-btn" data-on-click="add-contact" title="{{localize 'anima.dialogs.items.contact.content'}}">
          <i class="fas fa-plus"></i>
        </button>
      </div>
    </div>
    <div class="v2-card__body" style="padding: 0;">
      <table class="v2-table">
        <thead>
          <tr>
            <th>{{localize "anima.ui.contactSection.contactRow.name"}}</th>
            <th>{{localize "anima.ui.contactSection.contactRow.description"}}</th>
          </tr>
        </thead>
        <tbody>
          {{#each system.general.contacts as |contact|}}
          <tr data-item-id="{{contact._id}}">
            <td>
              <input type="text" class="v2-table__input"
                     name="system.dynamic.contacts.{{contact._id}}.name"
                     value="{{contact.name}}">
            </td>
            <td>
              <input type="text" class="v2-table__input"
                     name="system.dynamic.contacts.{{contact._id}}.system.description.value"
                     value="{{contact.system.description.value}}">
            </td>
          </tr>
          {{else}}
          <tr>
            <td colspan="2" class="v2-text-center v2-text-muted">-</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>

  {{!-- Notes --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <span>{{localize "anima.ui.notesSection.title"}}</span>
    </div>
    <div class="v2-card__body v2-notes-editor">
      {{editor system.general.notesText.enriched target="system.general.notesText.value" button=true owner=true editable=true}}
    </div>
  </div>
</div>
