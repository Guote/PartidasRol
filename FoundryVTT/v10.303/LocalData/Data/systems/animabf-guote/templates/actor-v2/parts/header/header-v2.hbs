{{!-- V2 Compact Header Template --}}
<header class="v2-header">
  {{!-- ROW 1: Portrait+Level | Resistances+TA | Initiative+Mod --}}
  <div class="v2-header__row v2-header__row--top">
    {{!-- Portrait + Level --}}
    <div class="v2-header__identity">
      <img class="v2-header__portrait" src="{{actor.img}}" data-edit="img" title="{{actor.name}}">
      <div class="v2-header__info">
        <input class="v2-header__name" type="text" name="name" value="{{actor.name}}" title="{{actor.name}}">
        <span class="v2-header__level">Nv. {{system.general.levels.length}}</span>
      </div>
    </div>

    {{!-- Resistances + TA stacked (centered) --}}
    <div class="v2-header__defense-block">
      {{!-- Resistances --}}
      <div class="v2-header__resistances-block">
        <span class="v2-header__block-title">{{localize "anima.ui.resistances.title"}}</span>
        <div class="v2-header__resistances">
          <span class="v2-header__res rollable" title="{{localize 'anima.ui.resistances.physical'}}" data-roll="1d100"
            data-rollvalue="{{system.characteristics.secondaries.resistances.physical.base.value}}"
            data-label="{{localize 'anima.ui.resistances.physical'}}">
            <b>RF</b><span
              class="v2-header__res-value">{{system.characteristics.secondaries.resistances.physical.base.value}}</span>
          </span>
          <span class="v2-header__res rollable" title="{{localize 'anima.ui.resistances.magic'}}" data-roll="1d100"
            data-rollvalue="{{system.characteristics.secondaries.resistances.magic.base.value}}"
            data-label="{{localize 'anima.ui.resistances.magic'}}">
            <b>RM</b><span
              class="v2-header__res-value">{{system.characteristics.secondaries.resistances.magic.base.value}}</span>
          </span>
          <span class="v2-header__res rollable" title="{{localize 'anima.ui.resistances.psychic'}}" data-roll="1d100"
            data-rollvalue="{{system.characteristics.secondaries.resistances.psychic.base.value}}"
            data-label="{{localize 'anima.ui.resistances.psychic'}}">
            <b>RP</b><span
              class="v2-header__res-value">{{system.characteristics.secondaries.resistances.psychic.base.value}}</span>
          </span>
          <span class="v2-header__res v2-header__res--crit rollable"
            title="{{localize 'anima.ui.resistances.resistCritical'}}" data-roll="1d100-1d100"
            data-rollvalue="{{system.characteristics.secondaries.resistances.physical.base.value}}"
            data-label="{{localize 'anima.ui.resistances.resistCritical'}}">
            <b><i class="fas fa-skull-crossbones"></i></b>
          </span>
        </div>
      </div>

      {{!-- TA (Total Armor) - clickable to open inventory --}}
      <div class="v2-header__ta-block" data-action="open-tab" data-tab="inventory" title="Click para ver inventario">
        <span class="v2-header__block-title">TA</span>
        <div class="v2-header__ta">
          <span class="v2-header__ta-item" title="{{localize 'anima.ui.combat.armors.at.cut.title'}}">
            <b>FIL</b><span class="v2-header__ta-value">{{system.combat.totalArmor.at.cut.value}}</span>
          </span>
          <span class="v2-header__ta-item" title="{{localize 'anima.ui.combat.armors.at.impact.title'}}">
            <b>CON</b><span class="v2-header__ta-value">{{system.combat.totalArmor.at.impact.value}}</span>
          </span>
          <span class="v2-header__ta-item" title="{{localize 'anima.ui.combat.armors.at.thrust.title'}}">
            <b>PEN</b><span class="v2-header__ta-value">{{system.combat.totalArmor.at.thrust.value}}</span>
          </span>
          <span class="v2-header__ta-item" title="{{localize 'anima.ui.combat.armors.at.heat.title'}}">
            <b>CAL</b><span class="v2-header__ta-value">{{system.combat.totalArmor.at.heat.value}}</span>
          </span>
          <span class="v2-header__ta-item" title="{{localize 'anima.ui.combat.armors.at.electricity.title'}}">
            <b>ELE</b><span class="v2-header__ta-value">{{system.combat.totalArmor.at.electricity.value}}</span>
          </span>
          <span class="v2-header__ta-item" title="{{localize 'anima.ui.combat.armors.at.cold.title'}}">
            <b>FRI</b><span class="v2-header__ta-value">{{system.combat.totalArmor.at.cold.value}}</span>
          </span>
          <span class="v2-header__ta-item" title="{{localize 'anima.ui.combat.armors.at.energy.title'}}">
            <b>ENE</b><span class="v2-header__ta-value">{{system.combat.totalArmor.at.energy.value}}</span>
          </span>
        </div>
      </div>
    </div>

    {{!-- Initiative + General Modifier --}}
    <div class="v2-header__right-stats">
      {{!-- Initiative --}}
      <div class="v2-res v2-res--init" title="{{localize 'anima.ui.general.initiative.base.title'}}">
        <span class="v2-res__icon rollable" data-roll="1d100Initiative"
          data-rollvalue="{{system.characteristics.secondaries.initiative.final.value}}"
          data-label="{{localize 'anima.ui.general.initiative.base.title'}}"><i class="fas fa-dice-d20"></i></span>
        <div class="v2-res__content">
          <span class="v2-res__label">Turno</span>
          <span class="v2-res__value rollable" data-roll="1d100Initiative"
            data-rollvalue="{{system.characteristics.secondaries.initiative.final.value}}"
            data-label="{{localize 'anima.ui.general.initiative.base.title'}}">{{system.characteristics.secondaries.initiative.final.value}}</span>
        </div>
      </div>

      {{!-- General Modifier (clickable to open effects tab) --}}
      <div
        class="v2-header__gen-mod {{#if (lt system.general.modifiers.modFinal.general.final.value 0)}}v2-header__gen-mod--negative{{/if}} {{#if (gt system.general.modifiers.modFinal.general.final.value 0)}}v2-header__gen-mod--positive{{/if}}"
        data-tab="effects" title="{{localize 'anima.ui.general.modifiers.allActions.title'}} - Click para ver efectos">
        <span class="v2-header__gen-mod-label">Mod</span>
        <span class="v2-header__gen-mod-value">{{system.general.modifiers.modFinal.general.final.value}}</span>
      </div>
    </div>
  </div>

  {{!-- ROW 2: Resources Bar (always visible) --}}
  <div class="v2-header__row v2-header__row--resources">
    <div class="v2-header__resources">
      {{!-- HP Group (HP + Sacrificed Life) --}}
      {{#if system.ui.resourceVisibility.hp.value}}
      <div class="v2-res-group">
        <div class="v2-res v2-res--hp v2-res--compact" title="{{localize 'anima.ui.general.life.current.title'}}">
          <span class="v2-res__label"><i class="fas fa-heart"></i> PV</span>
          <div class="v2-res__values">
            <input type="number" class="v2-res__input v2-res__input--compact"
              name="system.characteristics.secondaries.lifePoints.value"
              value="{{system.characteristics.secondaries.lifePoints.value}}">
            <span class="v2-res__sep">/</span>
            <input type="number" class="v2-res__input v2-res__input--compact"
              name="system.characteristics.secondaries.lifePoints.max"
              value="{{system.characteristics.secondaries.lifePoints.max}}">
          </div>
        </div>
        {{#if system.ui.resourceVisibility.sacrificedLife.value}}
        <div class="v2-res-group__sep"></div>
        <div class="v2-res v2-res--hp v2-res--compact v2-res--single" title="Vida Sacrificada">
          <span class="v2-res__label"><i class="fas fa-heart-broken"></i> Sacr</span>
          <div class="v2-res__values">
            <input type="number" class="v2-res__input v2-res__input--compact"
              name="system.characteristics.secondaries.lifePoints.sacrificed"
              value="{{system.characteristics.secondaries.lifePoints.sacrificed}}">
          </div>
        </div>
        {{/if}}
      </div>
      {{/if}}

      {{!-- Fatigue --}}
      {{#if system.ui.resourceVisibility.fatigue.value}}
      <div class="v2-res v2-res--fatigue v2-res--compact" title="{{localize 'anima.ui.general.fatigue.title'}}">
        <span class="v2-res__label"><i class="fas fa-bolt"></i> Cans</span>
        <div class="v2-res__values">
          <input type="number" class="v2-res__input v2-res__input--compact"
            name="system.characteristics.secondaries.fatigue.value"
            value="{{system.characteristics.secondaries.fatigue.value}}">
          <span class="v2-res__sep">/</span>
          <input type="number" class="v2-res__input v2-res__input--compact"
            name="system.characteristics.secondaries.fatigue.max"
            value="{{system.characteristics.secondaries.fatigue.max}}">
        </div>
      </div>
      {{/if}}

      {{!-- Destiny Points --}}
      {{#if system.ui.resourceVisibility.destiny.value}}
      <div class="v2-res v2-res--destiny v2-res--compact" title="{{localize 'anima.ui.general.destinyPoints.title'}}">
        <span class="v2-res__label"><i class="fas fa-star"></i> PD</span>
        <div class="v2-res__values">
          <input type="number" class="v2-res__input v2-res__input--compact"
            name="system.general.destinyPoints.base.value" value="{{system.general.destinyPoints.base.value}}"
            data-header-resource>
        </div>
      </div>
      {{/if}}

      {{!-- Zeon Group (Zeon + Zeon Accumulated) --}}
      {{#if system.ui.resourceVisibility.zeon.value}}
      <div class="v2-res-group">
        <div class="v2-res v2-res--zeon v2-res--compact" title="{{localize 'anima.ui.mystic.zeon.title'}}">
          <span class="v2-res__label"><i class="fas fa-hat-wizard"></i> Zeon</span>
          <div class="v2-res__values">
            <input type="number" class="v2-res__input v2-res__input--compact" name="_header.system.mystic.zeon.value"
              value="{{system.mystic.zeon.value}}">
            <span class="v2-res__sep">/</span>
            <input type="number" class="v2-res__input v2-res__input--compact" name="_header.system.mystic.zeon.max"
              value="{{system.mystic.zeon.max}}">
          </div>
        </div>
        {{#if system.ui.resourceVisibility.zeonAccumulated.value}}
        <div class="v2-res-group__sep"></div>
        <div class="v2-res v2-res--zeon-acc v2-res--compact v2-res--single" title="Zeon Acumulado">
          <span class="v2-res__label"><i class="fas fa-hat-wizard"></i> Acum</span>
          <div class="v2-res__values">
            <input type="number" class="v2-res__input v2-res__input--compact"
              name="_header.system.mystic.zeonAccumulated.value" value="{{system.mystic.zeonAccumulated.value}}">
          </div>
        </div>
        {{/if}}
      </div>
      {{/if}}

      {{!-- Ki Group (Ki + Ki Accumulated) --}}
      {{#if system.ui.resourceVisibility.ki.value}}
      <div class="v2-res-group">
        <div class="v2-res v2-res--ki v2-res--compact" title="Ki">
          <span class="v2-res__label"><i class="fas fa-yin-yang"></i> Ki</span>
          <div class="v2-res__values">
            <input type="number" class="v2-res__input v2-res__input--compact"
              name="_header.system.domine.kiAccumulation.generic.value"
              value="{{system.domine.kiAccumulation.generic.value}}">
            <span class="v2-res__sep">/</span>
            <input type="number" class="v2-res__input v2-res__input--compact"
              name="_header.system.domine.kiAccumulation.generic.max"
              value="{{system.domine.kiAccumulation.generic.max}}">
          </div>
        </div>
      </div>
      {{/if}}

      {{!-- Individual Ki Stats group (per characteristic accumulated + total) --}}
      {{#if (or system.ui.resourceVisibility.kiAccumulated.value system.ui.resourceVisibility.kiStr.value system.ui.resourceVisibility.kiAgi.value system.ui.resourceVisibility.kiDex.value system.ui.resourceVisibility.kiCon.value system.ui.resourceVisibility.kiWp.value system.ui.resourceVisibility.kiPow.value)}}
      <div class="v2-res-group v2-res-group--ki-stats" title="Ki Acumulado">
        {{#if system.ui.resourceVisibility.kiAccumulated.value}}
        <div class="v2-res v2-res--ki-acc v2-res--compact v2-res--single"
          title="Ki Acumulado (total de todas las características)">
          <span class="v2-res__label"><i class="fas fa-yin-yang"></i> Acum</span>
          <div class="v2-res__values">
            <span class="v2-res__readonly">{{totalKiAccumulated}}</span>
          </div>
        </div>
        {{/if}}
        {{#if system.ui.resourceVisibility.kiStr.value}}
        <div class="v2-res v2-res--ki v2-res--compact v2-res--single" title="{{localize 'anima.ui.domine.kiAccumulation.strength.title'}}">
          <span class="v2-res__label">FUE</span>
          <div class="v2-res__values">
            <input type="number" class="v2-res__input v2-res__input--compact"
              name="_header.system.domine.kiAccumulation.strength.accumulated.value"
              value="{{system.domine.kiAccumulation.strength.accumulated.value}}">
          </div>
        </div>
        {{/if}}
        {{#if system.ui.resourceVisibility.kiAgi.value}}
        <div class="v2-res v2-res--ki v2-res--compact v2-res--single" title="{{localize 'anima.ui.domine.kiAccumulation.agility.title'}}">
          <span class="v2-res__label">AGI</span>
          <div class="v2-res__values">
            <input type="number" class="v2-res__input v2-res__input--compact"
              name="_header.system.domine.kiAccumulation.agility.accumulated.value"
              value="{{system.domine.kiAccumulation.agility.accumulated.value}}">
          </div>
        </div>
        {{/if}}
        {{#if system.ui.resourceVisibility.kiDex.value}}
        <div class="v2-res v2-res--ki v2-res--compact v2-res--single" title="{{localize 'anima.ui.domine.kiAccumulation.dexterity.title'}}">
          <span class="v2-res__label">DES</span>
          <div class="v2-res__values">
            <input type="number" class="v2-res__input v2-res__input--compact"
              name="_header.system.domine.kiAccumulation.dexterity.accumulated.value"
              value="{{system.domine.kiAccumulation.dexterity.accumulated.value}}">
          </div>
        </div>
        {{/if}}
        {{#if system.ui.resourceVisibility.kiCon.value}}
        <div class="v2-res v2-res--ki v2-res--compact v2-res--single" title="{{localize 'anima.ui.domine.kiAccumulation.constitution.title'}}">
          <span class="v2-res__label">CON</span>
          <div class="v2-res__values">
            <input type="number" class="v2-res__input v2-res__input--compact"
              name="_header.system.domine.kiAccumulation.constitution.accumulated.value"
              value="{{system.domine.kiAccumulation.constitution.accumulated.value}}">
          </div>
        </div>
        {{/if}}
        {{#if system.ui.resourceVisibility.kiWp.value}}
        <div class="v2-res v2-res--ki v2-res--compact v2-res--single" title="{{localize 'anima.ui.domine.kiAccumulation.willPower.title'}}">
          <span class="v2-res__label">VOL</span>
          <div class="v2-res__values">
            <input type="number" class="v2-res__input v2-res__input--compact"
              name="_header.system.domine.kiAccumulation.willPower.accumulated.value"
              value="{{system.domine.kiAccumulation.willPower.accumulated.value}}">
          </div>
        </div>
        {{/if}}
        {{#if system.ui.resourceVisibility.kiPow.value}}
        <div class="v2-res v2-res--ki v2-res--compact v2-res--single" title="{{localize 'anima.ui.domine.kiAccumulation.power.title'}}">
          <span class="v2-res__label">POD</span>
          <div class="v2-res__values">
            <input type="number" class="v2-res__input v2-res__input--compact"
              name="_header.system.domine.kiAccumulation.power.accumulated.value"
              value="{{system.domine.kiAccumulation.power.accumulated.value}}">
          </div>
        </div>
        {{/if}}
      </div>
      {{/if}}

      {{!-- Psychic Points --}}
      {{#if system.ui.resourceVisibility.psychicPoints.value}}
      <div class="v2-res v2-res--psy v2-res--compact" title="{{localize 'anima.ui.psychic.psychicPoints.title'}}">
        <span class="v2-res__label"><i class="fas fa-brain"></i> CV</span>
        <div class="v2-res__values">
          <input type="number" class="v2-res__input v2-res__input--compact"
            name="_header.system.psychic.psychicPoints.value" value="{{system.psychic.psychicPoints.value}}">
          <span class="v2-res__sep">/</span>
          <input type="number" class="v2-res__input v2-res__input--compact"
            name="_header.system.psychic.psychicPoints.max" value="{{system.psychic.psychicPoints.max}}">
        </div>
      </div>
      {{/if}}

      {{!-- Supernatural Shield --}}
      {{#if system.ui.resourceVisibility.shield.value}}
      <div class="v2-res v2-res--shield v2-res--compact" title="{{localize 'anima.ui.mystic.shield.title'}}">
        <span class="v2-res__label"><i class="fas fa-shield-alt"></i> Escudo</span>
        <div class="v2-res__values">
          <input type="number" class="v2-res__input v2-res__input--compact" name="_header.system.mystic.shield.value"
            value="{{system.mystic.shield.value}}">
          <span class="v2-res__sep">/</span>
          <input type="number" class="v2-res__input v2-res__input--compact" name="_header.system.mystic.shield.max"
            value="{{system.mystic.shield.max}}">
        </div>
      </div>
      {{/if}}
    </div>
  </div>
</header>