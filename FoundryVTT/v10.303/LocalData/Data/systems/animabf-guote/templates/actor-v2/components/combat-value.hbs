{{!--
  Reusable Combat Value Component
  Used for values with base input + optional final display. Consistent appearance
  in both the actor sheet and the spellbook.

  Parameters:
  - label: The localized label text
  - baseName: The input name for the base value
  - baseValue: The base value
  - finalValue: The final calculated value (shown unless baseOnly or rollableDiv)
  - rollable: Whether the final value span is rollable (click to roll)
  - rollLabel: Label to show in roll message
  - rollFormula: Custom roll formula (default "1d100xa")
  - modifierType: Modifier type for _onRoll ("attack"|"defense"|"general"|"general-negative"|"initiative")
  - compact: Use compact styling (default false)
  - baseOnly: Show only the base input, hide the final value (default false)
  - rollableDiv: Make the whole div rollable instead of just the final span (hides final span)
  - tmpModName: Name for an optional temporary modifier input (shown between base and final)
  - tmpModValue: Value for the temporary modifier input
--}}
<div class="v2-combat-value {{#if compact}}v2-combat-value--compact{{/if}} {{#if rollableDiv}}rollable{{/if}}"
     {{#if rollableDiv}}
     data-roll="{{#if rollFormula}}{{rollFormula}}{{else}}1d100xa{{/if}}"
     data-rollvalue="{{finalValue}}"
     data-label="{{rollLabel}}"
     {{#if modifierType}}data-modifier-type="{{modifierType}}"{{/if}}
     {{/if}}>
  <span class="v2-combat-value__label">{{label}}</span>
  <div class="v2-combat-value__inputs">
    <input type="number" class="v2-combat-value__input"
           name="{{baseName}}"
           value="{{baseValue}}">
    {{#if tmpModName}}
    <span class="v2-combat-value__sep">+</span>
    <input type="number" class="v2-combat-value__input v2-combat-value__input--mod"
           name="{{tmpModName}}"
           value="{{tmpModValue}}">
    {{/if}}
    {{#unless baseOnly}}{{#unless rollableDiv}}
    {{#if rollable}}
    <span class="v2-combat-value__final rollable"
          data-roll="{{#if rollFormula}}{{rollFormula}}{{else}}1d100xa{{/if}}"
          data-rollvalue="{{finalValue}}"
          data-label="{{rollLabel}}"
          {{#if modifierType}}data-modifier-type="{{modifierType}}"{{/if}}>
      {{finalValue}}
    </span>
    {{else}}
    <span class="v2-combat-value__final">{{finalValue}}</span>
    {{/if}}
    {{/unless}}{{/unless}}
  </div>
</div>
