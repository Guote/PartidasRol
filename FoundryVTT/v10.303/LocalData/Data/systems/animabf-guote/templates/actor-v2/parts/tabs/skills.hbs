  {{!-- Special Skills --}}
  <div class="v2-card" style="margin-top: var(--space-3);">
    <div class="v2-card__header">
      <div class="v2-card__header-title">
        <span>{{localize "anima.ui.secondaries.secondarySpecialSkills.title"}}</span>
      </div>
      <div class="v2-card__header-actions">
        <button type="button" class="v2-card__header-btn" data-on-click="add-secondary-special-skill" title="{{localize 'anima.dialogs.items.secondarySkill.content'}}"
          <i class="fas fa-plus"></i>
        </button>
      </div>
    </div>
    <div class="v2-card__body" style="padding: 0;">
      <table class="v2-table">
        <thead>
          <tr>
            <th>{{localize "anima.ui.combat.ammo.name.title"}}</th>
            <th style="width: 60px;">{{localize "anima.ui.general.life.max.title"}}</th>
            <th style="width: 60px;">{{localize "anima.ui.mystic.zeon.final.title"}}</th>
          </tr>
        </thead>
        <tbody>
          {{#each system.secondaries.secondarySpecialSkills as |skill|}}
          <tr data-item-id="{{skill._id}}">
            <td>
              <span class="rollable"
                    data-roll="1d100xa"
                    data-rollvalue="{{skill.system.final.value}}"
                    data-label="{{skill.name}}">
                {{skill.name}}
              </span>
            </td>
            <td>
              <input type="number" class="v2-table__input v2-text-center"
                     name="system.dynamic.secondarySpecialSkills.{{skill._id}}.system.base.value"
                     value="{{skill.system.base.value}}">
            </td>
            <td class="v2-text-center v2-font-bold">{{skill.system.final.value}}</td>
          </tr>
          {{else}}
          <tr>
            <td colspan="3" class="v2-text-center v2-text-muted">-</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
