{{!-- Inventory Tab --}}
<div class="v2-tab-inventory">
  {{!-- Money --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <span>{{localize "anima.ui.general.money.title"}}</span>
    </div>
    <div class="v2-card__body">
      <div class="v2-grid v2-grid--3">
        <div>
          <label class="v2-text-muted" style="font-size: var(--font-size-xs);">{{localize "anima.ui.general.money.gold.title"}}</label>
          <input type="number" class="v2-input"
                 name="system.general.money.gold.value"
                 value="{{system.general.money.gold.value}}">
        </div>
        <div>
          <label class="v2-text-muted" style="font-size: var(--font-size-xs);">{{localize "anima.ui.general.money.silver.title"}}</label>
          <input type="number" class="v2-input"
                 name="system.general.money.silver.value"
                 value="{{system.general.money.silver.value}}">
        </div>
        <div>
          <label class="v2-text-muted" style="font-size: var(--font-size-xs);">{{localize "anima.ui.general.money.cooper.title"}}</label>
          <input type="number" class="v2-input"
                 name="system.general.money.cooper.value"
                 value="{{system.general.money.cooper.value}}">
        </div>
      </div>
    </div>
  </div>

  {{!-- Inventory Items --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <div class="v2-card__header-title">
        <span>{{localize "anima.ui.general.inventory.title"}}</span>
      </div>
      <div class="v2-card__header-actions">
        <button type="button" class="v2-card__header-btn" data-on-click="add-inventory-item" title="{{localize 'anima.ui.add'}}">
          <i class="fas fa-plus"></i>
        </button>
      </div>
    </div>
    <div class="v2-card__body" style="padding: 0;">
      <table class="v2-table">
        <thead>
          <tr>
            <th>{{localize "anima.ui.name"}}</th>
            <th style="width: 80px;">{{localize "anima.ui.general.inventory.amount.title"}}</th>
            <th style="width: 80px;">{{localize "anima.ui.general.inventory.weight.title"}}</th>
            <th>{{localize "anima.ui.description"}}</th>
          </tr>
        </thead>
        <tbody>
          {{#each system.general.inventory as |item|}}
          <tr class="item v2-table__row--draggable" data-item-id="{{item._id}}">
            <td>{{item.name}}</td>
            <td>
              <input type="number" class="v2-table__input v2-text-center"
                     name="system.dynamic.inventory.{{item._id}}.system.amount.value"
                     value="{{item.system.amount.value}}">
            </td>
            <td>
              <input type="number" class="v2-table__input v2-text-center"
                     name="system.dynamic.inventory.{{item._id}}.system.weight.value"
                     value="{{item.system.weight.value}}">
            </td>
            <td class="v2-text-muted" style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
              {{item.system.description.value}}
            </td>
          </tr>
          {{else}}
          <tr>
            <td colspan="4" class="v2-text-center v2-text-muted">{{localize "anima.ui.noItems"}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>

  {{!-- Ammo --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <div class="v2-card__header-title">
        <span>{{localize "anima.ui.combat.ammo.title"}}</span>
      </div>
      <div class="v2-card__header-actions">
        <button type="button" class="v2-card__header-btn" data-on-click="add-ammo" title="{{localize 'anima.ui.add'}}">
          <i class="fas fa-plus"></i>
        </button>
      </div>
    </div>
    <div class="v2-card__body" style="padding: 0;">
      <table class="v2-table">
        <thead>
          <tr>
            <th>{{localize "anima.ui.combat.ammo.name.title"}}</th>
            <th style="width: 70px;">{{localize "anima.ui.combat.ammo.amount.title"}}</th>
            <th style="width: 70px;">{{localize "anima.ui.combat.ammo.damage.title"}}</th>
            <th style="width: 80px;">{{localize "anima.ui.combat.ammo.critic.title"}}</th>
          </tr>
        </thead>
        <tbody>
          {{#each system.combat.ammo as |ammo|}}
          <tr class="ammo-row v2-table__row--draggable" data-item-id="{{ammo._id}}">
            <td>{{ammo.name}}</td>
            <td>
              <input type="number" class="v2-table__input v2-text-center"
                     name="system.dynamic.ammo.{{ammo._id}}.system.amount.value"
                     value="{{ammo.system.amount.value}}">
            </td>
            <td class="v2-text-center">{{ammo.system.damage.final.value}}</td>
            <td class="v2-text-center">{{ammo.system.critic.value}}</td>
          </tr>
          {{else}}
          <tr>
            <td colspan="4" class="v2-text-center v2-text-muted">{{localize "anima.ui.noItems"}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>
</div>
