{{!-- Domine Tab V2 --}}
<div class="v2-tab-domine">

  {{!-- Ki Accumulation --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <div class="v2-card__header-title">
        <span>Acumulación de Ki</span>
      </div>
      <div class="v2-card__header-actions">
        <button type="button" class="v2-card__header-btn" data-on-click="ki-accumulate-generic"
                title="Incrementa la acumulación de cada stat por su tasa de acumulación">
          <i class="fas fa-plus-circle"></i> Acumular ki genérico
        </button>
        <button type="button" class="v2-card__header-btn" data-on-click="ki-reset-accumulation"
                title="Resetea la acumulación de todos los stats a 0">
          <i class="fas fa-undo"></i> Limpiar
        </button>
        <button type="button" class="v2-card__header-btn" data-on-click="ki-accumulation-calculator"
                draggable="true"
                title="{{localize 'anima.ui.domine.kiAccumulation.macro.title'}}">
          <i class="fas fa-yin-yang"></i> Calculadora de Ki
        </button>
      </div>
    </div>
    <div class="v2-card__body" style="padding: 0;">
      <table class="v2-table v2-table--compact">
        <thead>
          <tr>
            <th style="width: 110px;"></th>
            <th class="v2-text-center v2-shadow--ki">{{localize "anima.ui.domine.kiAccumulation.agility.title"}}</th>
            <th class="v2-text-center v2-shadow--ki">{{localize "anima.ui.domine.kiAccumulation.constitution.title"}}</th>
            <th class="v2-text-center v2-shadow--ki">{{localize "anima.ui.domine.kiAccumulation.dexterity.title"}}</th>
            <th class="v2-text-center v2-shadow--ki">{{localize "anima.ui.domine.kiAccumulation.strength.title"}}</th>
            <th class="v2-text-center v2-shadow--ki">{{localize "anima.ui.domine.kiAccumulation.power.title"}}</th>
            <th class="v2-text-center v2-shadow--ki">{{localize "anima.ui.domine.kiAccumulation.willPower.title"}}</th>
            <th class="v2-text-center v2-shadow--ki" style="font-size:0.7rem;">Total</th>
          </tr>
        </thead>
        <tbody>
          {{!-- Accumulation rate row: base input + temporal + final per stat + total --}}
          <tr>
            <td class="v2-text-muted" style="font-size:0.75rem;">Acumulación por turno</td>
            <td class="v2-text-center">
              {{> "systems/animabf-guote/templates/actor-v2/components/base-to-final-input-small.hbs"
                  baseName="system.domine.kiAccumulation.agility.base.value"
                  baseValue=system.domine.kiAccumulation.agility.base.value
                  temporalName="system.domine.kiAccumulation.agility.temporal.value"
                  temporalValue=system.domine.kiAccumulation.agility.temporal.value
                  finalValue=system.domine.kiAccumulation.agility.final.value
                  width=70
              }}
            </td>
            <td class="v2-text-center">
              {{> "systems/animabf-guote/templates/actor-v2/components/base-to-final-input-small.hbs"
                  baseName="system.domine.kiAccumulation.constitution.base.value"
                  baseValue=system.domine.kiAccumulation.constitution.base.value
                  temporalName="system.domine.kiAccumulation.constitution.temporal.value"
                  temporalValue=system.domine.kiAccumulation.constitution.temporal.value
                  finalValue=system.domine.kiAccumulation.constitution.final.value
                  width=70
              }}
            </td>
            <td class="v2-text-center">
              {{> "systems/animabf-guote/templates/actor-v2/components/base-to-final-input-small.hbs"
                  baseName="system.domine.kiAccumulation.dexterity.base.value"
                  baseValue=system.domine.kiAccumulation.dexterity.base.value
                  temporalName="system.domine.kiAccumulation.dexterity.temporal.value"
                  temporalValue=system.domine.kiAccumulation.dexterity.temporal.value
                  finalValue=system.domine.kiAccumulation.dexterity.final.value
                  width=70
              }}
            </td>
            <td class="v2-text-center">
              {{> "systems/animabf-guote/templates/actor-v2/components/base-to-final-input-small.hbs"
                  baseName="system.domine.kiAccumulation.strength.base.value"
                  baseValue=system.domine.kiAccumulation.strength.base.value
                  temporalName="system.domine.kiAccumulation.strength.temporal.value"
                  temporalValue=system.domine.kiAccumulation.strength.temporal.value
                  finalValue=system.domine.kiAccumulation.strength.final.value
                  width=70
              }}
            </td>
            <td class="v2-text-center">
              {{> "systems/animabf-guote/templates/actor-v2/components/base-to-final-input-small.hbs"
                  baseName="system.domine.kiAccumulation.power.base.value"
                  baseValue=system.domine.kiAccumulation.power.base.value
                  temporalName="system.domine.kiAccumulation.power.temporal.value"
                  temporalValue=system.domine.kiAccumulation.power.temporal.value
                  finalValue=system.domine.kiAccumulation.power.final.value
                  width=70
              }}
            </td>
            <td class="v2-text-center">
              {{> "systems/animabf-guote/templates/actor-v2/components/base-to-final-input-small.hbs"
                  baseName="system.domine.kiAccumulation.willPower.base.value"
                  baseValue=system.domine.kiAccumulation.willPower.base.value
                  temporalName="system.domine.kiAccumulation.willPower.temporal.value"
                  temporalValue=system.domine.kiAccumulation.willPower.temporal.value
                  finalValue=system.domine.kiAccumulation.willPower.final.value
                  width=70
              }}
            </td>
            <td class="v2-text-center v2-text-muted" style="font-size:0.85rem;">{{totalKiAccRate}}</td>
          </tr>

          {{!-- Accumulated ki row: ki pool + per-stat accumulated + total --}}
          <tr class="ki-acc-row">
            <td class="ki-acc-row__cell">
              <div style="display:flex;align-items:center;justify-content:center;gap:3px;">
                <i class="fas fa-yin-yang v2-shadow--ki" style="font-size:0.75rem;"></i>
                <input type="number" class="v2-ki-acc-input"
                       data-field="system.domine.kiAccumulation.generic.value"
                       value="{{system.domine.kiAccumulation.generic.value}}">
                <span style="opacity:0.6;">/</span>
                <input type="number" class="v2-ki-acc-input"
                       data-field="system.domine.kiAccumulation.generic.max"
                       value="{{system.domine.kiAccumulation.generic.max}}">
              </div>
            </td>
            <td class="ki-acc-row__cell v2-text-center">
              <input type="number" class="v2-ki-acc-input"
                     data-field="system.domine.kiAccumulation.agility.accumulated.value"
                     value="{{system.domine.kiAccumulation.agility.accumulated.value}}">
            </td>
            <td class="ki-acc-row__cell v2-text-center">
              <input type="number" class="v2-ki-acc-input"
                     data-field="system.domine.kiAccumulation.constitution.accumulated.value"
                     value="{{system.domine.kiAccumulation.constitution.accumulated.value}}">
            </td>
            <td class="ki-acc-row__cell v2-text-center">
              <input type="number" class="v2-ki-acc-input"
                     data-field="system.domine.kiAccumulation.dexterity.accumulated.value"
                     value="{{system.domine.kiAccumulation.dexterity.accumulated.value}}">
            </td>
            <td class="ki-acc-row__cell v2-text-center">
              <input type="number" class="v2-ki-acc-input"
                     data-field="system.domine.kiAccumulation.strength.accumulated.value"
                     value="{{system.domine.kiAccumulation.strength.accumulated.value}}">
            </td>
            <td class="ki-acc-row__cell v2-text-center">
              <input type="number" class="v2-ki-acc-input"
                     data-field="system.domine.kiAccumulation.power.accumulated.value"
                     value="{{system.domine.kiAccumulation.power.accumulated.value}}">
            </td>
            <td class="ki-acc-row__cell v2-text-center">
              <input type="number" class="v2-ki-acc-input"
                     data-field="system.domine.kiAccumulation.willPower.accumulated.value"
                     value="{{system.domine.kiAccumulation.willPower.accumulated.value}}">
            </td>
            <td class="ki-acc-row__cell v2-text-center">
              <span class="ki-acc-total">{{totalKiAccumulated}}</span>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  {{!-- Active Ki Effects --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <div class="v2-card__header-title">
        <span>Efectos Ki Activos</span>
      </div>
      <div class="v2-card__header-actions">
        <button type="button" class="v2-card__header-btn" data-on-click="add-ki-maintenance">
          <i class="fas fa-plus"></i>
        </button>
      </div>
    </div>
    <div class="v2-card__body" style="padding: 0;">
      <table class="v2-table v2-table--compact" id="ki-maintenances-context-menu-container">
        <thead>
          <tr>
            <th style="width:30px;"></th>
            <th>Efecto</th>
            <th class="v2-text-center" style="width:70px;">Ki/Asalto</th>
            <th style="width:30px;"></th>
          </tr>
        </thead>
        <tbody>
          {{#each system.domine.kiMaintenances as |km|}}
          <tr class="ki-maintenance-row" data-item-id="{{km._id}}">
            <td class="v2-text-center" style="padding:0;">
              <input type="checkbox" class="km-active-toggle" {{#if km.system.active.value}}checked{{/if}}>
            </td>
            <td>
              <input type="text" class="v2-table__input km-name-input" value="{{km.name}}" style="width:100%;">
            </td>
            <td class="v2-text-center">
              <input type="number" class="v2-table__input km-cost-input" value="{{km.system.roundCost.value}}"
                     style="width:50px;text-align:center;">
            </td>
            <td class="v2-text-center" style="padding:0;">
              <button type="button" class="abf-button icon-button" data-on-click="delete-ki-maintenance"
                      data-item-id="{{km._id}}" style="width:auto!important;display:inline-flex">
                <i class="fas fa-trash"></i>
              </button>
            </td>
          </tr>
          {{/each}}
          {{#each activeTechniqueUpkeeps as |tu|}}
          <tr class="v2-text-muted">
            <td class="v2-text-center" style="padding:0;">
              <input type="checkbox" class="technique-upkeep-active-toggle"
                     data-item-id="{{tu.id}}" {{#if tu.active}}checked{{/if}}>
            </td>
            <td>{{tu.name}} <small>(técnica)</small></td>
            <td class="v2-text-center">{{tu.roundCost}}</td>
            <td></td>
          </tr>
          {{/each}}
          {{#unless system.domine.kiMaintenances.length}}
          {{#unless activeTechniqueUpkeeps.length}}
          <tr>
            <td colspan="4" class="v2-text-center v2-text-muted">-</td>
          </tr>
          {{/unless}}
          {{/unless}}
        </tbody>
        <tfoot>
          <tr style="border-top:1px solid var(--color-border-light-2,#d4c9a8);">
            <td colspan="2" class="v2-text-muted" style="font-size:0.72rem;padding:2px 4px;">Total activos</td>
            <td class="v2-text-center" style="font-size:0.8rem;font-weight:bold;">{{kiMaintenanceTotalRound}}</td>
            <td></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>

  {{!-- Ki Techniques --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <div class="v2-card__header-title">
        <span>{{localize "anima.ui.domine.techniques.title"}}</span>
      </div>
      <div class="v2-card__header-actions">
        <button type="button" class="v2-card__header-btn" data-on-click="add-technique" title="{{localize 'anima.ui.domine.techniques.title'}}">
          <i class="fas fa-plus"></i>
        </button>
      </div>
    </div>
    <div class="v2-card__body" style="padding: 0;">
      <table class="v2-table v2-table--compact">
        <thead>
          <tr>
            <th class="v2-text-center" style="width:40px;">Niv.</th>
            <th>{{localize "anima.ui.domine.techniques.technique.header.name.title"}}</th>
            <th>Coste Ki</th>
            <th class="v2-text-center" style="width:55px;">Mant.</th>
            <th style="width:36px;"></th>
          </tr>
        </thead>
        <tbody id="techniques-context-menu-container">
          {{#each techniqueRows as |technique|}}
          <tr class="technique-row v2-table__row--clickable" data-item-id="{{technique._id}}">
            <td class="v2-text-center">{{technique.system.level.value}}</td>
            <td>
              <span class="v2-table__link" title="{{technique.name}}">{{technique.name}}</span>
              {{#if technique.system.description.value}}
              <div class="summon-resolved-duration">{{technique.system.description.value}}</div>
              {{/if}}
            </td>
            <td style="font-size:0.75rem; white-space:nowrap;">{{technique.kiCostStr}}</td>
            <td class="v2-text-center">{{technique.mantenimientoStr}}</td>
            <td class="v2-text-center" style="padding:0;">
              <button type="button" class="abf-button icon-button"
                      data-on-click="cast-technique" data-item-id="{{technique._id}}"
                      style="width:auto!important;display:inline-flex;" title="Lanzar técnica">
                <i class="fas fa-hand-sparkles"></i>
              </button>
            </td>
          </tr>
          {{else}}
          <tr>
            <td colspan="5" class="v2-text-center v2-text-muted">-</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>

  {{!-- Ki Seals + Linked Creatures side by side --}}
  <div class="v2-grid v2-grid--2">

    {{!-- Ki Seals --}}
    <div class="v2-card">
      <div class="v2-card__header">
        <span>{{localize "anima.ui.domine.seals.title"}}</span>
      </div>
      <div class="v2-card__body" style="padding: 0;">
        <table class="v2-table v2-table--compact">
          <thead>
            <tr>
              <th></th>
              <th class="v2-text-center" style="width: 60px;">{{localize "anima.ui.domine.seals.minor.title"}}</th>
              <th class="v2-text-center" style="width: 60px;">{{localize "anima.ui.domine.seals.major.title"}}</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="v2-text-muted" style="font-size:0.8rem;">{{localize "anima.ui.domine.seals.earth.title"}}</td>
              <td class="v2-text-center">
                <input type="checkbox" name="system.domine.seals.minor.earth.isActive.value"
                       {{checked system.domine.seals.minor.earth.isActive.value}}>
              </td>
              <td class="v2-text-center">
                <input type="checkbox" name="system.domine.seals.major.earth.isActive.value"
                       {{checked system.domine.seals.major.earth.isActive.value}}>
              </td>
            </tr>
            <tr>
              <td class="v2-text-muted" style="font-size:0.8rem;">{{localize "anima.ui.domine.seals.metal.title"}}</td>
              <td class="v2-text-center">
                <input type="checkbox" name="system.domine.seals.minor.metal.isActive.value"
                       {{checked system.domine.seals.minor.metal.isActive.value}}>
              </td>
              <td class="v2-text-center">
                <input type="checkbox" name="system.domine.seals.major.metal.isActive.value"
                       {{checked system.domine.seals.major.metal.isActive.value}}>
              </td>
            </tr>
            <tr>
              <td class="v2-text-muted" style="font-size:0.8rem;">{{localize "anima.ui.domine.seals.wind.title"}}</td>
              <td class="v2-text-center">
                <input type="checkbox" name="system.domine.seals.minor.wind.isActive.value"
                       {{checked system.domine.seals.minor.wind.isActive.value}}>
              </td>
              <td class="v2-text-center">
                <input type="checkbox" name="system.domine.seals.major.wind.isActive.value"
                       {{checked system.domine.seals.major.wind.isActive.value}}>
              </td>
            </tr>
            <tr>
              <td class="v2-text-muted" style="font-size:0.8rem;">{{localize "anima.ui.domine.seals.water.title"}}</td>
              <td class="v2-text-center">
                <input type="checkbox" name="system.domine.seals.minor.water.isActive.value"
                       {{checked system.domine.seals.minor.water.isActive.value}}>
              </td>
              <td class="v2-text-center">
                <input type="checkbox" name="system.domine.seals.major.water.isActive.value"
                       {{checked system.domine.seals.major.water.isActive.value}}>
              </td>
            </tr>
            <tr>
              <td class="v2-text-muted" style="font-size:0.8rem;">{{localize "anima.ui.domine.seals.wood.title"}}</td>
              <td class="v2-text-center">
                <input type="checkbox" name="system.domine.seals.minor.wood.isActive.value"
                       {{checked system.domine.seals.minor.wood.isActive.value}}>
              </td>
              <td class="v2-text-center">
                <input type="checkbox" name="system.domine.seals.major.wood.isActive.value"
                       {{checked system.domine.seals.major.wood.isActive.value}}>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    {{!-- Linked Ki Creatures --}}
    <div class="v2-card">
      <div class="v2-card__header">
        <div class="v2-card__header-title">
          <span>{{localize "anima.ui.domine.kiCreatures.title"}}</span>
        </div>
        <div class="v2-card__header-actions">
          <button type="button" class="v2-card__header-btn" data-on-click="add-creature"
                  title="{{localize 'anima.ui.domine.kiCreatures.add'}}">
            <i class="fas fa-plus"></i>
          </button>
        </div>
      </div>
      <div class="v2-card__body" style="padding: 0;">
        <table class="v2-table v2-table--compact">
          <thead>
            <tr>
              <th>{{localize "anima.ui.domine.creatures.name.title"}}</th>
              <th style="width: 90px;">{{localize "anima.ui.domine.kiCreatures.kiSealCost.title"}}</th>
            </tr>
          </thead>
          <tbody id="creatures-context-menu-container">
            {{#each system.domine.creatures as |creature|}}
            <tr class="creature-row" data-item-id="{{creature._id}}">
              <td>
                {{#if creature.system.actorUuid.value}}
                <span class="ki-creature-link" data-uuid="{{creature.system.actorUuid.value}}"
                      title="{{localize 'anima.ui.domine.kiCreatures.openSheet'}}">
                  <i class="fas fa-external-link-alt" style="font-size:0.65rem;margin-right:3px;"></i>{{creature.name}}
                </span>
                {{else}}
                <span>{{creature.name}}</span>
                {{/if}}
              </td>
              <td>
                <input type="text"
                       name="system.dynamic.creatures.{{creature._id}}.system.kiSealCost.value"
                       value="{{creature.system.kiSealCost.value}}"
                       style="width:100%;border:none;background:transparent;font-size:0.75rem;">
              </td>
            </tr>
            {{else}}
            <tr>
              <td colspan="2" class="v2-text-center v2-text-muted" style="padding: 8px;">
                <i class="fas fa-hand-point-down" style="margin-right:4px;"></i>{{localize "anima.ui.domine.kiCreatures.dropHint"}}
              </td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>

  </div>{{!-- end grid --}}

</div>{{!-- end v2-tab-domine --}}
