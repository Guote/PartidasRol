{{!-- Domine Tab V2 --}}
<div class="v2-tab-domine">

  {{!-- Ki Accumulation --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <div class="v2-card__header-title">
        <span>{{localize "anima.ui.domine.kiAccumulation.title"}}</span>
      </div>
      <div class="v2-card__header-actions">
        <button type="button" class="v2-card__header-btn" data-on-click="ki-accumulation-macro"
                title="{{localize 'anima.ui.domine.kiAccumulation.macro.title'}}">
          <i class="fas fa-yin-yang"></i>
        </button>
      </div>
    </div>
    <div class="v2-card__body" style="padding: 0;">
      <table class="v2-table v2-table--compact">
        <thead>
          <tr>
            <th style="width: 55px;"></th>
            <th class="v2-text-center" style="width: 60px;">Base</th>
            <th class="v2-text-center" style="width: 60px;">Final</th>
            <th class="v2-text-center" style="width: 65px;">{{localize "anima.ui.domine.kiAccumulation.accumulation.title"}}</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="v2-text-muted" style="font-size:0.75rem;">{{localize "anima.ui.domine.kiAccumulation.strength.title"}}</td>
            <td class="v2-text-center">
              <input type="number" class="v2-table__input" style="width:50px;text-align:center;"
                     name="system.domine.kiAccumulation.strength.base.value"
                     value="{{system.domine.kiAccumulation.strength.base.value}}">
            </td>
            <td class="v2-text-center v2-text-muted" style="font-size:0.85rem;">{{system.domine.kiAccumulation.strength.final.value}}</td>
            <td class="v2-text-center">
              <input type="number" class="v2-table__input" style="width:55px;text-align:center;"
                     name="system.domine.kiAccumulation.strength.accumulated.value"
                     value="{{system.domine.kiAccumulation.strength.accumulated.value}}">
            </td>
          </tr>
          <tr>
            <td class="v2-text-muted" style="font-size:0.75rem;">{{localize "anima.ui.domine.kiAccumulation.agility.title"}}</td>
            <td class="v2-text-center">
              <input type="number" class="v2-table__input" style="width:50px;text-align:center;"
                     name="system.domine.kiAccumulation.agility.base.value"
                     value="{{system.domine.kiAccumulation.agility.base.value}}">
            </td>
            <td class="v2-text-center v2-text-muted" style="font-size:0.85rem;">{{system.domine.kiAccumulation.agility.final.value}}</td>
            <td class="v2-text-center">
              <input type="number" class="v2-table__input" style="width:55px;text-align:center;"
                     name="system.domine.kiAccumulation.agility.accumulated.value"
                     value="{{system.domine.kiAccumulation.agility.accumulated.value}}">
            </td>
          </tr>
          <tr>
            <td class="v2-text-muted" style="font-size:0.75rem;">{{localize "anima.ui.domine.kiAccumulation.dexterity.title"}}</td>
            <td class="v2-text-center">
              <input type="number" class="v2-table__input" style="width:50px;text-align:center;"
                     name="system.domine.kiAccumulation.dexterity.base.value"
                     value="{{system.domine.kiAccumulation.dexterity.base.value}}">
            </td>
            <td class="v2-text-center v2-text-muted" style="font-size:0.85rem;">{{system.domine.kiAccumulation.dexterity.final.value}}</td>
            <td class="v2-text-center">
              <input type="number" class="v2-table__input" style="width:55px;text-align:center;"
                     name="system.domine.kiAccumulation.dexterity.accumulated.value"
                     value="{{system.domine.kiAccumulation.dexterity.accumulated.value}}">
            </td>
          </tr>
          <tr>
            <td class="v2-text-muted" style="font-size:0.75rem;">{{localize "anima.ui.domine.kiAccumulation.constitution.title"}}</td>
            <td class="v2-text-center">
              <input type="number" class="v2-table__input" style="width:50px;text-align:center;"
                     name="system.domine.kiAccumulation.constitution.base.value"
                     value="{{system.domine.kiAccumulation.constitution.base.value}}">
            </td>
            <td class="v2-text-center v2-text-muted" style="font-size:0.85rem;">{{system.domine.kiAccumulation.constitution.final.value}}</td>
            <td class="v2-text-center">
              <input type="number" class="v2-table__input" style="width:55px;text-align:center;"
                     name="system.domine.kiAccumulation.constitution.accumulated.value"
                     value="{{system.domine.kiAccumulation.constitution.accumulated.value}}">
            </td>
          </tr>
          <tr>
            <td class="v2-text-muted" style="font-size:0.75rem;">{{localize "anima.ui.domine.kiAccumulation.willPower.title"}}</td>
            <td class="v2-text-center">
              <input type="number" class="v2-table__input" style="width:50px;text-align:center;"
                     name="system.domine.kiAccumulation.willPower.base.value"
                     value="{{system.domine.kiAccumulation.willPower.base.value}}">
            </td>
            <td class="v2-text-center v2-text-muted" style="font-size:0.85rem;">{{system.domine.kiAccumulation.willPower.final.value}}</td>
            <td class="v2-text-center">
              <input type="number" class="v2-table__input" style="width:55px;text-align:center;"
                     name="system.domine.kiAccumulation.willPower.accumulated.value"
                     value="{{system.domine.kiAccumulation.willPower.accumulated.value}}">
            </td>
          </tr>
          <tr>
            <td class="v2-text-muted" style="font-size:0.75rem;">{{localize "anima.ui.domine.kiAccumulation.power.title"}}</td>
            <td class="v2-text-center">
              <input type="number" class="v2-table__input" style="width:50px;text-align:center;"
                     name="system.domine.kiAccumulation.power.base.value"
                     value="{{system.domine.kiAccumulation.power.base.value}}">
            </td>
            <td class="v2-text-center v2-text-muted" style="font-size:0.85rem;">{{system.domine.kiAccumulation.power.final.value}}</td>
            <td class="v2-text-center">
              <input type="number" class="v2-table__input" style="width:55px;text-align:center;"
                     name="system.domine.kiAccumulation.power.accumulated.value"
                     value="{{system.domine.kiAccumulation.power.accumulated.value}}">
            </td>
          </tr>
          {{!-- Generic Ki Pool --}}
          <tr style="border-top: 1px solid var(--color-border-light-2, #d4c9a8);">
            <td class="v2-text-muted" style="font-size:0.75rem;">{{localize "anima.ui.domine.kiAccumulation.reserve.title"}}</td>
            <td class="v2-text-center" colspan="2">
              <span class="v2-text-muted" style="font-size:0.7rem;">Total acum: {{totalKiAccumulated}}</span>
            </td>
            <td class="v2-text-center">
              <div style="display:flex;align-items:center;justify-content:center;gap:2px;">
                <input type="number" class="v2-table__input" style="width:42px;text-align:center;"
                       name="system.domine.kiAccumulation.generic.value"
                       value="{{system.domine.kiAccumulation.generic.value}}">
                <span class="v2-text-muted" style="font-size:0.8rem;">/</span>
                <input type="number" class="v2-table__input" style="width:42px;text-align:center;"
                       name="system.domine.kiAccumulation.generic.max"
                       value="{{system.domine.kiAccumulation.generic.max}}">
              </div>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  {{!-- Ki Techniques --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <div class="v2-card__header-title">
        <span>{{localize "anima.ui.domine.techniques.title"}}</span>
      </div>
      <div class="v2-card__header-actions">
        <button type="button" class="v2-card__header-btn" data-on-click="add-technique" title="{{localize 'anima.ui.domine.techniques.title'}}">
          <i class="fas fa-plus"></i>
        </button>
      </div>
    </div>
    <div class="v2-card__body" style="padding: 0;">
      <table class="v2-table v2-table--compact">
        <thead>
          <tr>
            <th>{{localize "anima.ui.domine.techniques.technique.header.name.title"}}</th>
            <th class="v2-text-center" style="width:40px;">{{localize "anima.ui.domine.techniques.technique.footer.level.title"}}</th>
            <th class="v2-text-center" style="width:40px;">{{localize "anima.ui.domine.techniques.technique.footer.martialKnowledge.title"}}</th>
            <th class="v2-text-center" style="width:38px;">{{localize "anima.ui.domine.techniques.technique.footer.strength.title"}}</th>
            <th class="v2-text-center" style="width:38px;">{{localize "anima.ui.domine.techniques.technique.footer.agility.title"}}</th>
            <th class="v2-text-center" style="width:38px;">{{localize "anima.ui.domine.techniques.technique.footer.dexterity.title"}}</th>
            <th class="v2-text-center" style="width:38px;">{{localize "anima.ui.domine.techniques.technique.footer.constitution.title"}}</th>
            <th class="v2-text-center" style="width:38px;">{{localize "anima.ui.domine.techniques.technique.footer.willPower.title"}}</th>
            <th class="v2-text-center" style="width:38px;">{{localize "anima.ui.domine.techniques.technique.footer.power.title"}}</th>
          </tr>
        </thead>
        <tbody id="techniques-context-menu-container">
          {{#each system.domine.techniques as |technique|}}
          <tr class="technique-row v2-table__row--clickable" data-item-id="{{technique._id}}">
            <td><span class="v2-table__link" title="{{technique.name}}">{{technique.name}}</span></td>
            <td class="v2-text-center">{{technique.system.level.value}}</td>
            <td class="v2-text-center">{{technique.system.martialKnowledge.value}}</td>
            <td class="v2-text-center">{{technique.system.strength.value}}</td>
            <td class="v2-text-center">{{technique.system.agility.value}}</td>
            <td class="v2-text-center">{{technique.system.dexterity.value}}</td>
            <td class="v2-text-center">{{technique.system.constitution.value}}</td>
            <td class="v2-text-center">{{technique.system.willPower.value}}</td>
            <td class="v2-text-center">{{technique.system.power.value}}</td>
          </tr>
          {{else}}
          <tr>
            <td colspan="9" class="v2-text-center v2-text-muted">-</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>

  {{!-- Ki Seals + Linked Creatures side by side --}}
  <div class="v2-grid v2-grid--2">

    {{!-- Ki Seals --}}
    <div class="v2-card">
      <div class="v2-card__header">
        <span>{{localize "anima.ui.domine.seals.title"}}</span>
      </div>
      <div class="v2-card__body" style="padding: 0;">
        <table class="v2-table v2-table--compact">
          <thead>
            <tr>
              <th></th>
              <th class="v2-text-center" style="width: 60px;">{{localize "anima.ui.domine.seals.minor.title"}}</th>
              <th class="v2-text-center" style="width: 60px;">{{localize "anima.ui.domine.seals.major.title"}}</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="v2-text-muted" style="font-size:0.8rem;">{{localize "anima.ui.domine.seals.earth.title"}}</td>
              <td class="v2-text-center">
                <input type="checkbox" name="system.domine.seals.minor.earth.isActive.value"
                       {{checked system.domine.seals.minor.earth.isActive.value}}>
              </td>
              <td class="v2-text-center">
                <input type="checkbox" name="system.domine.seals.major.earth.isActive.value"
                       {{checked system.domine.seals.major.earth.isActive.value}}>
              </td>
            </tr>
            <tr>
              <td class="v2-text-muted" style="font-size:0.8rem;">{{localize "anima.ui.domine.seals.metal.title"}}</td>
              <td class="v2-text-center">
                <input type="checkbox" name="system.domine.seals.minor.metal.isActive.value"
                       {{checked system.domine.seals.minor.metal.isActive.value}}>
              </td>
              <td class="v2-text-center">
                <input type="checkbox" name="system.domine.seals.major.metal.isActive.value"
                       {{checked system.domine.seals.major.metal.isActive.value}}>
              </td>
            </tr>
            <tr>
              <td class="v2-text-muted" style="font-size:0.8rem;">{{localize "anima.ui.domine.seals.wind.title"}}</td>
              <td class="v2-text-center">
                <input type="checkbox" name="system.domine.seals.minor.wind.isActive.value"
                       {{checked system.domine.seals.minor.wind.isActive.value}}>
              </td>
              <td class="v2-text-center">
                <input type="checkbox" name="system.domine.seals.major.wind.isActive.value"
                       {{checked system.domine.seals.major.wind.isActive.value}}>
              </td>
            </tr>
            <tr>
              <td class="v2-text-muted" style="font-size:0.8rem;">{{localize "anima.ui.domine.seals.water.title"}}</td>
              <td class="v2-text-center">
                <input type="checkbox" name="system.domine.seals.minor.water.isActive.value"
                       {{checked system.domine.seals.minor.water.isActive.value}}>
              </td>
              <td class="v2-text-center">
                <input type="checkbox" name="system.domine.seals.major.water.isActive.value"
                       {{checked system.domine.seals.major.water.isActive.value}}>
              </td>
            </tr>
            <tr>
              <td class="v2-text-muted" style="font-size:0.8rem;">{{localize "anima.ui.domine.seals.wood.title"}}</td>
              <td class="v2-text-center">
                <input type="checkbox" name="system.domine.seals.minor.wood.isActive.value"
                       {{checked system.domine.seals.minor.wood.isActive.value}}>
              </td>
              <td class="v2-text-center">
                <input type="checkbox" name="system.domine.seals.major.wood.isActive.value"
                       {{checked system.domine.seals.major.wood.isActive.value}}>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    {{!-- Linked Ki Creatures --}}
    <div class="v2-card">
      <div class="v2-card__header">
        <div class="v2-card__header-title">
          <span>{{localize "anima.ui.domine.kiCreatures.title"}}</span>
        </div>
        <div class="v2-card__header-actions">
          <button type="button" class="v2-card__header-btn" data-on-click="add-creature"
                  title="{{localize 'anima.ui.domine.kiCreatures.add'}}">
            <i class="fas fa-plus"></i>
          </button>
        </div>
      </div>
      <div class="v2-card__body" style="padding: 0;">
        <table class="v2-table v2-table--compact">
          <thead>
            <tr>
              <th>{{localize "anima.ui.domine.creatures.name.title"}}</th>
              <th style="width: 90px;">{{localize "anima.ui.domine.kiCreatures.kiSealCost.title"}}</th>
            </tr>
          </thead>
          <tbody id="creatures-context-menu-container">
            {{#each system.domine.creatures as |creature|}}
            <tr class="creature-row" data-item-id="{{creature._id}}">
              <td>
                {{#if creature.system.actorUuid.value}}
                <span class="ki-creature-link" data-uuid="{{creature.system.actorUuid.value}}"
                      title="{{localize 'anima.ui.domine.kiCreatures.openSheet'}}">
                  <i class="fas fa-external-link-alt" style="font-size:0.65rem;margin-right:3px;"></i>{{creature.name}}
                </span>
                {{else}}
                <span>{{creature.name}}</span>
                {{/if}}
              </td>
              <td>
                <input type="text"
                       name="system.dynamic.creatures.{{creature._id}}.system.kiSealCost.value"
                       value="{{creature.system.kiSealCost.value}}"
                       style="width:100%;border:none;background:transparent;font-size:0.75rem;">
              </td>
            </tr>
            {{else}}
            <tr>
              <td colspan="2" class="v2-text-center v2-text-muted" style="padding: 8px;">
                <i class="fas fa-hand-point-down" style="margin-right:4px;"></i>{{localize "anima.ui.domine.kiCreatures.dropHint"}}
              </td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>

  </div>{{!-- end grid --}}

</div>{{!-- end v2-tab-domine --}}
