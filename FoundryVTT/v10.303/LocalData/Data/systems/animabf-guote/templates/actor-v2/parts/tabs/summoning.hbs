{{!-- Summoning/Convocatoria Tab - V2 styled summoning system --}}
<div class="v2-tab-summoning">
  {{!-- Summoning Stats Header --}}
  <div class="v2-card">
    <div class="v2-card__header" style="display:flex; align-items:center; justify-content:space-between;">
      <span>{{localize "anima.ui.mystic.summoning.title"}}</span>
      <div style="display:flex; align-items:center; gap:4px;">
        <span style="font-size:10px; color:#aaa; text-transform:uppercase;">Especialización</span>
        <select name="system.mystic.summoning.specialization.value" style="font-size:11px; border:1px solid rgba(255,255,255,0.2); background:rgba(0,0,0,0.2); color:inherit; border-radius:3px; padding:1px 4px;">
          <option value="ninguna"   {{#if (is 'eq' system.mystic.summoning.specialization.value 'ninguna')}}selected{{/if}}>Ninguna</option>
          <option value="elemental" {{#if (is 'eq' system.mystic.summoning.specialization.value 'elemental')}}selected{{/if}}>Elemental</option>
          <option value="invocador" {{#if (is 'eq' system.mystic.summoning.specialization.value 'invocador')}}selected{{/if}}>Invocador</option>
        </select>
      </div>
    </div>
    <div class="v2-card__body">
      <div class="v2-combat-values v2-summoning-stats">
        {{> "systems/animabf-guote/templates/actor-v2/components/combat-value.hbs"
            label=(localize "anima.ui.mystic.summoning.summon.title")
            baseName="system.mystic.summoning.summon.base.value"
            baseValue=system.mystic.summoning.summon.base.value
            finalValue=system.mystic.summoning.summon.final.value
            rollable=true
            rollLabel=(localize "anima.ui.mystic.summoning.summon.title")
            modifierType="general"}}

        {{> "systems/animabf-guote/templates/actor-v2/components/combat-value.hbs"
            label=(localize "anima.ui.mystic.summoning.bind.title")
            baseName="system.mystic.summoning.bind.base.value"
            baseValue=system.mystic.summoning.bind.base.value
            finalValue=system.mystic.summoning.bind.final.value
            rollable=true
            rollLabel=(localize "anima.ui.mystic.summoning.bind.title")
            modifierType="general"}}

        {{> "systems/animabf-guote/templates/actor-v2/components/combat-value.hbs"
            label=(localize "anima.ui.mystic.summoning.control.title")
            baseName="system.mystic.summoning.control.base.value"
            baseValue=system.mystic.summoning.control.base.value
            finalValue=system.mystic.summoning.control.final.value
            rollable=true
            rollLabel=(localize "anima.ui.mystic.summoning.control.title")
            modifierType="general"}}

        {{> "systems/animabf-guote/templates/actor-v2/components/combat-value.hbs"
            label=(localize "anima.ui.mystic.summoning.banish.title")
            baseName="system.mystic.summoning.banish.base.value"
            baseValue=system.mystic.summoning.banish.base.value
            finalValue=system.mystic.summoning.banish.final.value
            rollable=true
            rollLabel=(localize "anima.ui.mystic.summoning.banish.title")
            modifierType="general"}}
      </div>
    </div>
  </div>

  {{!-- Summons/Invocaciones List --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <div class="v2-card__header-title">
        <span>{{localize "anima.ui.mystic.summon.title"}}</span>
      </div>
      <div class="v2-card__header-actions">
        <button type="button" class="v2-card__header-btn" data-on-click="add-summon" title="{{localize 'anima.ui.mystic.summon.add'}}">
          <i class="fas fa-plus"></i>
        </button>
      </div>
    </div>
    <div class="v2-card__body" style="padding: 0;">
      <table class="v2-table v2-table--compact">
        <thead>
          <tr>
            <th style="width:28px;" title="Activo/Mantenido"><i class="fas fa-check-circle"></i></th>
            <th>{{localize "anima.ui.mystic.summon.name.title"}}</th>
            <th class="v2-text-center" style="width:44px;" title="Nivel de Éxito">NE</th>
            <th class="v2-text-center" style="width:45px;">{{localize "anima.ui.mystic.summon.summonDif.short"}}</th>
            <th class="v2-text-center" style="width:55px;">{{localize "anima.ui.mystic.summon.zeonCost.short"}}</th>
            <th style="width:30px;"></th>
          </tr>
        </thead>
        <tbody id="summons-context-menu-container">
          {{#each summonRows as |row|}}
          <tr class="summon-row v2-table__row--draggable{{#if row.power.active.value}} summon-row--active{{/if}}"
              data-item-id="{{row.summon._id}}" data-power-index="{{row.powerIndex}}">
            <td class="v2-text-center" style="padding:0;">
              <input type="checkbox" class="power-active-checkbox"
                     data-item-id="{{row.summon._id}}" data-power-index="{{row.powerIndex}}"
                     {{checked row.power.active.value}}
                     title="Activo/Mantenido">
            </td>
            <td>
              <span class="v2-table__link">{{row.displayName}}</span>
              {{#if row.resolvedDuration}}
              <div class="summon-resolved-duration">{{row.resolvedDuration}}</div>
              {{/if}}
            </td>
            <td class="v2-text-center" style="padding: 2px 4px;">
              <input type="number" class="power-ne-input v2-text-center"
                     data-item-id="{{row.summon._id}}" data-power-index="{{row.powerIndex}}"
                     value="{{row.ne}}"
                     style="width:36px; border: 1px solid rgba(255,200,80,0.6); border-radius:3px; background: rgba(255,200,80,0.08);">
            </td>
            <td class="v2-text-center">{{row.power.summonDif.value}}</td>
            <td class="v2-text-center">{{row.zeonFinal}}</td>
            <td class="v2-text-center" style="padding:2px;">
              <button type="button" class="abf-button icon-button roll-summon-power"
                data-item-id="{{row.summon._id}}" data-power-index="{{row.powerIndex}}"
                title="Tirar invocación"
                style="width:auto !important; display:inline-flex; padding:3px 6px;">
                <i class="fas fa-dice-d20"></i>
              </button>
            </td>
          </tr>
          {{else}}
          <tr>
            <td colspan="6" class="v2-text-center v2-text-muted">-</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>

  {{!-- Criaturas Vinculadas --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <div class="v2-card__header-title">
        <span>{{localize "anima.ui.mystic.creatureSummon.title"}}</span>
      </div>
      <div class="v2-card__header-actions">
        <button type="button" class="v2-card__header-btn" data-on-click="add-creature-summon" title="{{localize 'anima.ui.mystic.creatureSummon.add'}}">
          <i class="fas fa-plus"></i>
        </button>
      </div>
    </div>
    <div class="v2-card__body" style="padding: 0;">
      <table class="v2-table v2-table--compact">
        <thead>
          <tr>
            <th>{{localize "anima.ui.mystic.creatureSummon.name"}}</th>
            <th>{{localize "anima.ui.mystic.creatureSummon.notes"}}</th>
          </tr>
        </thead>
        <tbody id="creature-summons-context-menu-container">
          {{#each system.mystic.creatureSummons as |cs|}}
          <tr class="creature-summon-row" data-item-id="{{cs._id}}">
            <td>
              {{#if cs.system.actorUuid.value}}
              <span class="creature-summon-link" data-uuid="{{cs.system.actorUuid.value}}" title="{{localize 'anima.ui.mystic.creatureSummon.openSheet'}}">
                <i class="fas fa-external-link-alt" style="font-size:0.7rem;margin-right:2px;"></i>{{cs.name}}
              </span>
              {{else}}
              <span>{{cs.name}}</span>
              {{/if}}
            </td>
            <td>
              <input type="text" name="system.dynamic.creatureSummons.{{cs._id}}.system.notes.value"
                     value="{{cs.system.notes.value}}" style="width:100%;border:none;background:transparent;font-size:0.75rem;">
            </td>
          </tr>
          {{else}}
          <tr>
            <td colspan="2" class="v2-text-center v2-text-muted" style="padding: 8px;">
              <i class="fas fa-hand-point-down" style="margin-right:4px;"></i>{{localize "anima.ui.mystic.creatureSummon.dropHint"}}
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>

  {{!-- Encarnaciones --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <div class="v2-card__header-title">
        <span>{{localize "anima.ui.mystic.incarnation.title"}}</span>
      </div>
      <div class="v2-card__header-actions">
        <button type="button" class="v2-card__header-btn" data-on-click="add-incarnation" title="{{localize 'anima.ui.mystic.incarnation.add'}}">
          <i class="fas fa-plus"></i>
        </button>
      </div>
    </div>
    <div class="v2-card__body" style="padding: 0;">
      <table class="v2-table v2-table--compact">
        <thead>
          <tr>
            <th style="width:28px;"></th>
            <th>{{localize "anima.ui.mystic.incarnation.name"}}</th>
            <th class="v2-text-center" style="width:45px;">Dif</th>
            <th class="v2-text-center" style="width:55px;">{{localize "anima.ui.mystic.incarnation.summonBonus.short"}}</th>
          </tr>
        </thead>
        <tbody id="incarnations-context-menu-container">
          {{#each system.mystic.incarnations as |inc|}}
          <tr class="incarnation-row" data-item-id="{{inc._id}}">
            <td class="v2-text-center" style="padding:0;">
              <input type="checkbox" class="incarnation-toggle" data-item-id="{{inc._id}}"
                     {{#if inc.system.active.value}}checked{{/if}}
                     title="{{localize 'anima.ui.mystic.incarnation.active'}}">
            </td>
            <td>
              <span class="v2-table__link {{#if inc.system.active.value}}incarnation--active{{/if}}" title="{{inc.name}}">{{inc.name}}</span>
            </td>
            <td class="v2-text-center">{{inc.system.difficulty.value}}</td>
            <td class="v2-text-center">
              <input type="number" class="incarnation-summon-bonus" data-item-id="{{inc._id}}"
                     value="{{inc.system.summonBonus.value}}"
                     style="width:40px;text-align:center;border:1px solid #d4c9a8;border-radius:3px;font-size:0.75rem;padding:1px;">
            </td>
          </tr>
          {{else}}
          <tr>
            <td colspan="4" class="v2-text-center v2-text-muted">-</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>
</div>
