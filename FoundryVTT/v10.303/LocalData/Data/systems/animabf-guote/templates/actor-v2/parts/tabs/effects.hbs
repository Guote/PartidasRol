{{!-- Effects Tab - Modifiers & Active Effects --}}
<div class="v2-tab-effects">
  {{!-- Modifiers Table --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <span>{{localize "anima.ui.general.modifiers.title"}}</span>
    </div>
    <div class="v2-card__body">
      <div class="v2-modifiers-table">

        {{!-- Header row --}}
        <div class="v2-modifiers-table__row v2-modifiers-table__row--header">
          <span class="v2-modifiers-table__cell"></span>
          <span class="v2-modifiers-table__cell">{{localize "anima.ui.general.modifiers.physicalActions.title"}}</span>
          <span class="v2-modifiers-table__cell">{{localize
            "anima.ui.general.modifiers.supernaturalActions.title"}}</span>
        </div>

        {{!-- Bonus row --}}
        <div class="v2-modifiers-table__row">
          <span class="v2-modifiers-table__cell v2-modifiers-table__cell--label v2-mod--bonus">Bonus (+)</span>

          <span class="v2-modifiers-table__cell v2-modifiers-table__cell--content">
            <input type="number" class="v2-modifiers-table__input v2-mod--bonus"
              name="system.general.modifiers.modFisico.bonus.value"
              value="{{system.general.modifiers.modFisico.bonus.value}}">
            {{#each system.general.modifiers.modFisico.breakdown as |row|}}
            {{#if (gt row.value 0)}}
            <div class="v2-mod-entry v2-mod--positive">
              <span class="v2-mod-entry__label">↳ {{row.label}}</span>
              <span class="v2-mod-entry__value">{{row.value}}</span>
            </div>
            {{/if}}
            {{/each}}
          </span>

          <span class="v2-modifiers-table__cell v2-modifiers-table__cell--content">
            <input type="number" class="v2-modifiers-table__input v2-mod--bonus"
              name="system.general.modifiers.modSobrenatural.bonus.value"
              value="{{system.general.modifiers.modSobrenatural.bonus.value}}">
            {{#each system.general.modifiers.modSobrenatural.breakdown as |row|}}
            {{#if (gt row.value 0)}}
            <div class="v2-mod-entry v2-mod--positive">
              <span class="v2-mod-entry__label">↳ {{row.label}}</span>
              <span class="v2-mod-entry__value">{{row.value}}</span>
            </div>
            {{/if}}
            {{/each}}
          </span>
        </div>

        {{!-- Malus row --}}
        <div class="v2-modifiers-table__row">
          <span class="v2-modifiers-table__cell v2-modifiers-table__cell--label v2-mod--malus">Malus (−)</span>

          <span class="v2-modifiers-table__cell v2-modifiers-table__cell--content">
            <input type="number" class="v2-modifiers-table__input v2-mod--malus"
              name="system.general.modifiers.modFisico.malus.value"
              value="{{system.general.modifiers.modFisico.malus.value}}">
            {{#each system.general.modifiers.modFisico.breakdown as |row|}}
            {{#if (lt row.value 0)}}
            <div class="v2-mod-entry v2-mod--negative">
              <span class="v2-mod-entry__label">↳ {{row.label}}</span>
              <span class="v2-mod-entry__value">{{row.value}}</span>
            </div>
            {{/if}}
            {{/each}}
          </span>

          <span class="v2-modifiers-table__cell v2-modifiers-table__cell--content">
            <input type="number" class="v2-modifiers-table__input v2-mod--malus"
              name="system.general.modifiers.modSobrenatural.malus.value"
              value="{{system.general.modifiers.modSobrenatural.malus.value}}">
            {{#each system.general.modifiers.modSobrenatural.breakdown as |row|}}
            {{#if (lt row.value 0)}}
            <div class="v2-mod-entry v2-mod--negative">
              <span class="v2-mod-entry__label">↳ {{row.label}}</span>
              <span class="v2-mod-entry__value">{{row.value}}</span>
            </div>
            {{/if}}
            {{/each}}
          </span>
        </div>

        {{!-- Custom entries row (editable only) --}}
        {{#if editable}}
        <div class="v2-modifiers-table__row">
          <span
            class="v2-modifiers-table__cell v2-modifiers-table__cell--label v2-modifiers-table__cell--custom-label">+
            propias</span>

          <span class="v2-modifiers-table__cell v2-modifiers-table__cell--content">
            {{#each system.general.modifiers.modFisico.customEntries as |entry i|}}
            <div class="v2-mod-custom-entry">
              <input type="text" class="v2-mod-custom-entry__label-input"
                name="system.general.modifiers.modFisico.customEntries.{{i}}.label" value="{{entry.label}}"
                placeholder="Etiqueta">
              <input type="number" class="v2-mod-custom-entry__value-input"
                name="system.general.modifiers.modFisico.customEntries.{{i}}.value" value="{{entry.value}}">
              <button type="button" class="v2-mod-custom-entry__del" data-action="remove-custom-mod"
                data-mod-key="modFisico" data-index="{{i}}" title="Eliminar">
                <i class="fas fa-times"></i>
              </button>
            </div>
            {{/each}}
            <button type="button" class="v2-add-btn" data-action="add-custom-mod" data-mod-key="modFisico">
              <i class="fas fa-plus"></i> Añadir
            </button>
          </span>

          <span class="v2-modifiers-table__cell v2-modifiers-table__cell--content">
            {{#each system.general.modifiers.modSobrenatural.customEntries as |entry i|}}
            <div class="v2-mod-custom-entry">
              <input type="text" class="v2-mod-custom-entry__label-input"
                name="system.general.modifiers.modSobrenatural.customEntries.{{i}}.label" value="{{entry.label}}"
                placeholder="Etiqueta">
              <input type="number" class="v2-mod-custom-entry__value-input"
                name="system.general.modifiers.modSobrenatural.customEntries.{{i}}.value" value="{{entry.value}}">
              <button type="button" class="v2-mod-custom-entry__del" data-action="remove-custom-mod"
                data-mod-key="modSobrenatural" data-index="{{i}}" title="Eliminar">
                <i class="fas fa-times"></i>
              </button>
            </div>
            {{/each}}
            <button type="button" class="v2-add-btn" data-action="add-custom-mod" data-mod-key="modSobrenatural">
              <i class="fas fa-plus"></i> Añadir
            </button>
          </span>
        </div>
        {{/if}}

        {{!-- Total row --}}
        {{!-- <div class="v2-modifiers-table__row v2-modifiers-table__row--final">
          <span class="v2-modifiers-table__cell v2-modifiers-table__cell--label">Total</span>
          <span class="v2-modifiers-table__cell v2-modifiers-table__cell--result
            {{#if (gt system.general.modifiers.modFisico.final.value 0)}}v2-mod--positive{{/if}}
            {{#if (lt system.general.modifiers.modFisico.final.value 0)}}v2-mod--negative{{/if}}">
            {{system.general.modifiers.modFisico.final.value}}
          </span>
          <span class="v2-modifiers-table__cell v2-modifiers-table__cell--result
            {{#if (gt system.general.modifiers.modSobrenatural.final.value 0)}}v2-mod--positive{{/if}}
            {{#if (lt system.general.modifiers.modSobrenatural.final.value 0)}}v2-mod--negative{{/if}}">
            {{system.general.modifiers.modSobrenatural.final.value}}
          </span>
        </div> --}}

      </div>

      {{!-- Modifier type reference: shows which computed value applies to each roll type --}}
      <div class="v2-mod-type-grid">
        <div class="v2-mod-type-cell v2-mod-type-cell--wide"
          title="Se aplica a: Habilidades secundarias y primarias&#10;Qué se aplica: Modificador completo (físico y sobrenatural, positivo y negativo)">
          <span class="v2-mod-type__name">Modificador general <i class="fas fa-info-circle"></i></span>
          <span class="v2-mod-type__value
            {{#if (gt system.general.modifiers.modFinal.general.final.value 0)}}v2-mod--positive{{/if}}
            {{#if (lt system.general.modifiers.modFinal.general.final.value 0)}}v2-mod--negative{{/if}}">
            {{system.general.modifiers.modFinal.general.final.value}}
          </span>
        </div>
        <div class="v2-mod-type-cell"
          title="Se aplica a: Iniciativa (turno)&#10;Qué se aplica: Mitad del modificador general, positivo y negativo">
          <span class="v2-mod-type__name">Turno <i class="fas fa-info-circle"></i></span>
          <span class="v2-mod-type__value
            {{#if (gt system.general.modifiers.modFinal.initiative 0)}}v2-mod--positive{{/if}}
            {{#if (lt system.general.modifiers.modFinal.initiative 0)}}v2-mod--negative{{/if}}">
            {{system.general.modifiers.modFinal.initiative}}
          </span>
        </div>
        <div class="v2-mod-type-cell"
          title="Se aplica a: Ataques con armas&#10;Qué se aplica: Modificador completo + extras por maniobras o posturas de combate">
          <span class="v2-mod-type__name">Ataques con armas <i class="fas fa-info-circle"></i></span>
          <span class="v2-mod-type__value
            {{#if (gt system.general.modifiers.modFinal.attack.final.value 0)}}v2-mod--positive{{/if}}
            {{#if (lt system.general.modifiers.modFinal.attack.final.value 0)}}v2-mod--negative{{/if}}">
            {{system.general.modifiers.modFinal.attack.final.value}}
          </span>
        </div>
        <div class="v2-mod-type-cell"
          title="Se aplica a: Proyección Mágica y Psíquica, Habilidades de Convocatoria&#10;Qué se aplica: Modificador general completo, solo si es negativo">
          <span class="v2-mod-type__name">Proy. Mágica, Proy. Psíquica, Convocatoria <i class="fas fa-info-circle"></i></span>
          <span class="v2-mod-type__value
            {{#if (gt system.general.modifiers.modFinal.generalNegative 0)}}v2-mod--positive{{/if}}
            {{#if (lt system.general.modifiers.modFinal.generalNegative 0)}}v2-mod--negative{{/if}}">
            {{system.general.modifiers.modFinal.generalNegative}}
          </span>
        </div>
        <div class="v2-mod-type-cell"
          title="Se aplica a: Tipo de Movimiento, Índice de Peso, Acumulaciones de Ki&#10;Qué se aplica: -1 por cada -20 de modificador general, solo si es negativo">
          <span class="v2-mod-type__name">Capacidades físicas, Ki ACT <i class="fas fa-info-circle"></i></span>
          <span class="v2-mod-type__value
            {{#if (gt system.general.modifiers.modFinal.generalNegativeFloor20 0)}}v2-mod--positive{{/if}}
            {{#if (lt system.general.modifiers.modFinal.generalNegativeFloor20 0)}}v2-mod--negative{{/if}}">
            {{system.general.modifiers.modFinal.generalNegativeFloor20}}
          </span>
        </div>
        <div class="v2-mod-type-cell"
          title="Se aplica a: Defensas con armas&#10;Qué se aplica: Modificador completo + extras por maniobras o posturas de combate">
          <span class="v2-mod-type__name">Defensas con armas <i class="fas fa-info-circle"></i></span>
          <span class="v2-mod-type__value
            {{#if (gt system.general.modifiers.modFinal.defense.final.value 0)}}v2-mod--positive{{/if}}
            {{#if (lt system.general.modifiers.modFinal.defense.final.value 0)}}v2-mod--negative{{/if}}">
            {{system.general.modifiers.modFinal.defense.final.value}}
          </span>
        </div>
        <div class="v2-mod-type-cell"
          title="Se aplica a: Zeon ACT, Potencial Psíquico&#10;Qué se aplica: Mitad del modificador general, solo si es negativo">
          <span class="v2-mod-type__name">Zeon ACT, Potencial Psíquico <i class="fas fa-info-circle"></i></span>
          <span class="v2-mod-type__value
            {{#if (gt system.general.modifiers.modFinal.generalNegativeHalf 0)}}v2-mod--positive{{/if}}
            {{#if (lt system.general.modifiers.modFinal.generalNegativeHalf 0)}}v2-mod--negative{{/if}}">
            {{system.general.modifiers.modFinal.generalNegativeHalf}}
          </span>
        </div>
      </div>

    </div>
  </div>
  <div class="v2-card">
    <div class="v2-card__header">
      <span>Efectos activos</span>
    </div>
    <div class="v2-card__body">
      {{#if effects}}
      <ol class="items-list effects-list v2-effects-list">
        {{#each effects as |section sid|}}
        {{#unless section.hidden}}
        <li class="v2-effects-section" data-effect-type="{{section.type}}">
          <h3 class="v2-effects-section__title">{{localize section.label}}</h3>

          {{#if section.info}}
          <ol class="v2-effects-info">
            {{#each section.info}}
            <li class="v2-effects-info__item">{{this}}</li>
            {{/each}}
          </ol>
          {{/if}}

          {{#if section.effects.length}}
          <ol class="v2-effects-items">
            {{#each section.effects as |effect|}}
            <li class="v2-effect-item {{#if effect.disabled}}v2-effect-item--disabled{{/if}}"
              data-effect-id="{{effect.id}}">
              <img class="v2-effect-item__icon" src="{{effect.icon}}" alt="{{effect.label}}" />
              <div class="v2-effect-item__info">
                <span class="v2-effect-item__name">{{effect.label}}</span>
                <span class="v2-effect-item__meta">
                  {{#if effect.sourceName}}<span class="v2-effect-item__source">{{effect.sourceName}}</span>{{/if}}
                  {{#if effect.duration.label}}<span
                    class="v2-effect-item__duration">{{effect.duration.label}}</span>{{/if}}
                </span>
              </div>
              {{#if @root.editable}}
              <div class="v2-effect-item__controls">
                <a class="effect-control v2-effect-btn" data-action="toggle"
                  title="{{#if effect.disabled}}Enable{{else}}Disable{{/if}}">
                  <i class="fas {{#if effect.disabled}}fa-toggle-off{{else}}fa-toggle-on{{/if}}"></i>
                </a>
                <a class="effect-control v2-effect-btn" data-action="edit" title="Edit">
                  <i class="fas fa-edit"></i>
                </a>
                <a class="effect-control v2-effect-btn v2-effect-btn--danger" data-action="delete" title="Delete">
                  <i class="fas fa-trash"></i>
                </a>
              </div>
              {{/if}}
            </li>
            {{/each}}
          </ol>
          {{/if}}
        </li>
        {{/unless}}
        {{/each}}
      </ol>
      {{else}}
      <p class="v2-effects-empty v2-text-center v2-text-muted">No active effects</p>
      {{/if}}
    </div>
  </div>
</div>