{{!-- Effects Tab - Modifiers & Active Effects --}}
<div class="v2-tab-effects">
  {{!-- Modifiers Table --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <span>{{localize "anima.ui.general.modifiers.title"}}</span>
    </div>
    <div class="v2-card__body">
      <div class="v2-modifiers-table">
        {{!-- Header row --}}
        <div class="v2-modifiers-table__row v2-modifiers-table__row--header">
          <span class="v2-modifiers-table__cell"></span>
          <span class="v2-modifiers-table__cell">{{localize "anima.ui.general.modifiers.physicalActions.title"}}</span>
          <span class="v2-modifiers-table__cell">{{localize "anima.ui.general.modifiers.supernaturalActions.title"}}</span>
          <span class="v2-modifiers-table__cell v2-modifiers-table__cell--sep"></span>
          <span class="v2-modifiers-table__cell">General</span>
          <span class="v2-modifiers-table__cell">{{localize "anima.ui.combat.baseValues.attack.title"}}</span>
          <span class="v2-modifiers-table__cell">{{localize "anima.macros.combat.dialog.defense.title"}}</span>
        </div>
        {{!-- Bonus row --}}
        <div class="v2-modifiers-table__row">
          <span class="v2-modifiers-table__cell v2-modifiers-table__cell--label v2-mod--bonus">Bonus (+)</span>
          <span class="v2-modifiers-table__cell">
            <input type="number" class="v2-modifiers-table__input v2-mod--bonus" name="system.general.modifiers.modFisico.bonus.value" value="{{system.general.modifiers.modFisico.bonus.value}}">
          </span>
          <span class="v2-modifiers-table__cell">
            <input type="number" class="v2-modifiers-table__input v2-mod--bonus" name="system.general.modifiers.modSobrenatural.bonus.value" value="{{system.general.modifiers.modSobrenatural.bonus.value}}">
          </span>
          <span class="v2-modifiers-table__cell v2-modifiers-table__cell--sep"></span>
          <span class="v2-modifiers-table__cell v2-modifiers-table__cell--final {{#if (gt system.general.modifiers.modFinal.general.final.value 0)}}v2-mod--positive{{/if}} {{#if (lt system.general.modifiers.modFinal.general.final.value 0)}}v2-mod--negative{{/if}}">
            {{system.general.modifiers.modFinal.general.final.value}}
          </span>
          <span class="v2-modifiers-table__cell v2-modifiers-table__cell--final {{#if (gt system.general.modifiers.modFinal.attack.final.value 0)}}v2-mod--positive{{/if}} {{#if (lt system.general.modifiers.modFinal.attack.final.value 0)}}v2-mod--negative{{/if}}">
            {{system.general.modifiers.modFinal.attack.final.value}}
          </span>
          <span class="v2-modifiers-table__cell v2-modifiers-table__cell--final {{#if (gt system.general.modifiers.modFinal.defense.final.value 0)}}v2-mod--positive{{/if}} {{#if (lt system.general.modifiers.modFinal.defense.final.value 0)}}v2-mod--negative{{/if}}">
            {{system.general.modifiers.modFinal.defense.final.value}}
          </span>
        </div>
        {{!-- Malus row --}}
        <div class="v2-modifiers-table__row">
          <span class="v2-modifiers-table__cell v2-modifiers-table__cell--label v2-mod--malus">Malus (-)</span>
          <span class="v2-modifiers-table__cell">
            <input type="number" class="v2-modifiers-table__input v2-mod--malus" name="system.general.modifiers.modFisico.malus.value" value="{{system.general.modifiers.modFisico.malus.value}}">
          </span>
          <span class="v2-modifiers-table__cell">
            <input type="number" class="v2-modifiers-table__input v2-mod--malus" name="system.general.modifiers.modSobrenatural.malus.value" value="{{system.general.modifiers.modSobrenatural.malus.value}}">
          </span>
          <span class="v2-modifiers-table__cell v2-modifiers-table__cell--sep"></span>
          <span class="v2-modifiers-table__cell"></span>
          <span class="v2-modifiers-table__cell"></span>
          <span class="v2-modifiers-table__cell"></span>
        </div>
        {{!-- Final row --}}
        <div class="v2-modifiers-table__row v2-modifiers-table__row--final">
          <span class="v2-modifiers-table__cell v2-modifiers-table__cell--label">Total</span>
          <span class="v2-modifiers-table__cell v2-modifiers-table__cell--result {{#if (gt system.general.modifiers.modFisico.final.value 0)}}v2-mod--positive{{/if}} {{#if (lt system.general.modifiers.modFisico.final.value 0)}}v2-mod--negative{{/if}}">
            {{system.general.modifiers.modFisico.final.value}}
          </span>
          <span class="v2-modifiers-table__cell v2-modifiers-table__cell--result {{#if (gt system.general.modifiers.modSobrenatural.final.value 0)}}v2-mod--positive{{/if}} {{#if (lt system.general.modifiers.modSobrenatural.final.value 0)}}v2-mod--negative{{/if}}">
            {{system.general.modifiers.modSobrenatural.final.value}}
          </span>
          <span class="v2-modifiers-table__cell v2-modifiers-table__cell--sep"></span>
          <span class="v2-modifiers-table__cell"></span>
          <span class="v2-modifiers-table__cell"></span>
          <span class="v2-modifiers-table__cell"></span>
        </div>
      </div>
    </div>
  </div>

  {{!-- Active Effects --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <span class="v2-card__header-title">
        <i class="fas fa-magic"></i>
        Active Effects
      </span>
      {{#if editable}}
      <div class="v2-card__header-actions">
        <button type="button" class="v2-add-btn" data-action="create-effect">
          <i class="fas fa-plus"></i> Add Effect
        </button>
      </div>
      {{/if}}
    </div>
    <div class="v2-card__body">
      {{#if effects}}
      <ol class="items-list effects-list v2-effects-list">
        {{#each effects as |section sid|}}
        {{#unless section.hidden}}
        <li class="v2-effects-section" data-effect-type="{{section.type}}">
          <h3 class="v2-effects-section__title">{{localize section.label}}</h3>

          {{#if section.info}}
          <ol class="v2-effects-info">
            {{#each section.info}}
            <li class="v2-effects-info__item">{{this}}</li>
            {{/each}}
          </ol>
          {{/if}}

          {{#if section.effects.length}}
          <ol class="v2-effects-items">
            {{#each section.effects as |effect|}}
            <li class="v2-effect-item {{#if effect.disabled}}v2-effect-item--disabled{{/if}}" data-effect-id="{{effect.id}}">
              <img class="v2-effect-item__icon" src="{{effect.icon}}" alt="{{effect.label}}" />
              <div class="v2-effect-item__info">
                <span class="v2-effect-item__name">{{effect.label}}</span>
                <span class="v2-effect-item__meta">
                  {{#if effect.sourceName}}<span class="v2-effect-item__source">{{effect.sourceName}}</span>{{/if}}
                  {{#if effect.duration.label}}<span class="v2-effect-item__duration">{{effect.duration.label}}</span>{{/if}}
                </span>
              </div>
              {{#if @root.editable}}
              <div class="v2-effect-item__controls">
                <a class="effect-control v2-effect-btn" data-action="toggle" title="{{#if effect.disabled}}Enable{{else}}Disable{{/if}}">
                  <i class="fas {{#if effect.disabled}}fa-toggle-off{{else}}fa-toggle-on{{/if}}"></i>
                </a>
                <a class="effect-control v2-effect-btn" data-action="edit" title="Edit">
                  <i class="fas fa-edit"></i>
                </a>
                <a class="effect-control v2-effect-btn v2-effect-btn--danger" data-action="delete" title="Delete">
                  <i class="fas fa-trash"></i>
                </a>
              </div>
              {{/if}}
            </li>
            {{/each}}
          </ol>
          {{else}}
          <p class="v2-effects-empty">No effects in this category</p>
          {{/if}}
        </li>
        {{/unless}}
        {{/each}}
      </ol>
      {{else}}
      <p class="v2-effects-empty v2-text-center v2-text-muted">No active effects</p>
      {{/if}}
    </div>
  </div>
</div>
