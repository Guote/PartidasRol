{{!--
  Simple Item List Component
  A card with a table listing items by name, with an add button and context menu support.

  Parameters:
  - title: Card header title (localized string)
  - addAction: The data-on-click action for the add button (e.g., "add-advantage")
  - addLabel: Tooltip for the add button
  - items: Array of items to display (each must have ._id and .name)
--}}
<div class="v2-card">
  <div class="v2-card__header">
    <div class="v2-card__header-title">
      <span>{{title}}</span>
    </div>
    <div class="v2-card__header-actions">
      <button type="button" class="v2-card__header-btn" data-on-click="{{addAction}}" title="{{addLabel}}">
        <i class="fas fa-plus"></i>
      </button>
    </div>
  </div>
  <div class="v2-card__body" style="padding: 0;">
    <table class="v2-table">
      <tbody>
        {{#each items as |item|}}
        <tr data-item-id="{{item._id}}">
          <td>{{item.name}}</td>
        </tr>
        {{else}}
        <tr>
          <td class="v2-text-center v2-text-muted">-</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>
