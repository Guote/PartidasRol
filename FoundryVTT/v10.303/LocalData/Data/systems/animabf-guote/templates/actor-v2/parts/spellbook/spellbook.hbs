<div class="spellbook-container">
  {{!-- Header --}}
  <header class="spellbook-header">
    <div class="spellbook-header__info">
      <span class="spellbook-header__count">
        {{localize "anima.ui.spellbook.spellCount" count=totalSpells}}
      </span>
    </div>
    <div class="spellbook-header__resources">
      {{!-- Zeon Group (Zeon + Accumulated) --}}
      <div class="v2-res-group">
        <div class="v2-res v2-res--zeon v2-res--compact" title="{{localize 'anima.ui.mystic.zeon.title'}}">
          <span class="v2-res__label"><i class="fas fa-hat-wizard"></i> Zeon</span>
          <div class="v2-res__values">
            <input type="number" class="v2-res__input v2-res__input--compact"
                   name="system.mystic.zeon.value"
                   value="{{mystic.zeon.value}}">
            <span class="v2-res__sep">/</span>
            <input type="number" class="v2-res__input v2-res__input--compact"
                   name="system.mystic.zeon.max"
                   value="{{mystic.zeon.max}}">
          </div>
        </div>
        <div class="v2-res-group__sep"></div>
        <div class="v2-res v2-res--zeon-acc v2-res--compact v2-res--single" title="Zeon Acumulado">
          <span class="v2-res__label"><i class="fas fa-hat-wizard"></i> Acum</span>
          <div class="v2-res__values">
            <input type="number" class="v2-res__input v2-res__input--compact"
                   name="system.mystic.zeonAccumulated.value"
                   value="{{mystic.zeonAccumulated.value}}">
          </div>
        </div>
      </div>

      {{!-- Shield --}}
      <div class="v2-res v2-res--shield v2-res--compact" title="{{localize 'anima.ui.mystic.shield.title'}}">
        <span class="v2-res__label"><i class="fas fa-shield-alt"></i> Escudo</span>
        <div class="v2-res__values">
          <input type="number" class="v2-res__input v2-res__input--compact"
                 name="system.mystic.shield.value"
                 value="{{mystic.shield.value}}">
          <span class="v2-res__sep">/</span>
          <input type="number" class="v2-res__input v2-res__input--compact"
                 name="system.mystic.shield.max"
                 value="{{mystic.shield.max}}">
        </div>
      </div>
    </div>
    <div class="spellbook-header__actions">
      <button type="button" class="spellbook-btn" data-action="expand-all">
        <i class="fas fa-expand-alt"></i>
        {{localize "anima.ui.spellbook.expandAll"}}
      </button>
      <button type="button" class="spellbook-btn" data-action="collapse-all">
        <i class="fas fa-compress-alt"></i>
        {{localize "anima.ui.spellbook.collapseAll"}}
      </button>
      <button type="button" class="spellbook-btn" data-action="open-zeon-calculator" draggable="true">
        <i class="fas fa-calculator"></i>
        {{localize "anima.ui.spellbook.openCalculator"}}
      </button>
    </div>
  </header>

  {{!-- Main area with side tabs --}}
  <div class="spellbook-main">
    {{!-- Side Tabs --}}
    <nav class="spellbook-sidetabs">
      {{!-- Overview Tab (always first) --}}
      <button type="button"
              class="spellbook-sidetab spellbook-sidetab--overview {{#if isOverviewTab}}active{{/if}}"
              data-via="{{overviewTabId}}">
        <span class="spellbook-sidetab__label">{{localize "anima.ui.spellbook.overview"}}</span>
        <i class="fas fa-chart-bar"></i>
      </button>
      {{!-- Via Tabs --}}
      {{#each availableVias as |via|}}
      <button type="button"
              class="spellbook-sidetab {{#if (eq via ../activeVia)}}active{{/if}}"
              data-via="{{via}}">
        <span class="spellbook-sidetab__label">{{lookup ../viaLabels via}}</span>
        <span class="spellbook-sidetab__count">{{lookup (lookup ../spellsByVia via) "length"}}</span>
      </button>
      {{/each}}
    </nav>

    {{!-- Content Area --}}
    <main class="spellbook-content">
    {{#if isOverviewTab}}
      {{!-- Overview Tab Content --}}
      <form class="spellbook-overview" autocomplete="off">
        {{!-- Combat Stats Row: Projections + ACT + Innate Magic --}}
        <div class="spellbook-combat-row">
          {{!-- Magic Projection Offensive --}}
          {{> "systems/animabf-guote/templates/actor-v2/components/combat-value.hbs"
              label=(localize "anima.ui.mystic.magicProjection.offensive.title")
              baseName="system.mystic.magicProjection.imbalance.offensive.base.value"
              baseValue=mystic.magicProjection.imbalance.offensive.base.value
              finalValue=mystic.magicProjection.imbalance.offensive.final.value
              rollLabel=(localize "anima.ui.mystic.magicProjection.offensive.title")
              modifierType="general-negative"
              rollableDiv=true
          }}

          {{!-- Magic Projection Defensive --}}
          {{> "systems/animabf-guote/templates/actor-v2/components/combat-value.hbs"
              label=(localize "anima.ui.mystic.magicProjection.defensive.title")
              baseName="system.mystic.magicProjection.imbalance.defensive.base.value"
              baseValue=mystic.magicProjection.imbalance.defensive.base.value
              finalValue=mystic.magicProjection.imbalance.defensive.final.value
              rollLabel=(localize "anima.ui.mystic.magicProjection.defensive.title")
              modifierType="general-negative"
              rollableDiv=true
          }}

          {{!-- ACT (editable) --}}
          {{> "systems/animabf-guote/templates/actor-v2/components/combat-value.hbs"
              label=(localize "anima.ui.mystic.act.title")
              baseName="system.mystic.act.main.base.value"
              baseValue=mystic.act.main.base.value
              finalValue=mystic.act.main.final.value
          }}

          {{!-- Alternative ACT (only if set) --}}
          {{#if mystic.act.alternative.base.value}}
          {{> "systems/animabf-guote/templates/actor-v2/components/combat-value.hbs"
              label=(localize "anima.ui.mystic.act.alternative.title")
              baseName="system.mystic.act.alternative.base.value"
              baseValue=mystic.act.alternative.base.value
              finalValue=mystic.act.alternative.final.value
          }}
          {{/if}}

          {{!-- Innate Magic --}}
          <div class="spellbook-innate">
            <span class="spellbook-innate__label">{{localize "anima.ui.mystic.innateMagic.title"}}</span>
            <input type="number" class="spellbook-innate__input"
                   name="system.mystic.innateMagic.main.value"
                   value="{{mystic.innateMagic.main.value}}">
          </div>
        </div>

        {{!-- Active Spells / Maintenances --}}
        <div class="spellbook-maintenances">
          <div class="spellbook-maintenances__header">
            <h4 class="spellbook-maintenances__title">{{localize "anima.ui.mystic.spellMaintenances.title"}}</h4>
            <button type="button" class="spellbook-btn spellbook-btn--action" data-action="add-maintenance">
              <i class="fas fa-plus"></i>
              {{localize "anima.ui.mystic.spellMaintenances.add"}}
            </button>
          </div>
          {{#if spellMaintenances.length}}
          <table class="spell-maintenances-table">
            <thead>
              <tr>
                <th title="{{localize 'anima.ui.mystic.spellMaintenance.active.title'}}">✓</th>
                <th>{{localize 'anima.ui.mystic.spellMaintenance.name.title'}}</th>
                <th>{{localize 'anima.ui.mystic.spellMaintenance.grade.title'}}</th>
                <th title="{{localize 'anima.ui.mystic.spellMaintenance.roundCost.title'}}">{{localize 'anima.ui.mystic.spellMaintenance.roundCost.title'}}</th>
                <th>+</th>
                <th title="{{localize 'anima.ui.mystic.spellMaintenance.cost.title'}}">{{localize 'anima.ui.mystic.spellMaintenance.cost.title'}}</th>
                <th>+</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              {{#each spellMaintenances as |maint|}}
              <tr data-item-id="{{maint._id}}" class="spell-maintenance-row{{#unless maint.system.active.value}} sm-row--inactive{{/unless}}">
                <td class="sm-col--active">
                  <input type="hidden"
                    name="{{concat 'system.dynamic.spellMaintenances.' maint._id '.system.spellId.value'}}"
                    value="{{maint.system.spellId.value}}">
                  <input type="checkbox"
                    name="{{concat 'system.dynamic.spellMaintenances.' maint._id '.system.active.value'}}"
                    {{#if maint.system.active.value}}checked{{/if}}>
                </td>
                <td class="sm-col--name">
                  <input type="text" class="v2-input"
                    name="{{concat 'system.dynamic.spellMaintenances.' maint._id '.name'}}"
                    value="{{maint.name}}">
                </td>
                <td class="sm-col--grade">
                  <select class="v2-select sm-grade-select"
                    name="{{concat 'system.dynamic.spellMaintenances.' maint._id '.system.grade.value'}}"
                    data-spell-id="{{maint.system.spellId.value}}"
                    data-item-id="{{maint._id}}">
                    <option value="" {{#unless maint.system.grade.value}}selected{{/unless}}>—</option>
                    <option value="base" {{#if (is "eq" maint.system.grade.value "base")}}selected{{/if}}>{{localize 'anima.macros.combat.dialog.spellGrade.base.title'}}</option>
                    <option value="intermediate" {{#if (is "eq" maint.system.grade.value "intermediate")}}selected{{/if}}>{{localize 'anima.macros.combat.dialog.spellGrade.intermediate.title'}}</option>
                    <option value="advanced" {{#if (is "eq" maint.system.grade.value "advanced")}}selected{{/if}}>{{localize 'anima.macros.combat.dialog.spellGrade.advanced.title'}}</option>
                    <option value="arcane" {{#if (is "eq" maint.system.grade.value "arcane")}}selected{{/if}}>{{localize 'anima.macros.combat.dialog.spellGrade.arcane.title'}}</option>
                  </select>
                </td>
                <td class="sm-col--cost">
                  <input type="number" class="v2-input v2-input--number"
                    name="{{concat 'system.dynamic.spellMaintenances.' maint._id '.system.roundCost.value'}}"
                    value="{{maint.system.roundCost.value}}">
                </td>
                <td class="sm-col--mod">
                  <input type="number" class="v2-input v2-input--number"
                    name="{{concat 'system.dynamic.spellMaintenances.' maint._id '.system.roundCostMod.value'}}"
                    value="{{maint.system.roundCostMod.value}}">
                </td>
                <td class="sm-col--cost">
                  <input type="number" class="v2-input v2-input--number"
                    name="{{concat 'system.dynamic.spellMaintenances.' maint._id '.system.cost.value'}}"
                    value="{{maint.system.cost.value}}">
                </td>
                <td class="sm-col--mod">
                  <input type="number" class="v2-input v2-input--number"
                    name="{{concat 'system.dynamic.spellMaintenances.' maint._id '.system.dayCostMod.value'}}"
                    value="{{maint.system.dayCostMod.value}}">
                </td>
                <td class="sm-col--delete">
                  <button type="button" class="abf-button icon-button" data-action="delete-maintenance" data-item-id="{{maint._id}}" style="width:auto!important;display:inline-flex">
                    <i class="fas fa-trash"></i>
                  </button>
                </td>
              </tr>
              {{/each}}
            </tbody>
          </table>
          {{/if}}
        </div>

        
        {{!-- Spheres (Nivel de Magia) --}}
        <div class="spellbook-spheres spellbook-spheres--compact">
          <div class="spellbook-spheres__header">
            <h4 class="spellbook-spheres__title">{{localize "anima.ui.mystic.magicLevel.title"}}</h4>
            <div class="spellbook-spheres__totals-inline">
              <span class="spellbook-spheres__total">
                <span class="spellbook-spheres__total-label">{{localize "anima.ui.mystic.magicLevel.total.title"}}</span>
                <input type="number" class="spellbook-spheres__total-input"
                       name="system.mystic.magicLevel.total.value"
                       value="{{mystic.magicLevel.total.value}}">
              </span>
              <span class="spellbook-spheres__total">
                <span class="spellbook-spheres__total-label">{{localize "anima.ui.mystic.magicLevel.used.title"}}</span>
                <input type="number" class="spellbook-spheres__total-input"
                       name="system.mystic.magicLevel.used.value"
                       value="{{mystic.magicLevel.used.value}}">
              </span>
            </div>
            <button type="button" class="spellbook-btn spellbook-btn--action" data-action="import-spells">
              <i class="fas fa-download"></i>
              {{localize "anima.ui.mystic.importSpells.button"}}
            </button>
          </div>
          <div class="spellbook-spheres__grid spellbook-spheres__grid--compact">
            {{#each sphereRows as |row|}}
            <div class="spellbook-sphere spellbook-sphere--editable">
              <span class="spellbook-sphere__label">{{row.label}}</span>
              <input type="number" class="spellbook-sphere__input"
                     name="system.mystic.magicLevel.spheres.{{row.key}}.value"
                     value="{{row.value}}">
              <select class="spellbook-sphere__subpath"
                      name="system.mystic.magicLevel.spheres.{{row.key}}.subpath"
                      title="{{localize 'anima.ui.mystic.spell.via.title'}}">
                {{#each ../subviaOptions as |opt|}}
                <option value="{{opt.value}}" {{#if (eq opt.value ../row.subpath)}}selected{{/if}}>{{opt.label}}</option>
                {{/each}}
              </select>
            </div>
            {{/each}}
          </div>
        </div>
      </form>
    {{else if activeVia}}
      {{#with (lookup spellsByVia activeVia) as |spells|}}
        {{#if spells.length}}
        <div class="spellbook-grid" id="spells-context-menu-container">
          {{#each spells as |spell|}}
          <article class="spell-card spell-row {{#if spell.expanded}}spell-card--expanded{{/if}}" data-spell-id="{{spell.id}}" data-item-id="{{spell.id}}">
            {{!-- Spell Header (always visible) --}}
            <header class="spell-card__header">
              <span class="spell-card__level">{{spell.system.level.value}}</span>
              <h3 class="spell-card__name">{{spell.name}}</h3>
              <div class="spell-card__header-actions">
                <button type="button" class="spell-card__header-btn" data-action="edit-spell" title="{{localize 'anima.contextualMenu.common.options.edit'}}">
                  <i class="fas fa-edit"></i>
                </button>
                <i class="spell-card__toggle fas {{#if spell.expanded}}fa-chevron-up{{else}}fa-chevron-down{{/if}}"></i>
              </div>
            </header>

            {{#if spell.expanded}}
            <div class="spell-card__body">
              {{!-- Spell Meta (Type & Action) --}}
              <div class="spell-card__meta">
                <span class="spell-card__meta-item" title="{{localize 'anima.ui.mystic.spell.spellType.title'}}">
                  <i class="fas fa-magic"></i> {{spell.spellTypeLabel}}
                </span>
                <span class="spell-card__meta-item" title="{{localize 'anima.ui.mystic.spell.actionType.title'}}">
                  <i class="fas fa-bolt"></i> {{spell.actionTypeLabel}}
                </span>
                {{#if spell.system.hasDailyMaintenance.value}}
                <span class="spell-card__meta-item spell-card__meta-item--maint" title="{{localize 'anima.ui.mystic.spell.hasDailyMaintenance.title'}}">
                  <i class="fas fa-clock"></i> {{localize "anima.ui.spellbook.dailyMaint"}}
                </span>
                {{/if}}
              </div>

              {{!-- Grades List --}}
              <div class="spell-card__grades-list">
                {{!-- Base Grade --}}
                {{#with spell.system.grades.base as |grade|}}
                {{#if (or grade.zeon.value grade.description.value)}}
                <div class="spell-grade" data-grade="base" data-spell-id="{{spell.id}}">
                  <div class="spell-grade__header">
                    <span class="spell-grade__name spell-grade__name--base">{{localize "anima.ui.mystic.spell.grade.base.title"}}</span>
                    <div class="spell-grade__stats">
                      <span class="spell-grade__stat" title="{{localize 'anima.ui.mystic.spell.grade.zeon.title'}}">
                        <i class="fas fa-fire-alt"></i> {{grade.zeon.value}}
                      </span>
                      <span class="spell-grade__stat" title="{{localize 'anima.ui.mystic.spell.grade.intRequired.title'}}">
                        <i class="fas fa-brain"></i> {{grade.intRequired.value}}
                      </span>
                      {{#if grade.maintenanceCost.value}}
                      <span class="spell-grade__stat spell-grade__stat--maint" title="{{localize 'anima.ui.mystic.spell.grade.maintenanceCost.title'}}">
                        <i class="fas fa-sync-alt"></i> {{grade.maintenanceCost.value}}
                      </span>
                      {{/if}}
                    </div>
                  </div>
                  {{#if grade.description.value}}
                  <p class="spell-grade__desc">{{grade.description.value}}</p>
                  {{/if}}
                </div>
                {{/if}}
                {{/with}}

                {{!-- Intermediate Grade --}}
                {{#with spell.system.grades.intermediate as |grade|}}
                {{#if (or grade.zeon.value grade.description.value)}}
                <div class="spell-grade" data-grade="intermediate" data-spell-id="{{spell.id}}">
                  <div class="spell-grade__header">
                    <span class="spell-grade__name spell-grade__name--intermediate">{{localize "anima.ui.mystic.spell.grade.intermediate.title"}}</span>
                    <div class="spell-grade__stats">
                      <span class="spell-grade__stat" title="{{localize 'anima.ui.mystic.spell.grade.zeon.title'}}">
                        <i class="fas fa-fire-alt"></i> {{grade.zeon.value}}
                      </span>
                      <span class="spell-grade__stat" title="{{localize 'anima.ui.mystic.spell.grade.intRequired.title'}}">
                        <i class="fas fa-brain"></i> {{grade.intRequired.value}}
                      </span>
                      {{#if grade.maintenanceCost.value}}
                      <span class="spell-grade__stat spell-grade__stat--maint" title="{{localize 'anima.ui.mystic.spell.grade.maintenanceCost.title'}}">
                        <i class="fas fa-sync-alt"></i> {{grade.maintenanceCost.value}}
                      </span>
                      {{/if}}
                    </div>
                  </div>
                  {{#if grade.description.value}}
                  <p class="spell-grade__desc">{{grade.description.value}}</p>
                  {{/if}}
                </div>
                {{/if}}
                {{/with}}

                {{!-- Advanced Grade --}}
                {{#with spell.system.grades.advanced as |grade|}}
                {{#if (or grade.zeon.value grade.description.value)}}
                <div class="spell-grade" data-grade="advanced" data-spell-id="{{spell.id}}">
                  <div class="spell-grade__header">
                    <span class="spell-grade__name spell-grade__name--advanced">{{localize "anima.ui.mystic.spell.grade.advanced.title"}}</span>
                    <div class="spell-grade__stats">
                      <span class="spell-grade__stat" title="{{localize 'anima.ui.mystic.spell.grade.zeon.title'}}">
                        <i class="fas fa-fire-alt"></i> {{grade.zeon.value}}
                      </span>
                      <span class="spell-grade__stat" title="{{localize 'anima.ui.mystic.spell.grade.intRequired.title'}}">
                        <i class="fas fa-brain"></i> {{grade.intRequired.value}}
                      </span>
                      {{#if grade.maintenanceCost.value}}
                      <span class="spell-grade__stat spell-grade__stat--maint" title="{{localize 'anima.ui.mystic.spell.grade.maintenanceCost.title'}}">
                        <i class="fas fa-sync-alt"></i> {{grade.maintenanceCost.value}}
                      </span>
                      {{/if}}
                    </div>
                  </div>
                  {{#if grade.description.value}}
                  <p class="spell-grade__desc">{{grade.description.value}}</p>
                  {{/if}}
                </div>
                {{/if}}
                {{/with}}

                {{!-- Arcane Grade --}}
                {{#with spell.system.grades.arcane as |grade|}}
                {{#if (or grade.zeon.value grade.description.value)}}
                <div class="spell-grade" data-grade="arcane" data-spell-id="{{spell.id}}">
                  <div class="spell-grade__header">
                    <span class="spell-grade__name spell-grade__name--arcane">{{localize "anima.ui.mystic.spell.grade.arcane.title"}}</span>
                    <div class="spell-grade__stats">
                      <span class="spell-grade__stat" title="{{localize 'anima.ui.mystic.spell.grade.zeon.title'}}">
                        <i class="fas fa-fire-alt"></i> {{grade.zeon.value}}
                      </span>
                      <span class="spell-grade__stat" title="{{localize 'anima.ui.mystic.spell.grade.intRequired.title'}}">
                        <i class="fas fa-brain"></i> {{grade.intRequired.value}}
                      </span>
                      {{#if grade.maintenanceCost.value}}
                      <span class="spell-grade__stat spell-grade__stat--maint" title="{{localize 'anima.ui.mystic.spell.grade.maintenanceCost.title'}}">
                        <i class="fas fa-sync-alt"></i> {{grade.maintenanceCost.value}}
                      </span>
                      {{/if}}
                    </div>
                  </div>
                  {{#if grade.description.value}}
                  <p class="spell-grade__desc">{{grade.description.value}}</p>
                  {{/if}}
                </div>
                {{/if}}
                {{/with}}
              </div>

            </div>
            {{/if}}
          </article>
          {{/each}}
        </div>
        {{else}}
        <div class="spellbook-empty">
          <i class="fas fa-book-open"></i>
          <p>{{localize "anima.ui.spellbook.noSpellsInVia"}}</p>
        </div>
        {{/if}}
      {{/with}}
    {{else}}
    <div class="spellbook-empty">
      <i class="fas fa-book-open"></i>
      <p>{{localize "anima.ui.spellbook.noSpells"}}</p>
    </div>
    {{/if}}
  </main>
  </div>
</div>
