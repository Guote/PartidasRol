{{!-- Psychic Tab V2 --}}
<div class="v2-tab-psychic">

  {{!-- Psychic Core Values --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <span>{{localize "anima.ui.psychic.title"}}</span>
    </div>
    <div class="v2-card__body">
      <div class="v2-btfl-group">
        {{> "systems/animabf-guote/templates/actor-v2/components/base-to-final-input-large.hbs"
            label=(localize "anima.ui.psychic.psychicProjection.offensive.title")
            baseName="system.psychic.psychicProjection.imbalance.offensive.base.value"
            baseValue=system.psychic.psychicProjection.imbalance.offensive.base.value
            finalValue=system.psychic.psychicProjection.imbalance.offensive.final.value
            rollable=true
            rollLabel=(localize "anima.ui.psychic.psychicProjection.offensive.rollMessage")
            modifierType="general-negative"
            rollableDiv=true
            temporalName="system.psychic.psychicProjection.imbalance.offensive.temporal.value"
            temporalValue=system.psychic.psychicProjection.imbalance.offensive.temporal.value}}

        {{> "systems/animabf-guote/templates/actor-v2/components/base-to-final-input-large.hbs"
            label=(localize "anima.ui.psychic.psychicProjection.defensive.title")
            baseName="system.psychic.psychicProjection.imbalance.defensive.base.value"
            baseValue=system.psychic.psychicProjection.imbalance.defensive.base.value
            finalValue=system.psychic.psychicProjection.imbalance.defensive.final.value
            rollable=true
            rollLabel=(localize "anima.ui.psychic.psychicProjection.defensive.rollMessage")
            modifierType="general-negative"
            rollableDiv=true
            temporalName="system.psychic.psychicProjection.imbalance.defensive.temporal.value"
            temporalValue=system.psychic.psychicProjection.imbalance.defensive.temporal.value}}

        {{> "systems/animabf-guote/templates/actor-v2/components/base-to-final-input-large.hbs"
            label=(localize "anima.ui.psychic.psychicPotential.title")
            baseName="system.psychic.psychicPotential.base.value"
            baseValue=system.psychic.psychicPotential.base.value
            finalValue=system.psychic.psychicPotential.final.value
            rollable=true
            rollLabel=(localize "anima.ui.psychic.psychicPotential.title")
            modifierType="general-negative-half"
            rollableDiv=true
            temporalName="system.psychic.psychicPotential.temporal.value"
            temporalValue=system.psychic.psychicPotential.temporal.value}}

        {{!-- Psychic Points --}}
        <div class="v2-btfl">
          <div class="v2-btfl__header">
            <span class="v2-btfl__label">{{localize "anima.ui.psychic.psychicPoints.title"}}</span>
          </div>
          <div class="v2-btfl__body">
            <div class="v2-btfl__inputs-container">
              <div class="v2-btfl__field">
                <input type="number" class="v2-btfl__input v2-btfl__input--base"
                       name="system.psychic.psychicPoints.value"
                       value="{{system.psychic.psychicPoints.value}}">
              </div>
              <span class="v2-text-muted" style="font-size:0.85rem;">/</span>
              <div class="v2-btfl__field">
                <input type="number" class="v2-btfl__input v2-btfl__input--base"
                       name="system.psychic.psychicPoints.max"
                       value="{{system.psychic.psychicPoints.max}}">
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  {{!-- Psychic Powers --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <div class="v2-card__header-title">
        <span>{{localize "anima.ui.psychic.psychicPowers.title"}}</span>
      </div>
      <div class="v2-card__header-actions" style="display:flex;align-items:center;gap:4px;">
        <span class="v2-text-muted" style="font-size:0.7rem;white-space:nowrap;">
          {{localize "anima.ui.psychic.innatePsychicPower.amount.title"}}:
        </span>
        <input type="number" style="width:36px;text-align:center;background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.4);border-radius:3px;color:white;padding:1px 3px;font-size:0.75rem;"
               name="system.psychic.innatePsychicPower.amount.value"
               value="{{system.psychic.innatePsychicPower.amount.value}}">
        <button type="button" class="v2-card__header-btn" data-on-click="add-psychic-power"
                title="{{localize 'anima.dialogs.items.psychicPower.content'}}">
          <i class="fas fa-plus"></i>
        </button>
      </div>
    </div>
    <div class="v2-card__body" style="padding: 0;">
      <table class="v2-table v2-table--compact" id="psychic-powers-context-menu-container">
        <thead>
          <tr>
            <th class="inventory-sort-th v2-sort-th" style="width: 80px;" data-sort-table="psychicPowers" data-sort-field="discipline">
              {{localize "anima.ui.psychic.psychicPowers.power.header.discipline.title"}}
              {{#if inventorySortHeaders.psychicPowers.discipline.active}}
                <i class="fas fa-sort-{{inventorySortHeaders.psychicPowers.discipline.dir}} v2-sort-icon--active"></i>
              {{else}}
                <i class="fas fa-sort v2-sort-icon--inactive"></i>
              {{/if}}
            </th>
            <th class="inventory-sort-th v2-sort-th v2-text-center" style="width: 32px;" data-sort-table="psychicPowers" data-sort-field="level">
              {{localize "anima.ui.psychic.psychicPowers.power.header.level.title"}}
              {{#if inventorySortHeaders.psychicPowers.level.active}}
                <i class="fas fa-sort-{{inventorySortHeaders.psychicPowers.level.dir}} v2-sort-icon--active"></i>
              {{else}}
                <i class="fas fa-sort v2-sort-icon--inactive"></i>
              {{/if}}
            </th>
            <th class="inventory-sort-th v2-sort-th" data-sort-table="psychicPowers" data-sort-field="name">
              {{localize "anima.ui.psychic.psychicPowers.power.header.name.title"}}
              {{#if inventorySortHeaders.psychicPowers.name.active}}
                <i class="fas fa-sort-{{inventorySortHeaders.psychicPowers.name.dir}} v2-sort-icon--active"></i>
              {{else}}
                <i class="fas fa-sort v2-sort-icon--inactive"></i>
              {{/if}}
            </th>
            <th class="inventory-sort-th v2-sort-th v2-text-center" style="width: 42px;" data-sort-table="psychicPowers" data-sort-field="bonus">
              {{localize "anima.ui.psychic.psychicPowers.power.footer.bonus.title"}}
              {{#if inventorySortHeaders.psychicPowers.bonus.active}}
                <i class="fas fa-sort-{{inventorySortHeaders.psychicPowers.bonus.dir}} v2-sort-icon--active"></i>
              {{else}}
                <i class="fas fa-sort v2-sort-icon--inactive"></i>
              {{/if}}
            </th>
            <th class="v2-text-center" style="width: 42px;" title="{{localize 'anima.ui.psychic.psychicPowers.power.footer.hasMaintenance.title'}}">
              {{localize "anima.ui.psychic.psychicPowers.power.footer.maintained.short"}}
            </th>
            <th class="v2-text-center" style="width: 48px;">CV Mant</th>
            <th style="width: 52px;"></th>
          </tr>
        </thead>
        <tbody>
          {{#each system.psychic.psychicPowers as |power|}}
          <tr class="psychic-power-row" data-item-id="{{power._id}}">
            <td>
              <input type="text" class="v2-table__input"
                     name="system.dynamic.psychicPowers.{{power._id}}.system.discipline.value"
                     value="{{power.system.discipline.value}}"
                     style="width:100%;">
            </td>
            <td class="v2-text-center v2-text-muted" style="font-size:0.8rem;">
              {{power.system.level.value}}
            </td>
            <td>
              <span class="v2-table__link item-link" title="{{power.name}}">{{power.name}}</span>
            </td>
            <td class="v2-text-center">
              <input type="number" class="v2-table__input" style="width:38px;text-align:center;"
                     name="system.dynamic.psychicPowers.{{power._id}}.system.bonus.value"
                     value="{{power.system.bonus.value}}">
            </td>
            <td class="v2-text-center">
              <input type="checkbox"
                     name="system.dynamic.psychicPowers.{{power._id}}.system.isMaintained.value"
                     {{checked power.system.isMaintained.value}}
                     {{#unless power.system.hasMaintenance.value}}disabled{{/unless}}>
            </td>
            <td class="v2-text-center">
              <input type="number" class="v2-table__input" style="width:42px;text-align:center;"
                     name="system.dynamic.psychicPowers.{{power._id}}.system.maintainedCV.value"
                     value="{{power.system.maintainedCV.value}}">
            </td>
            <td class="v2-text-center" style="white-space:nowrap;">
              <button type="button" class="v2-btn-icon-sm"
                      data-on-click="use-psychic-power"
                      data-item-id="{{power._id}}"
                      style="width:auto!important;display:inline-flex;"
                      title="Usar poder psíquico">
                <i class="fas fa-bolt"></i>
              </button>
              <button type="button" class="v2-btn-icon-sm psychic-power-open-sheet"
                      data-item-id="{{power._id}}"
                      title="{{localize 'anima.ui.psychic.psychicPowers.power.openSheet'}}">
                <i class="fas fa-eye"></i>
              </button>
            </td>
          </tr>
          {{else}}
          <tr>
            <td colspan="7" class="v2-text-center v2-text-muted">-</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>

  {{!-- Psychic Disciplines --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <div class="v2-card__header-title">
        <span>{{localize "anima.ui.psychic.psychicDiscipline.title"}}</span>
      </div>
      <div class="v2-card__header-actions">
        <button type="button" class="v2-card__header-btn" data-on-click="add-psychic-discipline"
                title="{{localize 'anima.dialogs.items.psychicDiscipline.content'}}">
          <i class="fas fa-plus"></i>
        </button>
      </div>
    </div>
    <div class="v2-card__body" style="padding: 0;">
      <table class="v2-table v2-table--compact" id="psychic-disciplines-context-menu-container">
        <tbody>
          {{#each system.psychic.psychicDisciplines as |discipline|}}
          <tr class="psychic-discipline-row" data-item-id="{{discipline._id}}">
            <td>
              <input type="text" class="v2-table__input" style="width:100%;"
                     name="system.dynamic.psychicDisciplines.{{discipline._id}}.name"
                     value="{{discipline.name}}">
            </td>
          </tr>
          {{else}}
          <tr>
            <td class="v2-text-center v2-text-muted">-</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>

</div>{{!-- end v2-tab-psychic --}}
