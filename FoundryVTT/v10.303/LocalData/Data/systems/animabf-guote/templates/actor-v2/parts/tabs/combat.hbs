{{!-- Combat Tab --}}
<div class="v2-tab-combat">
  {{!-- Base Combat Values --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <span>{{localize "anima.ui.combat.baseValues.title"}}</span>
    </div>
    <div class="v2-card__body">
      <div class="v2-combat-values">
        {{> "systems/animabf-guote/templates/actor-v2/components/combat-value.hbs"
            label=(localize "anima.ui.combat.baseValues.attack.title")
            baseName="system.combat.attack.base.value"
            baseValue=system.combat.attack.base.value
            finalValue=system.combat.attack.final.value
            rollLabel=(localize "anima.ui.combat.baseValues.attack.title")
            modifierType="attack"
            rollableDiv=true}}

        {{> "systems/animabf-guote/templates/actor-v2/components/combat-value.hbs"
            label=(localize "anima.ui.combat.baseValues.block.title")
            baseName="system.combat.block.base.value"
            baseValue=system.combat.block.base.value
            finalValue=system.combat.block.final.value
            rollLabel=(localize "anima.ui.combat.baseValues.block.title")
            modifierType="defense"
            rollableDiv=true}}

        {{> "systems/animabf-guote/templates/actor-v2/components/combat-value.hbs"
            label=(localize "anima.ui.combat.baseValues.dodge.title")
            baseName="system.combat.dodge.base.value"
            baseValue=system.combat.dodge.base.value
            finalValue=system.combat.dodge.final.value
            rollLabel=(localize "anima.ui.combat.baseValues.dodge.title")
            modifierType="defense"
            rollableDiv=true}}

        {{> "systems/animabf-guote/templates/actor-v2/components/combat-value.hbs"
            label=(localize "anima.ui.combat.baseValues.wearArmor.title")
            baseName="system.combat.wearArmor.value"
            baseValue=system.combat.wearArmor.value
            baseOnly=true}}

        {{> "systems/animabf-guote/templates/actor-v2/components/combat-value.hbs"
            label=(localize "anima.ui.combat.weapons.initiative.final.title")
            baseName="system.characteristics.secondaries.initiative.base.value"
            baseValue=system.characteristics.secondaries.initiative.base.value
            finalValue=system.characteristics.secondaries.initiative.final.value
            rollFormula="1d100xaturn"
            rollLabel=(localize "anima.ui.combat.weapons.initiative.final.title")
            modifierType="initiative"
            rollableDiv=true}}
      </div>
    </div>
  </div>

  {{!-- Turno Actual --}}
  <div class="v2-card" data-action="open-tab" data-tab="inventory" style="cursor: pointer;"
       title="Click para cambiar armas del turno">
    <div class="v2-card__header">
      <span>Turno actual</span>
      <i class="fas fa-chevron-right" style="opacity:0.5;font-size:0.75rem;margin-left:auto;"></i>
    </div>
    <div class="v2-card__body" style="padding: 6px 12px; display: flex; flex-wrap: wrap; gap: 4px; min-height: 28px; align-items: center;">
      {{#each selectedWeaponsDisplay}}
      <span style="display:inline-flex;align-items:center;gap:4px;
                   background: {{#if this.isSlowest}}rgba(255,180,0,0.15){{else}}rgba(255,255,255,0.1){{/if}};
                   border: 1px solid {{#if this.isSlowest}}rgba(255,180,0,0.5){{else}}rgba(255,255,255,0.25){{/if}};
                   border-radius: 3px; padding: 2px 8px; font-size: 0.85rem;">
        {{#if this.isSlowest}}<i class="fas fa-hourglass-half" style="font-size:0.7rem;color:rgba(255,180,0,0.9);"></i>{{/if}}
        {{this.name}}
        <span style="font-size:0.7rem;opacity:0.6;">({{this.initValue}})</span>
      </span>
      {{else}}
      <span class="v2-text-muted" style="font-size:0.85rem;">Desarmado</span>
      {{/each}}
    </div>
  </div>

  {{!-- Attack Presets --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <div class="v2-card__header-title">
        <span>{{localize "anima.ui.combat.attackPresets.title"}}</span>
      </div>
      <div class="v2-card__header-actions">
        <button type="button" class="v2-card__header-btn open-attack-dialog" draggable="true"
                title="{{localize 'anima.macros.combat.dialog.attackButton.title'}}"
                data-actor-id="{{actor._id}}">
          <i class="fas fa-crosshairs"></i> {{localize "anima.macros.combat.dialog.attack.title"}}
        </button>
      </div>
    </div>
    <div class="v2-card__body" id="attack-presets-context-menu-container" style="padding: 0;">
      <div class="v2-preset-grid">
        {{#each system.combat.attackPresets as |preset|}}
        <div class="v2-preset-item preset-row-clickable attack-preset-row" draggable="true"
             data-item-id="{{preset._id}}" data-preset-id="{{preset._id}}" data-preset-type="attack">
          <span class="preset-name-cell">{{preset.name}}</span>
          <button type="button" class="v2-btn-icon-sm preset-quick-attack"
                  data-preset-id="{{preset._id}}"
                  title="{{localize 'anima.ui.combat.quickAttack'}}">
            <i class="fas fa-bolt"></i>
          </button>
        </div>
        {{else}}
        <div class="v2-preset-empty">-</div>
        {{/each}}
      </div>
    </div>
  </div>

  {{!-- Defense Presets --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <div class="v2-card__header-title">
        <span>{{localize "anima.ui.combat.defensePresets.title"}}</span>
      </div>
    </div>
    <div class="v2-card__body" id="defense-presets-context-menu-container" style="padding: 0;">
      <div class="v2-preset-grid">
        {{#each system.combat.defensePresets as |preset|}}
        <div class="v2-preset-item preset-row-clickable defense-preset-row" draggable="true"
             data-item-id="{{preset._id}}" data-preset-id="{{preset._id}}" data-preset-type="defense">
          <span class="preset-name-cell">{{preset.name}}</span>
        </div>
        {{else}}
        <div class="v2-preset-empty">-</div>
        {{/each}}
      </div>
    </div>
  </div>

  {{!-- Combat Notes --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <span>{{localize "anima.ui.notesSection.title"}}</span>
    </div>
    <div class="v2-card__body v2-notes-editor">
      {{editor system.combat.notes.enriched target="system.combat.notes.value" button=true owner=true editable=true}}
    </div>
  </div>
</div>
