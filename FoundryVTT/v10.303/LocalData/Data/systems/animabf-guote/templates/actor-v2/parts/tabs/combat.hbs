{{!-- Combat Tab --}}
<div class="v2-tab-combat">
  {{!-- Base Combat Values --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <span>{{localize "anima.ui.combat.baseValues.title"}}</span>
    </div>
    <div class="v2-card__body">
      <div class="v2-combat-values">
        {{!-- Attack --}}
        <div class="v2-combat-value">
          <span class="v2-combat-value__label">{{localize "anima.ui.combat.baseValues.attack.title"}}</span>
          <div class="v2-combat-value__inputs">
            <input type="number" class="v2-combat-value__input"
                   name="system.combat.attack.base.value"
                   value="{{system.combat.attack.base.value}}">
            <span class="v2-combat-value__final rollable"
                  data-roll="1d100xa"
                  data-rollvalue="{{system.combat.attack.final.value}}"
                  data-label="{{localize 'anima.ui.combat.baseValues.attack.title'}}">
              {{system.combat.attack.final.value}}
            </span>
          </div>
        </div>

        {{!-- Block --}}
        <div class="v2-combat-value">
          <span class="v2-combat-value__label">{{localize "anima.ui.combat.baseValues.block.title"}}</span>
          <div class="v2-combat-value__inputs">
            <input type="number" class="v2-combat-value__input"
                   name="system.combat.block.base.value"
                   value="{{system.combat.block.base.value}}">
            <span class="v2-combat-value__final rollable"
                  data-roll="1d100xa"
                  data-rollvalue="{{system.combat.block.final.value}}"
                  data-label="{{localize 'anima.ui.combat.baseValues.block.title'}}">
              {{system.combat.block.final.value}}
            </span>
          </div>
        </div>

        {{!-- Dodge --}}
        <div class="v2-combat-value">
          <span class="v2-combat-value__label">{{localize "anima.ui.combat.baseValues.dodge.title"}}</span>
          <div class="v2-combat-value__inputs">
            <input type="number" class="v2-combat-value__input"
                   name="system.combat.dodge.base.value"
                   value="{{system.combat.dodge.base.value}}">
            <span class="v2-combat-value__final rollable"
                  data-roll="1d100xa"
                  data-rollvalue="{{system.combat.dodge.final.value}}"
                  data-label="{{localize 'anima.ui.combat.baseValues.dodge.title'}}">
              {{system.combat.dodge.final.value}}
            </span>
          </div>
        </div>

        {{!-- Wear Armor --}}
        <div class="v2-combat-value">
          <span class="v2-combat-value__label">{{localize "anima.ui.combat.baseValues.wearArmor.title"}}</span>
          <div class="v2-combat-value__inputs">
            <input type="number" class="v2-combat-value__input"
                   name="system.combat.wearArmor.value"
                   value="{{system.combat.wearArmor.value}}">
          </div>
        </div>
      </div>
    </div>
  </div>

  {{!-- Weapons --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <div class="v2-card__header-title">
        <span>{{localize "anima.ui.combat.weapons.title"}}</span>
      </div>
      <div class="v2-card__header-actions">
        <button type="button" class="v2-card__header-btn" data-on-click="add-weapon" title="{{localize 'anima.dialogs.items.weapons.content'}}">
          <i class="fas fa-plus"></i>
        </button>
      </div>
    </div>
    <div class="v2-card__body" style="padding: 0;">
      <table class="v2-table">
        <thead>
          <tr>
            <th>{{localize "anima.ui.combat.ammo.name.title"}}</th>
            <th style="width: 60px;">{{localize "anima.ui.combat.baseValues.attack.title"}}</th>
            <th style="width: 60px;">{{localize "anima.ui.combat.baseValues.block.title"}}</th>
            <th style="width: 60px;">{{localize "anima.ui.combat.weapons.damage.final.title"}}</th>
            <th style="width: 50px;">{{localize "anima.ui.general.initiative.base.title"}}</th>
            <th style="width: 80px;">{{localize "anima.ui.combat.weapons.critic.primary.title"}}</th>
          </tr>
        </thead>
        <tbody>
          {{#each system.combat.weapons as |weapon|}}
          <tr class="weapon-row v2-table__row--draggable" data-item-id="{{weapon._id}}">
            <td>
              <span class="rollable"
                    data-roll="1d100xa"
                    data-rollvalue="{{weapon.system.attack.final.value}}"
                    data-label="{{weapon.name}}">
                {{weapon.name}}
              </span>
            </td>
            <td class="v2-text-center">{{weapon.system.attack.final.value}}</td>
            <td class="v2-text-center">{{weapon.system.block.final.value}}</td>
            <td class="v2-text-center">{{weapon.system.damage.final.value}}</td>
            <td class="v2-text-center">{{weapon.system.initiative.final.value}}</td>
            <td class="v2-text-center">{{weapon.system.critic.primary.value}}</td>
          </tr>
          {{else}}
          <tr>
            <td colspan="6" class="v2-text-center v2-text-muted">-</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>

  {{!-- Armors --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <div class="v2-card__header-title">
        <span>{{localize "anima.ui.combat.armors.title"}}</span>
      </div>
      <div class="v2-card__header-actions">
        <button type="button" class="v2-card__header-btn" data-on-click="add-armor" title="{{localize 'anima.dialogs.items.armors.content'}}"
          <i class="fas fa-plus"></i>
        </button>
      </div>
    </div>
    <div class="v2-card__body" style="padding: 0;">
      <table class="v2-table">
        <thead>
          <tr>
            <th>{{localize "anima.ui.combat.armors.name.title"}}</th>
            <th style="width: 40px;">{{localize "anima.ui.combat.armors.at.cut.title"}}</th>
            <th style="width: 40px;">{{localize "anima.ui.combat.armors.at.impact.title"}}</th>
            <th style="width: 40px;">{{localize "anima.ui.combat.armors.at.thrust.title"}}</th>
            <th style="width: 40px;">{{localize "anima.ui.combat.armors.at.heat.title"}}</th>
            <th style="width: 40px;">{{localize "anima.ui.combat.armors.at.electricity.title"}}</th>
            <th style="width: 40px;">{{localize "anima.ui.combat.armors.at.cold.title"}}</th>
            <th style="width: 40px;">{{localize "anima.ui.combat.armors.at.energy.title"}}</th>
          </tr>
        </thead>
        <tbody>
          {{#each system.combat.armors as |armor|}}
          <tr class="armor-row v2-table__row--draggable" data-item-id="{{armor._id}}">
            <td>{{armor.name}}</td>
            <td class="v2-text-center">{{armor.system.cut.final.value}}</td>
            <td class="v2-text-center">{{armor.system.impact.final.value}}</td>
            <td class="v2-text-center">{{armor.system.thrust.final.value}}</td>
            <td class="v2-text-center">{{armor.system.heat.final.value}}</td>
            <td class="v2-text-center">{{armor.system.electricity.final.value}}</td>
            <td class="v2-text-center">{{armor.system.cold.final.value}}</td>
            <td class="v2-text-center">{{armor.system.energy.final.value}}</td>
          </tr>
          {{else}}
          <tr>
            <td colspan="8" class="v2-text-center v2-text-muted">-</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>

  {{!-- Total Armor Summary --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <span>{{localize "anima.ui.combat.finalArmor.title"}}</span>
    </div>
    <div class="v2-card__body">
      <div class="v2-grid v2-grid--auto">
        <div class="v2-stat-block">
          <span class="v2-stat-block__label">{{localize "anima.ui.combat.armors.at.cut.title"}}</span>
          <span class="v2-stat-block__value">{{system.combat.totalArmor.at.cut.value}}</span>
        </div>
        <div class="v2-stat-block">
          <span class="v2-stat-block__label">{{localize "anima.ui.combat.armors.at.impact.title"}}</span>
          <span class="v2-stat-block__value">{{system.combat.totalArmor.at.impact.value}}</span>
        </div>
        <div class="v2-stat-block">
          <span class="v2-stat-block__label">{{localize "anima.ui.combat.armors.at.thrust.title"}}</span>
          <span class="v2-stat-block__value">{{system.combat.totalArmor.at.thrust.value}}</span>
        </div>
        <div class="v2-stat-block">
          <span class="v2-stat-block__label">{{localize "anima.ui.combat.armors.at.heat.title"}}</span>
          <span class="v2-stat-block__value">{{system.combat.totalArmor.at.heat.value}}</span>
        </div>
        <div class="v2-stat-block">
          <span class="v2-stat-block__label">{{localize "anima.ui.combat.armors.at.electricity.title"}}</span>
          <span class="v2-stat-block__value">{{system.combat.totalArmor.at.electricity.value}}</span>
        </div>
        <div class="v2-stat-block">
          <span class="v2-stat-block__label">{{localize "anima.ui.combat.armors.at.cold.title"}}</span>
          <span class="v2-stat-block__value">{{system.combat.totalArmor.at.cold.value}}</span>
        </div>
        <div class="v2-stat-block">
          <span class="v2-stat-block__label">{{localize "anima.ui.combat.armors.at.energy.title"}}</span>
          <span class="v2-stat-block__value">{{system.combat.totalArmor.at.energy.value}}</span>
        </div>
      </div>
    </div>
  </div>

  <div class="v2-grid v2-grid--2">
    {{!-- Combat Special Skills --}}
    <div class="v2-card">
      <div class="v2-card__header">
        <div class="v2-card__header-title">
          <span>{{localize "anima.ui.combat.combatSpecialSkill.title"}}</span>
        </div>
        <div class="v2-card__header-actions">
          <button type="button" class="v2-card__header-btn" data-on-click="add-combat-special-skill" title="{{localize 'anima.dialogs.items.combatSpecialSkills.content'}}"
            <i class="fas fa-plus"></i>
          </button>
        </div>
      </div>
      <div class="v2-card__body" style="padding: 0;">
        <table class="v2-table">
          <tbody>
            {{#each system.combat.combatSpecialSkills as |skill|}}
            <tr data-item-id="{{skill._id}}">
              <td>{{skill.name}}</td>
            </tr>
            {{else}}
            <tr>
              <td class="v2-text-center v2-text-muted">-</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>

    {{!-- Combat Tables --}}
    <div class="v2-card">
      <div class="v2-card__header">
        <div class="v2-card__header-title">
          <span>{{localize "anima.ui.combat.combatTables.title"}}</span>
        </div>
        <div class="v2-card__header-actions">
          <button type="button" class="v2-card__header-btn" data-on-click="add-combat-table" title="{{localize 'anima.dialogs.items.combatTable.content'}}"
            <i class="fas fa-plus"></i>
          </button>
        </div>
      </div>
      <div class="v2-card__body" style="padding: 0;">
        <table class="v2-table">
          <tbody>
            {{#each system.combat.combatTables as |table|}}
            <tr data-item-id="{{table._id}}">
              <td>{{table.name}}</td>
            </tr>
            {{else}}
            <tr>
              <td class="v2-text-center v2-text-muted">-</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  {{!-- Combat Notes --}}
  <div class="v2-card">
    <div class="v2-card__header">
      <span>{{localize "anima.ui.notesSection.title"}}</span>
    </div>
    <div class="v2-card__body">
      <textarea class="v2-textarea"
                name="system.combat.notes.value"
                placeholder="">{{system.combat.notes.value}}</textarea>
    </div>
  </div>
</div>
