<form class="summon-sheet flexcol" autocomplete="off">
  <style>
    .summon-sheet {
      font-size: 12px;
      padding: 6px;
      background: #f4f1ea;
      color: #333;
    }
    .summon-sheet .ss-header {
      display: flex;
      align-items: center;
      gap: 6px;
      margin-bottom: 6px;
      padding-bottom: 4px;
      border-bottom: 2px solid #8b4513;
    }
    .summon-sheet .ss-header img {
      width: 32px;
      height: 32px;
      border: 1px solid #8b4513;
      border-radius: 3px;
      cursor: pointer;
    }
    .summon-sheet .ss-header input {
      flex: 1;
      font-size: 14px;
      font-weight: bold;
      border: none;
      border-bottom: 1px solid #ccc;
      background: transparent;
      padding: 1px 4px;
    }
    .summon-sheet .ss-header input:focus {
      border-bottom-color: #8b4513;
      outline: none;
    }
    .summon-sheet .ss-row {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
      align-items: center;
      margin: 3px 0;
    }
    .summon-sheet .ss-label {
      font-size: 10px;
      font-weight: bold;
      color: #666;
      text-transform: uppercase;
    }
    .summon-sheet .ss-sep {
      width: 100%;
      height: 1px;
      background: #d4c9a8;
      margin: 4px 0;
    }
    .summon-sheet .ss-sep-title {
      font-size: 10px;
      font-weight: bold;
      text-transform: uppercase;
      color: #8b4513;
      margin: 6px 0 2px;
    }
    .summon-sheet .ss-field {
      display: flex;
      align-items: center;
      gap: 3px;
    }
    .summon-sheet .ss-field b {
      font-size: 10px;
      color: #666;
      min-width: 24px;
    }
    .summon-sheet input[type="number"] {
      width: 42px;
      text-align: center;
      border: 1px solid #d4c9a8;
      border-radius: 3px;
      padding: 1px 2px;
      font-size: 12px;
    }
    .summon-sheet input[type="text"] {
      flex: 1;
      border: 1px solid #d4c9a8;
      border-radius: 3px;
      padding: 1px 4px;
      font-size: 11px;
    }
    .summon-sheet select {
      border: 1px solid #d4c9a8;
      border-radius: 3px;
      padding: 1px 4px;
      font-size: 11px;
    }
    .summon-sheet textarea {
      width: 100%;
      min-height: 40px;
      resize: vertical;
      border: 1px solid #d4c9a8;
      border-radius: 3px;
      padding: 3px 4px;
      font-size: 11px;
      font-family: inherit;
    }
    .summon-sheet input:focus, .summon-sheet select:focus, .summon-sheet textarea:focus {
      border-color: #8b4513;
      outline: none;
    }
  </style>

  <div class="ss-header">
    <img src="{{item.img}}" data-edit="img" title="{{item.name}}">
    <input type="text" name="name" value="{{item.name}}">
  </div>

  {{!-- Summoning --}}
  <div class="ss-row">
    <div class="ss-field"><b>Dif</b><input type="number" name="system.summonDif.value" value="{{system.summonDif.value}}"></div>
    <div class="ss-field"><b>Zeon</b><input type="number" name="system.zeonCost.value" value="{{system.zeonCost.value}}"></div>
    <div class="ss-field"><b>Turno</b><input type="number" name="system.turno.value" value="{{system.turno.value}}"></div>
  </div>

  <div class="ss-sep"></div>

  {{!-- Combat --}}
  <div class="ss-sep-title">{{localize "anima.ui.tabs.combat"}}</div>
  <div class="ss-row">
    <div class="ss-field"><b>Atq</b><input type="number" name="system.baseAtk.value" value="{{system.baseAtk.value}}"></div>
    <div class="ss-field"><b>+</b><input type="number" name="system.bonusAtk.value" value="{{system.bonusAtk.value}}"></div>
    <div class="ss-field"><b>Def</b><input type="number" name="system.baseDef.value" value="{{system.baseDef.value}}"></div>
    <div class="ss-field"><b>+</b><input type="number" name="system.bonusDef.value" value="{{system.bonusDef.value}}"></div>
  </div>
  <div class="ss-row">
    <div class="ss-field"><b>Daño</b><input type="number" name="system.damage.value" value="{{system.damage.value}}"></div>
    <div class="ss-field"><b>+</b><input type="number" name="system.bonusDamage.value" value="{{system.bonusDamage.value}}"></div>
    <div class="ss-field"><b>Crit</b>
      <select name="system.critic.value">
        {{#each config.iterables.combat.weapon.criticTypes as |label key|}}
        <option value="{{key}}" {{#if (is 'eq' key ../system.critic.value)}}selected{{/if}}>{{localize label}}</option>
        {{/each}}
      </select>
    </div>
  </div>

  <div class="ss-sep"></div>

  {{!-- Special --}}
  <div class="ss-sep-title">{{localize "anima.ui.mystic.summon.special.title"}}</div>
  <textarea name="system.special.value" placeholder="{{localize 'anima.ui.mystic.summon.special.title'}}">{{system.special.value}}</textarea>

  <div class="ss-row" style="margin-top: 4px;">
    <div class="ss-field" style="flex: 1;">
      <b style="min-width: 36px;">Otros</b>
      <input type="text" name="system.bonusOther.value" value="{{system.bonusOther.value}}">
    </div>
  </div>
</form>
