<form class="weapon-sheet flexcol" autocomplete="off">
  <style>
    /* ── Tokens / palette ── */
    .weapon-sheet {
      --ws-red:       #6e2917;
      --ws-red-dark:  #4a1b10;
      --ws-red-mid:   #8b3a24;
      --ws-bg:        #f5f3eb;
      --ws-bg-alt:    #ede9db;
      --ws-border:    #d4c9a8;
      --ws-text:      #333;
      --ws-muted:     #777;
      --ws-white:     #fff;

      font-size: 12px;
      background: var(--ws-bg);
      color: var(--ws-text);
      padding: 0;
      gap: 0;
    }

    /* ── Counter .flexcol > * { flex: 1 } ── */
    .weapon-sheet .ws-name-bar,
    .weapon-sheet .ws-description-accordion,
    .weapon-sheet .ws-section {
      flex: 0 0 auto !important;
    }

    /* ── Name bar ── */
    .weapon-sheet .ws-name-bar {
      display: flex;
      align-items: center;
      gap: 6px;
      background: linear-gradient(to bottom, var(--ws-red), var(--ws-red-dark));
      padding: 2px 8px;
      height: 32px;
      box-sizing: border-box;
      flex-shrink: 0;
      margin-bottom: 2px;
    }
    .weapon-sheet .ws-name-bar img {
      width: 24px;
      height: 24px;
      border: 1px solid rgba(255,255,255,0.3);
      border-radius: 3px;
      cursor: pointer;
      flex-shrink: 0;
    }
    .weapon-sheet .ws-name-bar input[type="text"] {
      flex: 1;
      background: transparent;
      border: none;
      border-bottom: 1px solid rgba(255,255,255,0.4);
      color: var(--ws-white);
      font-size: 13px;
      font-weight: bold;
      padding: 0 4px;
      min-width: 0;
    }
    .weapon-sheet .ws-name-bar input[type="text"]::placeholder { color: rgba(255,255,255,0.5); }
    .weapon-sheet .ws-name-bar input[type="text"]:focus {
      border-bottom-color: rgba(255,255,255,0.9);
      outline: none;
    }

    /* ── Description accordion ── */
    .weapon-sheet .ws-description-accordion {
      border-bottom: 1px solid var(--ws-border);
    }
    .weapon-sheet .ws-description-accordion > summary {
      font-size: 9px;
      font-weight: bold;
      color: var(--ws-muted);
      text-transform: uppercase;
      letter-spacing: 0.04em;
      padding: 3px 8px;
      cursor: pointer;
      user-select: none;
      list-style: none;
      display: flex;
      align-items: center;
      gap: 4px;
      background: var(--ws-bg-alt);
    }
    .weapon-sheet .ws-description-accordion > summary::-webkit-details-marker { display: none; }
    .weapon-sheet .ws-description-accordion > summary::before { content: "▶"; font-size: 6px; opacity: 0.5; }
    .weapon-sheet .ws-description-accordion[open] > summary::before { content: "▼"; }
    .weapon-sheet .ws-description-accordion .editor { min-height: 80px; }
    .weapon-sheet .ws-description-accordion .editor-content { min-height: 80px; }

    /* ── Section headers ── */
    .weapon-sheet .ws-section { margin: 0; }
    .weapon-sheet .ws-section-header {
      background: linear-gradient(to bottom, var(--ws-red), var(--ws-red-dark));
      color: var(--ws-white);
      font-size: 10px;
      font-weight: bold;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      padding: 3px 8px;
      user-select: none;
    }
    .weapon-sheet .ws-section-body {
      padding: 5px 8px 6px;
      background: var(--ws-bg);
    }

    /* ── Rows and fields ── */
    .weapon-sheet .ws-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
      margin-bottom: 5px;
    }
    .weapon-sheet .ws-row:last-child { margin-bottom: 0; }
    .weapon-sheet .ws-field {
      display: flex;
      align-items: center;
      gap: 3px;
      flex-shrink: 0;
    }
    .weapon-sheet .ws-field.ws-full { flex: 1 1 100%; }
    .weapon-sheet .ws-label {
      font-size: 10px;
      font-weight: bold;
      color: var(--ws-muted);
      text-transform: uppercase;
      white-space: nowrap;
    }

    /* ── Inputs ── */
    .weapon-sheet input[type="number"] {
      width: 46px;
      text-align: center;
      border: 1px solid var(--ws-border);
      border-radius: 3px;
      padding: 2px 3px;
      font-size: 12px;
      background: var(--ws-white);
      color: var(--ws-text);
    }
    .weapon-sheet input[type="text"] {
      border: 1px solid var(--ws-border);
      border-radius: 3px;
      padding: 2px 5px;
      font-size: 11px;
      background: var(--ws-white);
      color: var(--ws-text);
    }
    .weapon-sheet .ws-name-bar input[type="text"] {
      border: none;
      border-bottom: 1px solid rgba(255,255,255,0.4);
      border-radius: 0;
      background: transparent;
      color: var(--ws-white);
      font-size: 13px;
      font-weight: bold;
    }
    .weapon-sheet select {
      border: 1px solid var(--ws-border);
      border-radius: 3px;
      padding: 2px 4px;
      font-size: 11px;
      background: var(--ws-white);
      color: var(--ws-text);
    }
    .weapon-sheet input[type="checkbox"] {
      width: 14px;
      height: 14px;
      cursor: pointer;
    }
    .weapon-sheet input:focus,
    .weapon-sheet select:focus {
      border-color: var(--ws-red-mid);
      outline: none;
    }
    .weapon-sheet .ws-input-wide { width: 100% !important; }
    .weapon-sheet .ws-input-sm  { width: 36px !important; }
  </style>

  {{!-- Name bar --}}
  <div class="ws-name-bar">
    <img src="{{item.img}}" data-edit="img" title="{{item.name}}">
    <input type="text" name="name" value="{{item.name}}" placeholder="Nombre del arma">
  </div>

  {{!-- Description (collapsible, starts closed) --}}
  <details class="ws-description-accordion">
    <summary>Descripción</summary>
    {{editor system.enrichedDescription target="system.description.value" button=true owner=true editable=true}}
  </details>

  {{!-- ── Stats ── --}}
  <div class="ws-section">
    <div class="ws-section-header">Stats</div>
    <div class="ws-section-body">
      <div class="ws-row">
        <div class="ws-field">
          <span class="ws-label">Calidad</span>
          <select name="system.quality.value">
            <option value="-10" {{#if (is 'eq' system.quality.value -10)}}selected{{/if}}>-10</option>
            <option value="-5"  {{#if (is 'eq' system.quality.value -5)}}selected{{/if}}>-5</option>
            <option value="0"   {{#if (is 'eq' system.quality.value 0)}}selected{{/if}}>0</option>
            <option value="5"   {{#if (is 'eq' system.quality.value 5)}}selected{{/if}}>5</option>
            <option value="10"  {{#if (is 'eq' system.quality.value 10)}}selected{{/if}}>10</option>
            <option value="15"  {{#if (is 'eq' system.quality.value 15)}}selected{{/if}}>15</option>
            <option value="20"  {{#if (is 'eq' system.quality.value 20)}}selected{{/if}}>20</option>
            <option value="25"  {{#if (is 'eq' system.quality.value 25)}}selected{{/if}}>25</option>
            <option value="30"  {{#if (is 'eq' system.quality.value 30)}}selected{{/if}}>30</option>
          </select>
        </div>
        <div class="ws-field">
          <span class="ws-label">Presencia</span>
          <input type="number" name="system.presence.base.value" value="{{system.presence.base.value}}">
        </div>
        <div class="ws-field">
          <span class="ws-label">Integridad</span>
          <input type="number" name="system.integrity.base.value" value="{{system.integrity.base.value}}">
        </div>
        <div class="ws-field">
          <span class="ws-label">Rotura</span>
          <input type="number" name="system.breaking.base.value" value="{{system.breaking.base.value}}">
        </div>
        <div class="ws-field">
          <span class="ws-label">Daño</span>
          <input type="number" name="system.damage.base.value" value="{{system.damage.base.value}}">
        </div>
        <div class="ws-field">
          <span class="ws-label">Ini</span>
          <input type="number" name="system.initiative.base.value" value="{{system.initiative.base.value}}">
        </div>
      </div>
      <div class="ws-row">
        <div class="ws-field ws-full">
          <span class="ws-label">Especial</span>
          <input type="text" class="ws-input-wide" name="system.special.value" value="{{system.special.value}}" placeholder="—">
        </div>
      </div>
    </div>
  </div>

  {{!-- ── Tipo ── --}}
  <div class="ws-section">
    <div class="ws-section-header">Tipo</div>
    <div class="ws-section-body">
      <div class="ws-row">
        <div class="ws-field">
          <span class="ws-label">Escudo</span>
          <input type="checkbox" name="system.isShield.value" {{checked system.isShield.value}}>
        </div>
        <div class="ws-field">
          <span class="ws-label">Tamaño</span>
          <select name="system.size.value">
            {{#each config.iterables.combat.weapon.sizes}}
            <option value="{{@key}}" {{#if (is 'eq' ../system.size.value @key)}}selected{{/if}}>{{localize this}}</option>
            {{/each}}
          </select>
        </div>
        <div class="ws-field">
          <span class="ws-label">Proporción</span>
          <select name="system.sizeProportion.value">
            {{#each config.iterables.combat.weapon.sizeProportions}}
            <option value="{{@key}}" {{#if (is 'eq' ../system.sizeProportion.value @key)}}selected{{/if}}>{{localize this}}</option>
            {{/each}}
          </select>
        </div>
        <div class="ws-field">
          <span class="ws-label">Manejabilidad</span>
          <select name="system.manageabilityType.value">
            {{#each config.iterables.combat.weapon.manageabilityTypes}}
            <option value="{{@key}}" {{#if (is 'eq' ../system.manageabilityType.value @key)}}selected{{/if}}>{{localize this}}</option>
            {{/each}}
          </select>
        </div>
      </div>
      <div class="ws-row">
        {{#if (or (is 'eq' system.manageabilityType.value 'one_hand') (is 'eq' system.manageabilityType.value 'one_or_two_hands'))}}
        <div class="ws-field">
          <span class="ws-label">FUE 1M</span>
          <input type="number" name="system.strRequired.oneHand.base.value" value="{{system.strRequired.oneHand.base.value}}">
        </div>
        {{/if}}
        {{#if (or (is 'eq' system.manageabilityType.value 'two_hands') (is 'eq' system.manageabilityType.value 'one_or_two_hands'))}}
        <div class="ws-field">
          <span class="ws-label">FUE 2M</span>
          <input type="number" name="system.strRequired.twoHands.base.value" value="{{system.strRequired.twoHands.base.value}}">
        </div>
        {{/if}}
      </div>
    </div>
  </div>

  {{!-- ── Críticos ── --}}
  {{#unless (and (is 'eq' system.isRanged.value true) (is 'eq' system.shotType.value 'shot'))}}
  <div class="ws-section">
    <div class="ws-section-header">Críticos</div>
    <div class="ws-section-body">
      <div class="ws-row">
        <div class="ws-field">
          <span class="ws-label">Principal</span>
          <select name="system.critic.primary.value">
            {{#each config.iterables.combat.weapon.criticTypes}}
            <option value="{{@key}}" {{#if (is 'eq' ../system.critic.primary.value @key)}}selected{{/if}}>{{localize this}}</option>
            {{/each}}
          </select>
        </div>
        {{#if (or (is 'eq' system.isRanged.value false) (is 'eq' system.shotType.value 'throw'))}}
        <div class="ws-field">
          <span class="ws-label">Secundario</span>
          <select name="system.critic.secondary.value">
            {{#each config.iterables.combat.weapon.criticTypesWithNone}}
            <option value="{{@key}}" {{#if (is 'eq' ../system.critic.secondary.value @key)}}selected{{/if}}>{{localize this}}</option>
            {{/each}}
          </select>
        </div>
        {{/if}}
      </div>
    </div>
  </div>
  {{/unless}}

  {{!-- ── Fijo ── --}}
  <div class="ws-section">
    <div class="ws-section-header">Valores fijos</div>
    <div class="ws-section-body">
      <div class="ws-row">
        <div class="ws-field">
          <span class="ws-label">Daño fijo</span>
          <input type="checkbox" name="system.damage.isFixed.value" {{checked system.damage.isFixed.value}}>
        </div>
        <div class="ws-field">
          <span class="ws-label">Ataque fijo</span>
          <input type="checkbox" name="system.attack.isFixed.value" {{checked system.attack.isFixed.value}}>
        </div>
        <div class="ws-field">
          <span class="ws-label">Parada fija</span>
          <input type="checkbox" name="system.block.isFixed.value" {{checked system.block.isFixed.value}}>
        </div>
        {{#if (or (is 'eq' system.attack.isFixed.value true) (is 'eq' system.block.isFixed.value true))}}
        <div class="ws-field">
          <span class="ws-label">ATK base</span>
          <input type="number" name="system.baseAtk.value" value="{{system.baseAtk.value}}">
        </div>
        <div class="ws-field">
          <span class="ws-label">DEF base</span>
          <input type="number" name="system.baseDef.value" value="{{system.baseDef.value}}">
        </div>
        {{/if}}
      </div>
    </div>
  </div>

  {{!-- ── A distancia ── --}}
  <div class="ws-section">
    <div class="ws-section-header">A distancia</div>
    <div class="ws-section-body">
      <div class="ws-row">
        <div class="ws-field">
          <span class="ws-label">Es a distancia</span>
          <input type="checkbox" name="system.isRanged.value" {{checked system.isRanged.value}}>
        </div>
        {{#if system.isRanged.value}}
        <div class="ws-field">
          <span class="ws-label">Alcance</span>
          <input type="number" name="system.range.base.value" value="{{system.range.base.value}}">
        </div>
        <div class="ws-field">
          <span class="ws-label">Tipo</span>
          <select name="system.shotType.value">
            {{#each config.iterables.combat.weapon.shotTypes}}
            <option value="{{@key}}" {{#if (is 'eq' ../system.shotType.value @key)}}selected{{/if}}>{{localize this}}</option>
            {{/each}}
          </select>
        </div>
        {{#if (is 'eq' system.shotType.value 'throw')}}
        <div class="ws-field">
          <span class="ws-label">Cadencia</span>
          <input type="text" class="ws-input-sm" name="system.cadence.value" value="{{system.cadence.value}}">
        </div>
        {{else}}
        <div class="ws-field">
          <span class="ws-label">FUE propia</span>
          <input type="checkbox" name="system.hasOwnStr.value" {{checked system.hasOwnStr.value}}>
        </div>
        {{#if system.hasOwnStr.value}}
        <div class="ws-field">
          <span class="ws-label">FUE arma</span>
          <input type="number" name="system.weaponStrength.base.value" value="{{system.weaponStrength.base.value}}">
        </div>
        {{/if}}
        <div class="ws-field">
          <span class="ws-label">Recarga</span>
          <input type="number" name="system.reload.base.value" value="{{system.reload.base.value}}">
        </div>
        {{/if}}
        {{/if}}
      </div>
    </div>
  </div>

</form>
